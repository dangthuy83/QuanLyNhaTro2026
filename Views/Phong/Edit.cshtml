@model QuanLyNhaTro.Models.Phong
@{
    ViewData["Title"] = "Sửa phòng";
    ViewData["ActiveMenu"] = "phong";
    var danhSachNha = ViewBag.DanhSachNha as IEnumerable<QuanLyNhaTro.Models.Nha> ?? [];
    var dichVuPhong = ViewBag.DichVuPhong as IEnumerable<QuanLyNhaTro.Models.PhongDichVu> ?? [];
    var coNha = danhSachNha.Any();
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Sửa phòng — @Model.TenPhong</h5>
</div>

<div class="card shadow-sm" style="max-width:640px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Nhà <span class="text-danger">*</span></label>
                <select asp-for="NhaId" class="form-select" required disabled="@(!coNha)">
                    <option value="">-- Chọn nhà --</option>
                    @foreach (var nha in danhSachNha)
                    {
                        <option value="@nha.Id">@nha.TenNha</option>
                    }
                </select>
                <span asp-validation-for="NhaId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Tên phòng <span class="text-danger">*</span></label>
                <input asp-for="TenPhong" class="form-control" required />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">Diện tích (m²)</label>
                    <input asp-for="DienTich" type="number" step="0.1" min="0" class="form-control" />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Sức chứa (người)</label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Giá niêm yết (đ)</label>
                <input asp-for="GiaThueMacDinh" type="number" min="0" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Trạng thái phòng</label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="Trong">Trống</option>
                    <option value="DangThue">Đang thuê</option>
                    <option value="DangSuaChua">Đang sửa chữa</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Ghi chú</label>
                <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@(!coNha)">Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>

        @if (dichVuPhong.Any())
        {
            <hr />
            <p class="fw-semibold mb-2">Đơn giá dịch vụ</p>
            <table class="table table-sm">
                <thead class="table-light">
                    <tr><th>Dịch vụ</th><th>Loại</th><th class="text-end">Đơn giá</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var pdv in dichVuPhong)
                    {
                        <tr>
                            <td>@pdv.DichVu?.TenDichVu</td>
                            <td>
                                <span class="badge bg-light text-dark border">@pdv.DichVu?.LoaiTinhPhiHienThi</span>
                                @if (pdv.DichVu?.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh)
                                {
                                    <span class="badge bg-light text-dark border">@pdv.DichVu.CachTinhCoDinhHienThi</span>
                                }
                            </td>
                            <td class="text-end">
                                <input type="number" class="form-control form-control-sm text-end"
                                       style="width:120px; display:inline-block"
                                       id="gia_@pdv.Id" value="@pdv.DonGia" min="0" />
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        onclick="capNhatGia(@pdv.Id)">Lưu</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
<script>
    async function capNhatGia(id) {
        const donGia = document.getElementById('gia_' + id).value;
        const res = await fetch('/Phong/CapNhatDonGia', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `phongDichVuId=${id}&donGia=${donGia}`
        });
        if (res.ok) alert('Đã cập nhật đơn giá.');
    }
</script>
}
