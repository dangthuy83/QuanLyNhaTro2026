@model QuanLyNhaTro.Models.Phong
@using System.Globalization
@{
    ViewData["Title"] = "Sửa phòng";
    ViewData["ActiveMenu"] = "phong";
    var danhSachNha = ViewBag.DanhSachNha as IEnumerable<QuanLyNhaTro.Models.Nha> ?? [];
    var dichVuPhong = ViewBag.DichVuPhong as IEnumerable<QuanLyNhaTro.Models.PhongDichVu> ?? [];
    var danhSachDichVu = ViewBag.DanhSachDichVu as IEnumerable<QuanLyNhaTro.Models.DichVu> ?? [];
    var dichVuTheoId = dichVuPhong.ToDictionary(x => x.DichVuId);
    var coNha = danhSachNha.Any();
    var khoaDoiNha = ViewBag.KhoaDoiNha == true;
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Sửa phòng — @Model.TenPhong</h5>
</div>

<div class="card shadow-sm" style="max-width:640px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Nhà <span class="text-danger">*</span></label>
                <select asp-for="NhaId" class="form-select" required disabled="@(!coNha || khoaDoiNha)">
                    <option value="">-- Chọn nhà --</option>
                    @foreach (var nha in danhSachNha)
                    {
                        <option value="@nha.Id">@nha.TenNha</option>
                    }
                </select>
                <span asp-validation-for="NhaId" class="text-danger small"></span>
                @if (khoaDoiNha)
                {
                    <div class="form-text">Phòng đã có dữ liệu nghiệp vụ nên không thể chuyển sang Nhà khác.</div>
                }
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Tên phòng <span class="text-danger">*</span></label>
                <input asp-for="TenPhong" class="form-control" required />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">Diện tích (m²)</label>
                    <input asp-for="DienTich" type="number" step="0.1" min="0" class="form-control" />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Sức chứa (người)</label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Giá niêm yết (đ)</label>
                <input asp-for="GiaThueMacDinh" type="number" min="0" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Trạng thái phòng</label>
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="dangSuaChua"
                           name="dangSuaChua" value="true" checked="@(Model.TrangThai == "DangSuaChua")" />
                    <label class="form-check-label" for="dangSuaChua">Chỉ đặt tay khi phòng đang sửa chữa</label>
                </div>
                <select asp-for="TrangThai" class="form-select" disabled>
                    <option value="Trong">Trống</option>
                    <option value="DangThue">Đang thuê</option>
                    <option value="DangSuaChua">Đang sửa chữa</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Ghi chú</label>
                <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
            </div>

            @if (danhSachDichVu.Any())
            {
                <hr />
                <p class="fw-semibold mb-2">Dịch vụ cung cấp tại phòng</p>
                @foreach (var dv in danhSachDichVu)
                {
                    dichVuTheoId.TryGetValue(dv.Id, out var pdv);
                    var isChecked = dv.BatBuocKhiThue || pdv?.DangApDung == true;
                    var donGia = pdv?.DonGia ?? dv.DonGiaMacDinh;
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="form-check" style="min-width:220px">
                            <input class="form-check-input dv-check" type="checkbox"
                                   id="dv_@dv.Id" name="dichVuIds" value="@dv.Id"
                                   checked="@isChecked"
                                   onclick="@(dv.BatBuocKhiThue ? "return false" : null)" />
                            <label class="form-check-label" for="dv_@dv.Id">
                                @dv.TenDichVu
                                @if (dv.BatBuocKhiThue)
                                {
                                    <span class="badge bg-danger ms-1">Bắt buộc</span>
                                }
                                <small class="text-muted">(@dv.LoaiTinhPhiHienThi)</small>
                            </label>
                        </div>
                        <div class="input-group input-group-sm" style="max-width:170px">
                            <input type="number" min="0" name="donGias" id="gia_@dv.Id"
                                   class="form-control dv-gia" value="@donGia.ToString("0.##", CultureInfo.InvariantCulture)"
                                   disabled="@(!isChecked)" readonly="@(pdv != null)" />
                            <span class="input-group-text">đ</span>
                        </div>
                        @if (pdv != null)
                        {
                            <a asp-controller="Gia" asp-action="DichVu" asp-route-phongDichVuId="@pdv.Id"
                               class="btn btn-sm btn-outline-warning">Đổi giá theo kỳ</a>
                        }
                    </div>
                }
                <div class="form-text">Tắt dịch vụ ở phòng không làm thay đổi hợp đồng đã đăng ký. Giá dịch vụ hiện có chỉ thay đổi qua luồng giá theo kỳ.</div>
            }

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@(!coNha)">Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.dv-check').forEach(cb => {
        cb.addEventListener('change', function () {
            const input = document.getElementById('gia_' + this.value);
            if (input) input.disabled = !this.checked;
        });
    });
</script>
}
