@model QuanLyNhaTro.Models.GanDichVuHangLoatViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Gán dịch vụ hàng loạt";
    ViewData["ActiveMenu"] = "phong";
    var dichVu = Model.DichVuDangChon;
}

<div class="rooms-page rooms-bulk-page">
    <a asp-action="Index" class="rooms-back-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Danh sách phòng</a>

    <header class="app-page-header">
        <div class="app-page-heading">
            <h1>Gán dịch vụ hàng loạt</h1>
            <p class="app-page-subtitle">Gán mới hoặc bật lại một dịch vụ cho nhiều phòng. Đơn giá đang dùng của phòng đã có dịch vụ luôn được giữ nguyên.</p>
        </div>
    </header>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div class="rooms-flash-stack" aria-live="polite">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="status">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div>
            }
        </div>
    }

    @if (Model.SoPhongDangThueThieuKhach > 0)
    {
        <div class="app-notice is-warning mb-4" role="alert">
            <svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg>
            <div>
                <strong>@Model.SoPhongDangThueThieuKhach phòng đang thuê chưa gắn khách</strong>
                <div>Dịch vụ tính theo người sẽ bị chặn khi preview hoặc chốt hóa đơn cho tới khi bổ sung khách.</div>
            </div>
        </div>
    }

    <form method="get" class="app-panel rooms-filter-panel" aria-labelledby="bulk-filter-heading">
        <h2 id="bulk-filter-heading" class="visually-hidden">Bộ lọc phòng và dịch vụ</h2>
        <div class="rooms-filter-grid">
            <div class="rooms-filter-field">
                <label for="bulk-service">Dịch vụ</label>
                <select id="bulk-service" name="dichVuId" class="form-select" required>
                    @foreach (var service in Model.DanhSachDichVu)
                    {
                        <option value="@service.Id" selected="@(Model.DichVuId == service.Id)">
                            @service.TenDichVu — @service.LoaiTinhPhiHienThi@(service.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh ? $" / {service.CachTinhCoDinhHienThi}" : "")
                        </option>
                    }
                </select>
            </div>
            <div class="rooms-filter-field">
                <label for="bulk-house">Nhà</label>
                <select id="bulk-house" name="nhaId" class="form-select">
                    <option value="">Tất cả nhà</option>
                    @foreach (var nha in Model.DanhSachNha)
                    {
                        <option value="@nha.Id" selected="@(Model.NhaId == nha.Id)">@nha.TenNha</option>
                    }
                </select>
            </div>
            <div class="rooms-filter-field">
                <label for="bulk-room-status">Trạng thái phòng</label>
                <select id="bulk-room-status" name="trangThai" class="form-select">
                    <option value="DangThue" selected="@(Model.TrangThai == "DangThue")">Đang thuê</option>
                    <option value="Trong" selected="@(Model.TrangThai == "Trong")">Trống</option>
                    <option value="DangSuaChua" selected="@(Model.TrangThai == "DangSuaChua")">Đang sửa chữa</option>
                    <option value="TatCa" selected="@(Model.TrangThai == "TatCa")">Tất cả</option>
                </select>
            </div>
            <div class="rooms-filter-reset">
                <button class="btn btn-primary" type="submit"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-filter"></use></svg>Áp dụng</span></button>
            </div>
        </div>
    </form>

    <section class="rooms-bulk-context" aria-label="Ngữ cảnh gán dịch vụ">
        <div>
            <div class="rooms-bulk-context-label">Dịch vụ đang chọn</div>
            <div class="rooms-bulk-context-value">@(dichVu?.TenDichVu ?? "Chưa có dịch vụ")</div>
            <div class="rooms-cell-meta">@dichVu?.LoaiTinhPhiHienThi@if (dichVu?.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh) { <text> · @dichVu.CachTinhCoDinhHienThi</text> }</div>
        </div>
        <div>
            <div class="rooms-bulk-context-label">Theo bộ lọc</div>
            <div class="rooms-bulk-context-value">@Model.Rows.Count phòng</div>
            <div class="rooms-cell-meta">Đang áp dụng: @Model.SoPhongDaGan · Chưa gán/đang tắt: @Model.SoPhongChuaGan</div>
        </div>
        <div>
            <div class="rooms-bulk-context-label">Giá khi gán mới</div>
            <div class="rooms-bulk-context-value">@Model.DonGia.ToString("N0") đ</div>
            <div class="rooms-cell-meta">Không ghi đè đơn giá hiện có.</div>
        </div>
    </section>

    <form asp-action="GanDichVuHangLoat" method="post" data-bulk-assignment>
        @Html.AntiForgeryToken()
        <input type="hidden" name="dichVuId" value="@Model.DichVuId" />
        <input type="hidden" name="nhaId" value="@Model.NhaId" />
        <input type="hidden" name="trangThai" value="@Model.TrangThai" />

        <div asp-validation-summary="All" class="mb-3" role="alert"></div>

        <section class="app-panel" aria-labelledby="bulk-room-list-heading">
            <header class="app-panel-header">
                <h2 id="bulk-room-list-heading">Chọn phòng để gán</h2>
                <span class="rooms-selection-count" data-selection-count aria-live="polite">0 phòng đã chọn</span>
            </header>

            <div class="rooms-bulk-toolbar">
                <div>
                    <label for="bulk-price" class="form-label fw-semibold">Đơn giá khi gán mới</label>
                    <div class="input-group">
                        <input id="bulk-price" name="donGia" type="number" min="0" step="1" inputmode="numeric"
                               class="form-control" value="@Model.DonGia.ToString("0.##", CultureInfo.InvariantCulture)"
                               aria-describedby="bulk-price-hint" />
                        <span class="input-group-text">đ</span>
                    </div>
                </div>
                <div id="bulk-price-hint" class="app-notice is-info">
                    <svg class="app-icon" aria-hidden="true"><use href="#icon-info"></use></svg>
                    <div>Phòng chưa từng có dịch vụ dùng giá này. Phòng đã có dịch vụ chỉ được bật lại và giữ nguyên đơn giá hiện tại.</div>
                </div>
            </div>

            @if (Model.Rows.Any())
            {
                <div class="rooms-bulk-head" aria-hidden="true">
                    <span></span><span>Nhà / phòng</span><span>Hợp đồng</span><span>Số lượng</span><span>Dịch vụ</span><span>Đơn giá hiện tại</span><span class="text-end">Thành tiền dự kiến</span>
                </div>
                <ul class="rooms-bulk-list">
                    @foreach (var row in Model.Rows)
                    {
                        var thieuKhach = Model.LaDichVuTheoNguoi && row.HopDongId.HasValue && row.SoKhach == 0;
                        var soLuongDuKien = ResolveSoLuongDuKien(Model, row);
                        var donGiaDuKien = row.DaGan && row.DonGiaHienTai.HasValue ? row.DonGiaHienTai.Value : Model.DonGia;
                        <li class="rooms-bulk-row @(thieuKhach ? "is-warning" : null)">
                            <label class="rooms-bulk-check">
                                <input class="form-check-input" type="checkbox" name="phongIds" value="@row.PhongId" data-room-check />
                                <span class="visually-hidden">Chọn phòng @row.TenPhong tại @row.TenNha</span>
                            </label>
                            <div class="rooms-bulk-room">
                                <a asp-action="Details" asp-route-id="@row.PhongId" class="rooms-room-name">@row.TenPhong</a>
                                <div class="rooms-room-meta">@row.TenNha</div>
                                <partial name="_StatusBadge" model="row.TrangThai" />
                            </div>
                            <div class="rooms-bulk-contract">
                                @if (row.HopDongId.HasValue)
                                {
                                    <a asp-controller="HopDong" asp-action="Details" asp-route-id="@row.HopDongId">Hợp đồng #@row.HopDongId</a>
                                    <div class="rooms-cell-meta">@row.SoKhach khách@(thieuKhach ? " · Cần bổ sung khách" : "")</div>
                                }
                                else
                                {
                                    <span class="rooms-cell-meta">Chưa có hợp đồng hiệu lực</span>
                                }
                            </div>
                            <div class="rooms-bulk-quantity">
                                <span class="rooms-field-label">Số lượng dự kiến</span>
                                @if (Model.LaDichVuTheoChiSo)
                                {
                                    <span class="rooms-cell-meta">Theo chỉ số</span>
                                }
                                else
                                {
                                    <strong>@soLuongDuKien.ToString("N0")</strong>
                                }
                            </div>
                            <div class="rooms-bulk-service-state">
                                @if (row.DaGan && row.DangApDung)
                                {
                                    <span class="app-status-badge is-success"><span class="app-status-dot" aria-hidden="true"></span>Đang áp dụng</span>
                                }
                                else if (row.DaGan)
                                {
                                    <span class="app-status-badge is-warning"><span class="app-status-dot" aria-hidden="true"></span>Đang tắt</span>
                                }
                                else
                                {
                                    <span class="app-status-badge is-neutral"><span class="app-status-dot" aria-hidden="true"></span>Chưa gán</span>
                                }
                                <div class="rooms-current-price-mobile rooms-cell-meta">Giá hiện tại: @(row.DonGiaHienTai.HasValue ? row.DonGiaHienTai.Value.ToString("N0") + " đ" : "Chưa có")</div>
                            </div>
                            <div class="rooms-bulk-current-price rooms-money">@(row.DonGiaHienTai.HasValue ? row.DonGiaHienTai.Value.ToString("N0") + " đ" : "—")</div>
                            <div class="rooms-bulk-amount">
                                @if (Model.LaDichVuTheoChiSo)
                                {
                                    <span class="rooms-cell-meta">Nhập theo chỉ số</span>
                                }
                                else
                                {
                                    <strong class="rooms-money" data-preview-amount data-quantity="@soLuongDuKien.ToString("0.##", CultureInfo.InvariantCulture)" data-fixed-price="@(row.DaGan ? donGiaDuKien.ToString("0.##", CultureInfo.InvariantCulture) : null)">
                                        @((soLuongDuKien * donGiaDuKien).ToString("N0")) đ
                                    </strong>
                                    <div class="rooms-cell-meta">@soLuongDuKien.ToString("N0") × <span data-preview-unit-price data-fixed-price="@(row.DaGan ? donGiaDuKien.ToString("0.##", CultureInfo.InvariantCulture) : null)">@donGiaDuKien.ToString("N0")</span></div>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="app-empty-state">
                    <div><svg class="app-icon" aria-hidden="true"><use href="#icon-filter"></use></svg><h3>Không có phòng phù hợp</h3><p>Đổi Nhà, trạng thái hoặc dịch vụ trong bộ lọc để tiếp tục.</p></div>
                </div>
            }

            <footer class="rooms-bulk-footer">
                <label class="rooms-bulk-check">
                    <input class="form-check-input" type="checkbox" data-check-all disabled="@(!Model.Rows.Any())" />
                    <span>Chọn tất cả phòng đang hiển thị</span>
                </label>
                <button class="btn btn-primary" type="submit" data-bulk-submit disabled>
                    <span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-service"></use></svg>Gán / cập nhật dịch vụ</span>
                </button>
            </footer>
        </section>
    </form>
</div>

@section Scripts {
    <script src="~/js/rooms.js" asp-append-version="true"></script>
}

@functions {
    static decimal ResolveSoLuongDuKien(QuanLyNhaTro.Models.GanDichVuHangLoatViewModel model, QuanLyNhaTro.Models.GanDichVuHangLoatRow row)
    {
        if (model.LaDichVuTheoNguoi) return row.SoKhach;
        if (model.LaDichVuTheoPhong) return 1;
        return 0;
    }
}
