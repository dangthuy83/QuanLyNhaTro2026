@model QuanLyNhaTro.Models.GanDichVuHangLoatViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Gán dịch vụ hàng loạt";
    ViewData["ActiveMenu"] = "phong";
    var dichVu = Model.DichVuDangChon;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h5 class="mb-1">Gán dịch vụ hàng loạt</h5>
        <div class="text-muted small">Cập nhật `PhongDichVu.DonGia`, là đơn giá thật sự được dùng khi lập hóa đơn.</div>
    </div>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Danh sách phòng
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (Model.SoPhongDangThueThieuKhach > 0)
{
    <div class="alert alert-warning py-2">
        <i class="bi bi-exclamation-triangle me-1"></i>
        Có @Model.SoPhongDangThueThieuKhach phòng đang có hợp đồng hiệu lực nhưng chưa gắn khách.
        Dịch vụ tính theo người sẽ bị chặn khi preview/chốt hóa đơn nếu chưa bổ sung khách.
    </div>
}

<form method="get" class="border rounded p-3 mb-3 bg-light">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small text-muted mb-1">Dịch vụ</label>
            <select name="dichVuId" class="form-select form-select-sm" required>
                @foreach (var dv in Model.DanhSachDichVu)
                {
                    <option value="@dv.Id" selected="@(Model.DichVuId == dv.Id)">
                        @dv.TenDichVu - @dv.LoaiTinhPhiHienThi@(dv.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh ? $" / {dv.CachTinhCoDinhHienThi}" : "")
                    </option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Nhà</label>
            <select name="nhaId" class="form-select form-select-sm">
                <option value="">Tất cả nhà</option>
                @foreach (var nha in Model.DanhSachNha)
                {
                    <option value="@nha.Id" selected="@(Model.NhaId == nha.Id)">@nha.TenNha</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Trạng thái phòng</label>
            <select name="trangThai" class="form-select form-select-sm">
                <option value="DangThue" selected="@(Model.TrangThai == "DangThue")">Đang thuê</option>
                <option value="Trong" selected="@(Model.TrangThai == "Trong")">Trống</option>
                <option value="DangSuaChua" selected="@(Model.TrangThai == "DangSuaChua")">Đang sửa</option>
                <option value="TatCa" selected="@(Model.TrangThai == "TatCa")">Tất cả</option>
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button class="btn btn-sm btn-primary">Lọc</button>
        </div>
    </div>
</form>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Dịch vụ đang chọn</div>
            <div class="fw-semibold">@dichVu?.TenDichVu</div>
            <div class="small text-muted">
                @dichVu?.LoaiTinhPhiHienThi
                @if (dichVu?.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh)
                {
                    <span> / @dichVu.CachTinhCoDinhHienThi</span>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Theo bộ lọc</div>
            <div class="fs-5 fw-semibold">@Model.Rows.Count phòng</div>
            <div class="small text-muted">Đã gán: @Model.SoPhongDaGan / Chưa gán: @Model.SoPhongChuaGan</div>
            @if (Model.SoPhongDangThueThieuKhach > 0)
            {
                <div class="small text-danger">Thiếu khách: @Model.SoPhongDangThueThieuKhach phòng</div>
            }
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Giá gợi ý từ danh mục</div>
            <div class="fs-5 fw-semibold">@Model.DonGia.ToString("N0") đ</div>
            <div class="small text-muted">Có thể sửa trước khi lưu cho phòng.</div>
        </div>
    </div>
</div>

<form asp-action="GanDichVuHangLoat" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="dichVuId" value="@Model.DichVuId" />
    <input type="hidden" name="nhaId" value="@Model.NhaId" />
    <input type="hidden" name="trangThai" value="@Model.TrangThai" />

    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

    <div class="card shadow-sm">
        <div class="card-body border-bottom">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Đơn giá áp dụng cho các phòng đã chọn</label>
                    <div class="input-group input-group-sm">
                        <input name="donGia" type="number" min="0" step="1" class="form-control"
                               value="@Model.DonGia.ToString("0.##", CultureInfo.InvariantCulture)" />
                        <span class="input-group-text">đ</span>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="small text-muted">
                        Nếu phòng đã có dịch vụ này, hệ thống sẽ cập nhật đơn giá và bật lại trạng thái áp dụng.
                        Nếu phòng chưa có, hệ thống sẽ gán mới.
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:48px">
                            <input class="form-check-input" type="checkbox" id="checkAll" />
                        </th>
                        <th>Nhà / phòng</th>
                        <th>Hợp đồng</th>
                        <th class="text-end">Số khách</th>
                        <th>Trạng thái dịch vụ</th>
                        <th class="text-end">Đơn giá hiện tại</th>
                        <th class="text-end">Số lượng dự kiến</th>
                        <th class="text-end">Thành tiền dự kiến</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        var thieuKhach = Model.LaDichVuTheoNguoi && row.HopDongId.HasValue && row.SoKhach == 0;
                        var soLuongDuKien = ResolveSoLuongDuKien(Model, row);
                        <tr class="@(thieuKhach ? "table-warning" : "")">
                            <td>
                                <input class="form-check-input room-check" type="checkbox" name="phongIds" value="@row.PhongId" />
                            </td>
                            <td>
                                <div class="text-muted small">@row.TenNha</div>
                                <a asp-action="Details" asp-route-id="@row.PhongId" class="fw-semibold text-decoration-none">@row.TenPhong</a>
                                <div class="small">@Html.Raw(TrangThaiPhongBadge(row.TrangThai))</div>
                            </td>
                            <td>
                                @if (row.HopDongId.HasValue)
                                {
                                    <a asp-controller="HopDong" asp-action="Details" asp-route-id="@row.HopDongId" class="text-decoration-none">
                                        HD #@row.HopDongId
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">Chưa có hợp đồng hiệu lực</span>
                                }
                            </td>
                            <td class="text-end @(row.HopDongId.HasValue && row.SoKhach == 0 ? "text-danger fw-semibold" : "")">
                                @row.SoKhach
                                @if (thieuKhach)
                                {
                                    <div class="small">Cần bổ sung khách</div>
                                }
                            </td>
                            <td>
                                @if (row.DaGan && row.DangApDung)
                                {
                                    <span class="badge bg-success">Đang áp dụng</span>
                                }
                                else if (row.DaGan)
                                {
                                    <span class="badge bg-warning text-dark">Đang tắt</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Chưa gán</span>
                                }
                            </td>
                            <td class="text-end">@(row.DonGiaHienTai.HasValue ? row.DonGiaHienTai.Value.ToString("N0") + " đ" : "-")</td>
                            <td class="text-end">
                                @if (Model.LaDichVuTheoChiSo)
                                {
                                    <span class="text-muted small">Theo chỉ số</span>
                                }
                                else
                                {
                                    <span>@soLuongDuKien.ToString("N0")</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (Model.LaDichVuTheoChiSo)
                                {
                                    <span class="text-muted small">Nhập chỉ số</span>
                                }
                                else
                                {
                                    <span class="preview-amount" data-quantity="@soLuongDuKien.ToString("0.##", CultureInfo.InvariantCulture)">
                                        @((soLuongDuKien * Model.DonGia).ToString("N0")) đ
                                    </span>
                                    <div class="small text-muted">
                                        @soLuongDuKien.ToString("N0") x <span class="preview-unit-price">@Model.DonGia.ToString("N0")</span>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">Không có phòng nào khớp bộ lọc.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center p-3 border-top flex-wrap gap-2">
            <div class="small text-muted">Chỉ các phòng được tick mới được gán/cập nhật.</div>
            <button class="btn btn-primary" type="submit" disabled="@(!Model.Rows.Any())">
                Gán/cập nhật dịch vụ
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const checkAll = document.getElementById('checkAll');
        const priceInput = document.querySelector('[name=donGia]');
        const currencyFormatter = new Intl.NumberFormat('vi-VN', { maximumFractionDigits: 0 });

        function refreshPreviewAmounts() {
            const price = Number(priceInput?.value || 0);
            document.querySelectorAll('.preview-amount').forEach((element) => {
                const quantity = Number(element.dataset.quantity || 0);
                element.textContent = `${currencyFormatter.format(quantity * price)} đ`;
            });
            document.querySelectorAll('.preview-unit-price').forEach((element) => {
                element.textContent = currencyFormatter.format(price);
            });
        }

        checkAll?.addEventListener('change', () => {
            document.querySelectorAll('.room-check').forEach((checkbox) => {
                checkbox.checked = checkAll.checked;
            });
        });
        priceInput?.addEventListener('input', refreshPreviewAmounts);
    </script>
}

@functions {
    static decimal ResolveSoLuongDuKien(QuanLyNhaTro.Models.GanDichVuHangLoatViewModel model, QuanLyNhaTro.Models.GanDichVuHangLoatRow row)
    {
        if (model.LaDichVuTheoNguoi) return row.SoKhach;
        if (model.LaDichVuTheoPhong) return 1;
        return 0;
    }

    static string TrangThaiPhongBadge(string tt) => tt switch
    {
        "DangThue" => "<span class='badge bg-success'>Đang thuê</span>",
        "DangSuaChua" => "<span class='badge bg-warning text-dark'>Đang sửa</span>",
        _ => "<span class='badge bg-secondary'>Trống</span>"
    };
}
