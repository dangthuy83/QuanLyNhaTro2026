@model QuanLyNhaTro.Models.Phong
@using System.Globalization
@{
    ViewData["Title"] = "Thêm phòng";
    ViewData["ActiveMenu"] = "phong";
    var danhSachNha = (ViewBag.DanhSachNha as IEnumerable<QuanLyNhaTro.Models.Nha> ?? []).ToList();
    var danhSachDichVu = (ViewBag.DanhSachDichVu as IEnumerable<QuanLyNhaTro.Models.DichVu> ?? []).ToList();
    var coNha = danhSachNha.Any();
}

<div class="rooms-page rooms-form-page">
    <a asp-action="Index" class="rooms-back-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Danh sách phòng</a>

    <header class="app-page-header">
        <div class="app-page-heading">
            <h1>Thêm phòng mới</h1>
            <p class="app-page-subtitle">Khai báo thông tin cơ bản và các dịch vụ có thể cung cấp tại phòng. Phòng mới luôn bắt đầu ở trạng thái Trống.</p>
        </div>
    </header>

    @if (!coNha)
    {
        <div class="app-notice is-warning mb-4" role="alert">
            <svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg>
            <div><strong>Chưa thể thêm phòng</strong><div>Cần có ít nhất một Nhà. Hãy <a asp-controller="Nha" asp-action="Index">tạo Nhà</a> trước khi tiếp tục.</div></div>
        </div>
    }

    <form asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="mb-3" role="alert"></div>

        <div class="rooms-form-shell">
            <div class="rooms-form-column">
                <section class="app-panel" aria-labelledby="new-room-information-heading">
                    <header class="app-panel-header"><h2 id="new-room-information-heading">Thông tin phòng</h2></header>
                    <div class="app-panel-body rooms-form-grid">
                        <div class="rooms-form-field">
                            <label asp-for="NhaId" class="form-label">Nhà <span class="rooms-required" aria-hidden="true">*</span></label>
                            <select asp-for="NhaId" class="form-select" required disabled="@(!coNha)" aria-required="true">
                                <option value="">Chọn Nhà</option>
                                @foreach (var nha in danhSachNha)
                                {
                                    <option value="@nha.Id">@nha.TenNha</option>
                                }
                            </select>
                            <span asp-validation-for="NhaId"></span>
                        </div>

                        <div class="rooms-form-field">
                            <label asp-for="TenPhong" class="form-label">Tên phòng <span class="rooms-required" aria-hidden="true">*</span></label>
                            <input asp-for="TenPhong" class="form-control" placeholder="Ví dụ: P01, A102" required aria-required="true" autocomplete="off" />
                            <span asp-validation-for="TenPhong"></span>
                        </div>

                        <div class="rooms-form-field">
                            <label asp-for="DienTich" class="form-label">Diện tích (m²)</label>
                            <input asp-for="DienTich" type="number" step="0.1" min="0" class="form-control" inputmode="decimal" placeholder="Ví dụ: 24" />
                            <span asp-validation-for="DienTich"></span>
                        </div>

                        <div class="rooms-form-field">
                            <label asp-for="GiaThueMacDinh" class="form-label">Giá thuê niêm yết (đ)</label>
                            <input asp-for="GiaThueMacDinh" type="number" min="0" step="1" class="form-control"
                                   inputmode="numeric" data-money-preview="room-rent-preview" aria-describedby="room-rent-preview room-rent-hint" />
                            <div id="room-rent-preview" class="rooms-money-preview">@Model.GiaThueMacDinh.ToString("N0", CultureInfo.InvariantCulture) đ</div>
                            <div id="room-rent-hint" class="rooms-form-hint">Giá thỏa thuận thực tế được nhập trong hợp đồng.</div>
                            <span asp-validation-for="GiaThueMacDinh"></span>
                        </div>

                        <div class="rooms-form-field is-wide">
                            <label asp-for="GhiChu" class="form-label">Ghi chú</label>
                            <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Thông tin vị trí, nội thất hoặc lưu ý vận hành"></textarea>
                            <span asp-validation-for="GhiChu"></span>
                        </div>
                    </div>
                </section>

                @if (danhSachDichVu.Any())
                {
                    <section class="app-panel" aria-labelledby="new-room-services-heading">
                        <header class="app-panel-header">
                            <div><h2 id="new-room-services-heading">Dịch vụ tại phòng</h2><div class="rooms-cell-meta">Chọn dịch vụ và đơn giá áp dụng ban đầu.</div></div>
                        </header>
                        <div>
                            @foreach (var dichVu in danhSachDichVu)
                            {
                                var pricePreviewId = $"new-service-price-{dichVu.Id}";
                                <div class="rooms-service-option" data-service-row>
                                    <div class="rooms-service-option-main">
                                        <input class="form-check-input" type="checkbox" id="service-@dichVu.Id"
                                               value="@dichVu.Id" name="dichVuIds" checked
                                               data-service-toggle data-price-target="service-price-@dichVu.Id"
                                               onclick="@(dichVu.BatBuocKhiThue ? "return false" : null)" />
                                        <label class="form-check-label" for="service-@dichVu.Id">
                                            <span class="rooms-service-option-title">
                                                @dichVu.TenDichVu
                                                @if (dichVu.BatBuocKhiThue)
                                                {
                                                    <span class="app-status-badge is-danger"><span class="app-status-dot" aria-hidden="true"></span>Bắt buộc</span>
                                                }
                                            </span>
                                            <span class="rooms-service-option-meta">
                                                @dichVu.LoaiTinhPhiHienThi@if (dichVu.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh) { <text> · @dichVu.CachTinhCoDinhHienThi</text> }
                                            </span>
                                        </label>
                                    </div>
                                    <div class="rooms-service-option-price">
                                        <label class="visually-hidden" for="service-price-@dichVu.Id">Đơn giá @dichVu.TenDichVu</label>
                                        <div class="input-group">
                                            <input id="service-price-@dichVu.Id" name="donGias" type="number" min="0" step="1"
                                                   class="form-control" inputmode="numeric"
                                                   value="@dichVu.DonGiaMacDinh.ToString("0.##", CultureInfo.InvariantCulture)"
                                                   data-money-preview="@pricePreviewId" />
                                            <span class="input-group-text">đ</span>
                                        </div>
                                        <div id="@pricePreviewId" class="rooms-money-preview">@dichVu.DonGiaMacDinh.ToString("N0", CultureInfo.InvariantCulture) đ</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>

            <aside class="rooms-form-column rooms-form-sidebar">
                <section class="app-panel" aria-labelledby="new-room-state-heading">
                    <header class="app-panel-header"><h2 id="new-room-state-heading">Sau khi lưu</h2></header>
                    <div class="app-panel-body">
                        <div class="rooms-contract-lead">
                            <svg class="app-icon" aria-hidden="true"><use href="#icon-door"></use></svg>
                            <div><h3>Trạng thái Trống</h3><p>Trạng thái thuê sẽ được cập nhật theo hợp đồng có hiệu lực, không đặt thủ công khi tạo phòng.</p></div>
                        </div>
                    </div>
                </section>
                <div class="app-notice is-info">
                    <svg class="app-icon" aria-hidden="true"><use href="#icon-info"></use></svg>
                    <div><strong>Đơn giá dịch vụ</strong><div>Có thể điều chỉnh theo kỳ sau khi phòng đã được tạo. Giá hợp đồng vẫn tuân theo luồng nghiệp vụ hiện tại.</div></div>
                </div>
            </aside>
        </div>

        <div class="rooms-form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary" disabled="@(!coNha)">
                <span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-save"></use></svg>Lưu phòng</span>
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/rooms.js" asp-append-version="true"></script>
}
