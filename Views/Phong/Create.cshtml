@model QuanLyNhaTro.Models.Phong
@using System.Globalization
@{
    ViewData["Title"] = "Thêm phòng";
    ViewData["ActiveMenu"] = "phong";
    var danhSachNha = ViewBag.DanhSachNha as IEnumerable<QuanLyNhaTro.Models.Nha> ?? [];
    var danhSachDichVu = ViewBag.DanhSachDichVu as IEnumerable<QuanLyNhaTro.Models.DichVu> ?? [];
    var coNha = danhSachNha.Any();
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Thêm phòng mới</h5>
</div>

<div class="card shadow-sm" style="max-width:640px">
    <div class="card-body">
        @if (!coNha)
        {
            <div class="alert alert-warning py-2">
                Chưa có Nhà nào. Hãy <a asp-controller="Nha" asp-action="Index" class="alert-link">tạo Nhà</a> trước khi tạo phòng.
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">Nhà <span class="text-danger">*</span></label>
                <select asp-for="NhaId" class="form-select" required disabled="@(!coNha)">
                    <option value="">-- Chọn nhà --</option>
                    @foreach (var nha in danhSachNha)
                    {
                        <option value="@nha.Id">@nha.TenNha</option>
                    }
                </select>
                <span asp-validation-for="NhaId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Tên phòng <span class="text-danger">*</span></label>
                <input asp-for="TenPhong" class="form-control" placeholder="P01, A102..." required />
                <span asp-validation-for="TenPhong" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">Diện tích (m²)</label>
                    <input asp-for="DienTich" type="number" step="0.1" min="0" class="form-control" />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Sức chứa (người)</label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Giá thuê niêm yết (đ)</label>
                <input asp-for="GiaThueMacDinh" type="number" min="0" class="form-control" />
                <div class="form-text">Giá thỏa thuận thực tế nhập trong hợp đồng.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Ghi chú</label>
                <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
            </div>

            @if (danhSachDichVu.Any())
            {
                <hr />
                <p class="fw-semibold mb-2">Dịch vụ áp dụng cho phòng</p>
                <div id="dich-vu-list">
                    @foreach (var dv in danhSachDichVu)
                    {
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="form-check" style="min-width:180px">
                                <input class="form-check-input dv-check" type="checkbox"
                                       id="dv_@dv.Id" value="@dv.Id" name="dichVuIds"
                                       data-index="@dv.Id" />
                                <label class="form-check-label" for="dv_@dv.Id">
                                    @dv.TenDichVu
                                    <small class="text-muted">
                                        (@dv.LoaiTinhPhiHienThi@if (dv.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh) { <text>, @dv.CachTinhCoDinhHienThi</text> })
                                    </small>
                                </label>
                            </div>
                            <div class="input-group input-group-sm" style="max-width:160px">
                                <input type="number" min="0" class="form-control dv-gia"
                                       name="donGias" placeholder="Đơn giá"
                                       value="@dv.DonGiaMacDinh.ToString("0.##", CultureInfo.InvariantCulture)"
                                       id="gia_@dv.Id" disabled />
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@(!coNha)">Lưu</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    // Bật/tắt input đơn giá theo checkbox
    document.querySelectorAll('.dv-check').forEach(cb => {
        cb.addEventListener('change', function () {
            const id = this.value;
            const input = document.getElementById('gia_' + id);
            input.disabled = !this.checked;
        });
    });
</script>
}
