@model IEnumerable<QuanLyNhaTro.Models.Phong>
@{
    ViewData["Title"] = "Danh sach phong";
    ViewData["ActiveMenu"] = "phong";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Danh sach phong</h5>
    <div class="d-flex gap-2">
        <a asp-action="GanDichVuHangLoat" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-ui-checks-grid me-1"></i>Gan dich vu hang loat
        </a>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Them phong
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle align-center">
            <thead class="table-light">
                <tr>
                    <th>Tên Nhà</th>
                    <th>Tên Phòng</th>
                    <th>Diện Tích</th>
                    <th class="text-end">Giá Phòng</th>
                    <th>Trạng Thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@(p.Nha?.TenNha ?? $"#{p.NhaId}")</td>
                        <td><a asp-action="Details" asp-route-id="@p.Id" class="fw-semibold text-decoration-none">@p.TenPhong</a></td>
                        <td>@(p.DienTich.HasValue ? $"{p.DienTich:N1} m2" : "-")</td>
                        <td class="text-end">@p.GiaThueMacDinh.ToString("N0") d</td>
                        <td>@Html.Raw(TrangThaiPhongBadge(p.TrangThai))</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xoa phong @p.TenPhong?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Chưa có phòng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    static string TrangThaiPhongBadge(string tt) => tt switch
    {
        "DangThue" => "<span class='badge bg-success'>Dang thue</span>",
        "DangSuaChua" => "<span class='badge bg-warning text-dark'>Dang sua</span>",
        _ => "<span class='badge bg-secondary'>Trong</span>"
    };
}
