@model QuanLyNhaTro.Models.Phong
@{
    ViewData["Title"] = "Chi tiết phòng";
    ViewData["ActiveMenu"] = "phong";
    var hopDong = ViewBag.HopDong as QuanLyNhaTro.Models.HopDong;
    var dichVuPhong = ViewBag.DichVuPhong as IEnumerable<QuanLyNhaTro.Models.PhongDichVu> ?? [];
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Phòng @Model.TenPhong</h5>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-auto">
        <i class="bi bi-pencil me-1"></i>Sửa
    </a>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Thông tin phòng</h6>
                <dl class="row mb-0">
                    <dt class="col-5">Nhà</dt><dd class="col-7">@(Model.Nha?.TenNha ?? $"#{Model.NhaId}")</dd>
                    <dt class="col-5">Diện tích</dt><dd class="col-7">@(Model.DienTich.HasValue ? $"{Model.DienTich:N1} m2" : "-")</dd>
                    <dt class="col-5">Giá niêm yết</dt><dd class="col-7">@Model.GiaThueMacDinh.ToString("N0") đ</dd>
                    <dt class="col-5">Trạng thái</dt>
                    <dd class="col-7">
                        @(Model.TrangThai switch {
                            "DangThue"    => "<span class='badge bg-success'>Đang thuê</span>",
                            "DangSuaChua" => "<span class='badge bg-warning text-dark'>Đang sửa</span>",
                            _             => "<span class='badge bg-secondary'>Trống</span>"
                        })
                    </dd>
                    @if (!string.IsNullOrEmpty(Model.GhiChu))
                    {
                        <dt class="col-5">Ghi chú</dt><dd class="col-7">@Model.GhiChu</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Hợp đồng hiện tại</h6>
                @if (hopDong != null)
                {
                    <dl class="row mb-0">
                        <dt class="col-5">Ngày bắt đầu</dt><dd class="col-7">@hopDong.NgayBatDau.ToString("dd/MM/yyyy")</dd>
                        <dt class="col-5">Giá thuê TT</dt><dd class="col-7">@hopDong.TienThueThoaThuan.ToString("N0") đ</dd>
                        <dt class="col-5">Tiền cọc</dt><dd class="col-7">@hopDong.TienCoc.ToString("N0") đ</dd>
                    </dl>
                    <a asp-controller="HopDong" asp-action="Details" asp-route-id="@hopDong.Id"
                       class="btn btn-sm btn-outline-primary mt-2">Xem hợp đồng</a>
                }
                else
                {
                    <p class="text-muted mb-2">Phòng đang trống.</p>
                    <a asp-controller="HopDong" asp-action="Create" asp-route-phongId="@Model.Id"
                       class="btn btn-sm btn-primary">
                        <i class="bi bi-plus me-1"></i>Tạo hợp đồng
                    </a>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Dịch vụ</h6>
                @if (dichVuPhong.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Dịch vụ</th><th>Loại</th><th class="text-end">Đơn giá</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var pdv in dichVuPhong)
                            {
                                <tr>
                                    <td>@pdv.DichVu?.TenDichVu</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@pdv.DichVu?.LoaiTinhPhiHienThi</span>
                                        @if (pdv.DichVu?.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh)
                                        {
                                            <span class="badge bg-light text-dark border">@pdv.DichVu.CachTinhCoDinhHienThi</span>
                                        }
                                    </td>
                                    <td class="text-end">@pdv.DonGia.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có dịch vụ.</p>
                }
            </div>
        </div>
    </div>
</div>
