@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLowerInvariant() ?? "home";
    var activeMenu = ViewData["ActiveMenu"]?.ToString() ?? currentController;
    var accountName = User.Identity?.Name?.Trim();
    accountName = string.IsNullOrWhiteSpace(accountName) ? "Quản trị" : accountName;
    var accountInitial = accountName.Substring(0, 1).ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0B5F59" />
    <title>@ViewData["Title"] — Quản lý nhà trọ</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <partial name="_IconSprite" />
    <a class="skip-link" href="#main-content">Bỏ qua điều hướng</a>

    <div class="app-shell">
        <button class="app-drawer-backdrop" id="drawerBackdrop" type="button" tabindex="-1" aria-label="Đóng menu"></button>

        <aside class="app-sidebar" id="appSidebar" aria-label="Điều hướng chính">
            <button class="app-icon-button app-drawer-close" id="drawerClose" type="button" aria-label="Đóng menu">
                <svg class="app-icon" aria-hidden="true"><use href="#icon-close"></use></svg>
            </button>

            <a class="app-brand" asp-controller="Home" asp-action="Index">
                <span class="app-brand-mark"><svg class="app-icon" aria-hidden="true"><use href="#icon-home"></use></svg></span>
                <span>Quản lý nhà trọ</span>
            </a>

            <nav class="app-primary-nav" aria-label="Các phân hệ">
                <p class="app-nav-label">Tổng quan</p>
                <ul class="app-nav-list">
                    <li><a asp-controller="Home" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "dashboard" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-dashboard"></use></svg><span>Tổng quan</span></a></li>
                </ul>

                <p class="app-nav-label">Quản lý</p>
                <ul class="app-nav-list">
                    <li><a asp-controller="Nha" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "nha" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-building"></use></svg><span>Nhà trọ</span></a></li>
                    <li><a asp-controller="Phong" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "phong" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-door"></use></svg><span>Phòng trọ</span></a></li>
                    <li><a asp-controller="KhachThue" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "khachthue" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-users"></use></svg><span>Khách thuê</span></a></li>
                    <li><a asp-controller="HopDong" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "hopdong" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-contract"></use></svg><span>Hợp đồng</span></a></li>
                </ul>

                <p class="app-nav-label">Tài chính</p>
                <ul class="app-nav-list">
                    <li><a asp-controller="HoaDon" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "hoadon" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-receipt"></use></svg><span>Hóa đơn</span></a></li>
                    <li><a asp-controller="ThuChi" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "thuchi" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-wallet"></use></svg><span>Thu chi</span></a></li>
                    <li><a asp-controller="NhacNo" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "nhacno" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-bell"></use></svg><span>Nhắc nợ</span></a></li>
                    <li><a asp-controller="BaoCao" asp-action="CongNo" class="app-nav-link" aria-current="@(activeMenu == "baocao" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-report"></use></svg><span>Công nợ</span></a></li>
                </ul>

                <p class="app-nav-label">Vận hành</p>
                <ul class="app-nav-list">
                    <li><a asp-controller="ChiSo" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "chiso" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-meter"></use></svg><span>Chỉ số điện nước</span></a></li>
                    <li><a asp-controller="ChiSoNgoaiHopDong" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "chiso-ngoai" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-tools"></use></svg><span>Chỉ số ngoài HĐ</span></a></li>
                    <li><a asp-controller="KiemTraDuLieu" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "kiemtra" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-check"></use></svg><span>Kiểm tra dữ liệu</span></a></li>
                    <li><a asp-controller="DichVu" asp-action="Index" class="app-nav-link" aria-current="@(activeMenu == "dichvu" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-settings"></use></svg><span>Dịch vụ</span></a></li>
                </ul>
            </nav>

            <div class="app-sidebar-footer">
                <div class="app-account-summary">
                    <span class="app-avatar" aria-hidden="true">@accountInitial</span>
                    <span><strong>@accountName</strong><small>Tài khoản quản trị</small></span>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="app-nav-link app-logout" type="submit"><svg class="app-icon" aria-hidden="true"><use href="#icon-logout"></use></svg><span>Đăng xuất</span></button>
                </form>
            </div>
        </aside>

        <div class="app-workspace" id="appWorkspace">
            <header class="app-topbar">
                <span class="app-topbar-title">@ViewData["Title"]</span>
                <div class="app-user-chip" aria-label="Tài khoản đang đăng nhập: @accountName">
                    <span class="app-avatar" aria-hidden="true">@accountInitial</span><span>@accountName</span>
                </div>
            </header>

            <header class="app-mobile-header">
                <button class="app-icon-button" id="drawerOpen" type="button" aria-controls="appSidebar" aria-expanded="false" aria-label="Mở menu"><svg class="app-icon" aria-hidden="true"><use href="#icon-menu"></use></svg></button>
                <a class="app-mobile-brand" asp-controller="Home" asp-action="Index">Quản lý nhà trọ</a>
                <span class="app-avatar app-mobile-avatar" aria-label="Tài khoản @accountName">@accountInitial</span>
            </header>

            <main class="app-main" id="main-content" tabindex="-1">
                @RenderBody()
            </main>

            <nav class="app-bottom-nav" aria-label="Điều hướng nhanh trên điện thoại">
                <a asp-controller="Home" asp-action="Index" class="app-bottom-link" aria-current="@(activeMenu == "dashboard" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-dashboard"></use></svg><span>Tổng quan</span></a>
                <a asp-controller="Phong" asp-action="Index" class="app-bottom-link" aria-current="@(activeMenu == "phong" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-door"></use></svg><span>Phòng</span></a>
                <a asp-controller="HopDong" asp-action="Index" class="app-bottom-link" aria-current="@(activeMenu == "hopdong" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-contract"></use></svg><span>Hợp đồng</span></a>
                <a asp-controller="HoaDon" asp-action="Index" class="app-bottom-link" aria-current="@(activeMenu == "hoadon" ? "page" : null)"><svg class="app-icon" aria-hidden="true"><use href="#icon-receipt"></use></svg><span>Hóa đơn</span></a>
                <button class="app-bottom-link" id="bottomMore" type="button" aria-controls="appSidebar" aria-expanded="false"><svg class="app-icon" aria-hidden="true"><use href="#icon-more"></use></svg><span>Thêm</span></button>
            </nav>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
