<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Quản lý nhà trọ</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- Sidebar + main layout -->
<div class="d-flex" id="wrapper">

    <button id="sidebar-toggle" class="btn btn-dark d-md-none" type="button"
            aria-controls="sidebar" aria-expanded="false" aria-label="Mở menu điều hướng">
        <i class="bi bi-list"></i>
    </button>

    <!-- Sidebar -->
    <nav id="sidebar" class="d-flex flex-column flex-shrink-0 p-3 bg-dark text-white" style="width:240px; min-height:100vh;">
        <button id="sidebar-close" class="btn btn-sm btn-outline-light d-md-none align-self-end mb-2"
                type="button" aria-label="Đóng menu điều hướng">
            <i class="bi bi-x-lg"></i>
        </button>
        <a href="/" class="d-flex align-items-center mb-3 text-white text-decoration-none">
            <i class="bi bi-house-door-fill me-2 fs-5"></i>
            <span class="fw-semibold">Quản lý nhà trọ</span>
        </a>
        <hr />
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a asp-controller="Home" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="Nha" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "nha" ? "active" : "")">
                    <i class="bi bi-building me-2"></i>Nhà Trọ
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="Phong" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "phong" ? "active" : "")">
                    <i class="bi bi-door-open me-2"></i>Phòng Trọ
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="KhachThue" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "khachthue" ? "active" : "")">
                    <i class="bi bi-people me-2"></i>Khách Thuê
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="HopDong" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "hopdong" ? "active" : "")">
                    <i class="bi bi-file-earmark-text me-2"></i>Hợp Đồng
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="ChiSo" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "chiso" ? "active" : "")">
                    <i class="bi bi-lightning-charge me-2"></i>Chỉ Số Điện Nước
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="ChiSoNgoaiHopDong" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "chiso-ngoai" ? "active" : "")">
                    <i class="bi bi-tools me-2"></i>Chỉ Số Ngoài HĐ
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="KiemTraDuLieu" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "kiemtra" ? "active" : "")">
                    <i class="bi bi-clipboard-check me-2"></i>Sẵn sàng vận hành
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="HoaDon" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "hoadon" ? "active" : "")">
                    <i class="bi bi-receipt me-2"></i>Hóa Đơn
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="ThuChi" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "thuchi" ? "active" : "")">
                    <i class="bi bi-wallet2 me-2"></i>Thu Chi
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="NhacNo" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "nhacno" ? "active" : "")">
                    <i class="bi bi-bell me-2"></i>Nhắc Nợ
                </a>
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="DichVu" asp-action="Index" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "dichvu" ? "active" : "")">
                    <i class="bi bi-gear me-2"></i>Dịch Vụ
                </a>
            </li>
            <li class="nav-item mt-2">
                <hr class="text-white opacity-25 my-1">
            </li>
            <li class="nav-item mt-1">
                <a asp-controller="BaoCao" asp-action="CongNo" class="nav-link text-white @(ViewData["ActiveMenu"]?.ToString() == "baocao" ? "active" : "")">
                    <i class="bi bi-graph-up-arrow me-2"></i> Công Nợ
                </a>
            </li>
        </ul>
        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <button class="btn btn-sm btn-outline-light w-100"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
        </form>
    </nav>

    <!-- Page content -->
    <div id="page-content" class="flex-grow-1 p-4">
        @RenderBody()
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
