@model QuanLyNhaTro.Models.ChiSoHangLoatViewModel
@{
    ViewData["Title"] = "Nhập chỉ số hàng loạt";
    ViewData["ActiveMenu"] = "chiso";
    var entered = Model.Rows.Count(x => x.DaNhap);
    var missing = Model.Rows.Count - entered;
    var locked = Model.Rows.Count(x => x.DaKhoa);
}

<div class="meters-page meters-bulk-page" data-meter-bulk>
    <header class="app-page-header">
        <div class="app-page-heading"><a asp-action="Index" asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam" class="app-back-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Về tiến độ kỳ</a><h1>Nhập chỉ số hàng loạt</h1><p class="app-page-subtitle">Kỳ @Model.Thang/@Model.Nam · chọn đúng dòng cần lưu, rà reset và mốc đầu trước khi gửi server.</p></div>
    </header>

    @if (TempData["Error"] != null) { <div class="app-notice is-danger" role="alert"><svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg><div><strong>Chưa thể lưu</strong><p>@TempData["Error"]</p></div></div> }

    <section class="app-panel meters-bulk-toolbar" aria-labelledby="bulk-toolbar-heading">
        <div class="app-panel-header"><div><h2 id="bulk-toolbar-heading">Kỳ và phạm vi nhập</h2><p>Dòng đã lên hóa đơn được khóa; các dòng khác vẫn do server kiểm tra liên tục và tính lại.</p></div><div class="meters-period-summary"><span><strong>@Model.Rows.Count</strong> dòng</span><span class="is-success"><strong>@entered</strong> đã nhập</span><span class="is-danger"><strong>@missing</strong> chưa nhập</span>@if (locked > 0) { <span><strong>@locked</strong> đã khóa</span> }</div></div>
        <div class="app-panel-body">
            <form method="get" class="meters-period-form"><div class="app-field"><label for="bulk-month">Tháng</label><select id="bulk-month" name="thang" class="form-select">@for (var m = 1; m <= 12; m++) { <option value="@m" selected="@(m == Model.Thang)">Tháng @m</option> }</select></div><div class="app-field"><label for="bulk-year">Năm</label><input id="bulk-year" name="nam" type="number" class="form-control" value="@Model.Nam" min="2020" max="2099" /></div><button class="btn btn-outline-primary">Xem kỳ</button></form>
            <div class="meters-quick-filters"><div class="app-field"><label for="bulk-house">Nhà</label><select id="bulk-house" class="form-select" data-meter-filter="house"><option value="">Tất cả nhà</option>@foreach (var house in Model.Rows.Select(x => x.TenNha).Distinct().OrderBy(x => x)) { <option value="@house">@house</option> }</select></div><div class="app-field meters-search-field"><label for="bulk-search">Tìm phòng, khách, dịch vụ</label><div class="app-input-with-icon"><svg class="app-icon" aria-hidden="true"><use href="#icon-search"></use></svg><input id="bulk-search" class="form-control" type="search" placeholder="Nhập từ khóa…" data-meter-filter="search" /></div></div><div class="app-field"><label for="bulk-status">Trạng thái</label><select id="bulk-status" class="form-select" data-meter-filter="status"><option value="">Tất cả</option><option value="missing">Chưa nhập</option><option value="entered">Đã nhập</option><option value="reset">Reset</option><option value="locked">Đã khóa</option></select></div><button type="button" class="btn btn-outline-secondary meters-reset-filter" data-meter-reset-filter><svg class="app-icon" aria-hidden="true"><use href="#icon-refresh"></use></svg>Làm mới</button></div>
        </div>
    </section>

    <form asp-action="NhapHangLoat" method="post" class="meters-bulk-form">
        @Html.AntiForgeryToken()<input asp-for="Thang" type="hidden" /><input asp-for="Nam" type="hidden" />
        <div class="meters-selection-bar"><label class="meters-select-all"><input type="checkbox" class="form-check-input" data-meter-select-all /> Chọn tất cả dòng đang hiển thị</label><span><strong data-meter-selected-count>0</strong> dòng được chọn</span><button type="submit" class="btn btn-primary" data-meter-save-selected disabled><svg class="app-icon" aria-hidden="true"><use href="#icon-save"></use></svg>Lưu dòng đã chọn</button></div>
        <section class="app-panel meters-bulk-list" aria-labelledby="bulk-list-heading">
            <div class="app-panel-header"><div><h2 id="bulk-list-heading">Danh sách dịch vụ theo hợp đồng</h2><p>Mỗi dòng giữ nguyên khóa PhongId, HopDongId, DichVuId và ngày bắt đầu hợp đồng.</p></div><span class="meters-result-count" data-meter-result-count>@Model.Rows.Count dòng</span></div>
            @if (!Model.Rows.Any()) { <div class="app-empty-state"><svg class="app-icon" aria-hidden="true"><use href="#icon-meter"></use></svg><h3>Không có dòng chỉ số trong kỳ</h3><p>Kiểm tra hợp đồng và dịch vụ Theo chỉ số đang áp dụng.</p></div> }
            else
            {
                <div class="meters-table-wrap"><table class="meters-table meters-bulk-table"><thead><tr><th>Chọn</th><th>Nhà / phòng</th><th>Dịch vụ</th><th>Ngày đọc</th><th>Mốc đầu</th><th>Chỉ số cuối</th><th>Ghi nhận</th><th>Sản lượng</th><th>Trạng thái</th></tr></thead><tbody>
                @for (var i = 0; i < Model.Rows.Count; i++)
                {
                    var row = Model.Rows[i];
                    var status = row.DaKhoa ? "locked" : row.LoaiGhiNhan == "Reset" ? "reset" : row.DaNhap ? "entered" : "missing";
                    <tr data-meter-bulk-row data-meter-row data-house="@row.TenNha" data-status="@status" data-search="@($"{row.TenNha} {row.TenPhong} {row.TenKhach} {row.TenDichVu}".ToLowerInvariant())" data-chi-so-dau="@row.ChiSoDau.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                        <td data-label="Chọn">@if (row.DaKhoa) { <input asp-for="Rows[i].Luu" type="hidden" value="false" /><input type="checkbox" class="form-check-input" disabled aria-label="Dòng đã khóa" /> } else { <input asp-for="Rows[i].Luu" class="form-check-input" data-meter-select-row /> }<input asp-for="Rows[i].PhongId" type="hidden" /><input asp-for="Rows[i].HopDongId" type="hidden" /><input asp-for="Rows[i].NgayBatDauHopDong" type="hidden" /><input asp-for="Rows[i].TenPhong" type="hidden" /><input asp-for="Rows[i].TenNha" type="hidden" /><input asp-for="Rows[i].TenKhach" type="hidden" /><input asp-for="Rows[i].DichVuId" type="hidden" /><input asp-for="Rows[i].TenDichVu" type="hidden" /><input asp-for="Rows[i].DonViTinh" type="hidden" /><input asp-for="Rows[i].ChiSoId" type="hidden" /><input asp-for="Rows[i].NguonChiSoDau" type="hidden" /><input asp-for="Rows[i].ChoNhapChiSoDau" type="hidden" /><input asp-for="Rows[i].DaNhap" type="hidden" /><input asp-for="Rows[i].DaKhoa" type="hidden" /><input asp-for="Rows[i].SanLuongHienTai" type="hidden" /></td>
                        <td data-label="Nhà / phòng"><strong>@row.TenPhong</strong><span>@row.TenNha</span><small>@row.TenKhach · HĐ #@row.HopDongId</small></td>
                        <td data-label="Dịch vụ"><strong>@row.TenDichVu</strong><small>@row.DonViTinh</small></td>
                        <td data-label="Ngày đọc"><input asp-for="Rows[i].NgayDoc" type="date" class="form-control" readonly="@row.DaKhoa" /></td>
                        <td data-label="Mốc đầu">@if (row.ChoNhapChiSoDau && !row.DaKhoa) { <input asp-for="Rows[i].ChiSoDau" type="number" step="0.01" min="0" class="form-control" data-start-input /> } else { <input asp-for="Rows[i].ChiSoDau" type="hidden" /><strong>@row.ChiSoDau.ToString("N2")</strong> }<small class="meters-anchor-source">@row.NguonChiSoDau</small></td>
                        <td data-label="Chỉ số cuối"><input asp-for="Rows[i].ChiSoCuoi" type="number" step="0.01" min="0" class="form-control meters-reading-input" data-meter-end-input readonly="@row.DaKhoa" /></td>
                        <td data-label="Ghi nhận">@if (row.DaKhoa) { <input asp-for="Rows[i].LoaiGhiNhan" type="hidden" /><strong>@(row.LoaiGhiNhan == "Reset" ? "Reset" : "Bình thường")</strong> } else { <select asp-for="Rows[i].LoaiGhiNhan" class="form-select" data-meter-type><option value="BinhThuong">Bình thường</option><option value="Reset">Reset</option></select> }<div class="meters-inline-reset @(row.LoaiGhiNhan == "Reset" ? "" : "d-none")" data-reset-fields><input asp-for="Rows[i].ChiSoTruocReset" type="number" step="0.01" class="form-control" placeholder="Trước reset" readonly="@row.DaKhoa" /><input asp-for="Rows[i].ChiSoSauReset" type="number" step="0.01" class="form-control" placeholder="Sau reset" readonly="@row.DaKhoa" /><input asp-for="Rows[i].LyDoDieuChinh" class="form-control" placeholder="Lý do reset" readonly="@row.DaKhoa" /></div></td>
                        <td data-label="Sản lượng"><strong data-meter-consumption>@(row.SanLuongHienTai?.ToString("N2") ?? "0,00")</strong><small>@row.DonViTinh</small></td>
                        <td data-label="Trạng thái">@if (row.DaKhoa) { <span class="app-status-badge is-neutral">Đã khóa</span><small>Đã lên hóa đơn</small> } else if (row.DaNhap) { <span class="app-status-badge is-success">Đã nhập</span> } else { <span class="app-status-badge is-danger">Chưa nhập</span> }</td>
                    </tr>
                }
                </tbody></table><div class="app-empty-state meters-filter-empty d-none" data-meter-filter-empty><svg class="app-icon" aria-hidden="true"><use href="#icon-search"></use></svg><h3>Không có dòng phù hợp</h3><p>Đổi bộ lọc để tiếp tục nhập.</p></div></div>
            }
        </section>
    </form>
</div>

@section Scripts { <script src="~/js/meters.js" asp-append-version="true"></script> }
