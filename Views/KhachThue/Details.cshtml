@model QuanLyNhaTro.Models.KhachThue
@{
    ViewData["Title"] = "Chi tiết khách thuê";
    ViewData["ActiveMenu"] = "khachthue";
    var lichSuCuTru = ViewBag.LichSuCuTru as IEnumerable<QuanLyNhaTro.Models.HopDongKhachThue> ?? [];
    var current = lichSuCuTru.FirstOrDefault(x => x.DangCuTru);
}

<div class="tenants-page tenants-details-page">
    <header class="app-page-header">
        <div class="app-page-heading"><a asp-action="Index" class="tenants-back-link">← Danh sách khách thuê</a><h1>@Model.HoTen</h1><p class="app-page-subtitle">Hồ sơ #@Model.Id · @(current == null ? "Chưa có nơi ở hiện tại" : $"{current.TenNha} / {current.TenPhong}")</p></div>
        <div class="app-page-actions"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Chỉnh sửa hồ sơ</a><form asp-action="Delete" asp-route-id="@Model.Id" method="post" data-confirm="Chỉ hồ sơ hoàn toàn chưa sử dụng mới được xóa. Bạn chắc chắn muốn tiếp tục?">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-danger">Xóa hồ sơ</button></form></div>
    </header>

    @if (TempData["Error"] != null) { <div class="app-notice is-danger" role="alert">@TempData["Error"]</div> }
    @if (TempData["Success"] != null) { <div class="app-notice is-success" role="status">@TempData["Success"]</div> }

    <div class="tenants-details-grid">
        <section class="app-panel"><div class="app-panel-header"><h2>Nhận diện và liên hệ</h2></div><div class="app-panel-body"><dl class="tenants-definition-list">
            <div><dt>Họ tên</dt><dd>@Model.HoTen</dd></div><div><dt>Ngày sinh</dt><dd>@(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa có")</dd></div>
            <div><dt>Điện thoại</dt><dd>@(Model.SoDienThoai ?? "Chưa có")</dd></div><div><dt>CCCD</dt><dd>@(Model.CCCD ?? "Chưa có")</dd></div>
            <div><dt>Ngày cấp CCCD</dt><dd>@(Model.NgayCapCCCD?.ToString("dd/MM/yyyy") ?? "Chưa có")</dd></div><div><dt>Quê quán</dt><dd>@(Model.QueQuan ?? "Chưa có")</dd></div>
            <div><dt>Nghề nghiệp</dt><dd>@(Model.NgheNghiep ?? "Chưa có")</dd></div><div><dt>Phương tiện</dt><dd>@(string.Join(" · ", new[] { Model.LoaiXe, Model.BienSoXe }.Where(x => !string.IsNullOrWhiteSpace(x))))</dd></div>
        </dl>@if (!string.IsNullOrWhiteSpace(Model.GhiChu)) { <div class="tenants-note"><strong>Ghi chú</strong><p>@Model.GhiChu</p></div> }</div></section>

        <section class="app-panel"><div class="app-panel-header"><div><h2>Ảnh CCCD</h2><p>Ảnh được tải qua endpoint đã xác thực, no-store/private.</p></div></div><div class="app-panel-body tenants-photo-grid">
            @if (!string.IsNullOrEmpty(Model.AnhCCCDMatTruoc)) { <figure><img src="@Url.Action("Photo", "KhachThue", new { id = Model.Id, side = "front" })" alt="CCCD mặt trước của @Model.HoTen" /><figcaption>Mặt trước</figcaption></figure> } else { <div class="tenants-photo-empty">Chưa có ảnh mặt trước</div> }
            @if (!string.IsNullOrEmpty(Model.AnhCCCDMatSau)) { <figure><img src="@Url.Action("Photo", "KhachThue", new { id = Model.Id, side = "back" })" alt="CCCD mặt sau của @Model.HoTen" /><figcaption>Mặt sau</figcaption></figure> } else { <div class="tenants-photo-empty">Chưa có ảnh mặt sau</div> }
        </div></section>
    </div>

    <section class="app-panel tenants-residency-panel"><div class="app-panel-header"><div><h2>Lịch sử cư trú</h2><p>Ngày bắt đầu, dự kiến rời và ngày kết thúc thực tế theo hợp đồng.</p></div></div>
        @if (!lichSuCuTru.Any()) { <div class="app-empty-state"><div><h3>Chưa có lịch sử cư trú</h3><p>Hồ sơ chưa được gắn vào hợp đồng nào.</p></div></div> }
        else { <div class="tenants-table-wrap"><table class="tenants-table"><thead><tr><th>Nhà / phòng</th><th>Hợp đồng</th><th>Bắt đầu</th><th>Dự kiến rời</th><th>Kết thúc</th><th>Vai trò</th></tr></thead><tbody>@foreach (var item in lichSuCuTru) { <tr><td data-label="Nhà / phòng"><strong>@item.TenNha / @item.TenPhong</strong></td><td data-label="Hợp đồng"><a asp-controller="HopDong" asp-action="Details" asp-route-id="@item.HopDongId">HĐ #@item.HopDongId</a></td><td data-label="Bắt đầu">@item.NgayBatDau.ToString("dd/MM/yyyy")</td><td data-label="Dự kiến rời">@(item.NgayKetThucDuKien?.ToString("dd/MM/yyyy") ?? "—")</td><td data-label="Kết thúc">@(item.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Đang mở")</td><td data-label="Vai trò"><span class="app-status-badge @(item.LaDaiDien ? "is-info" : "is-neutral")">@(item.LaDaiDien ? "Đại diện" : "Người ở")</span></td></tr> }</tbody></table></div> }
    </section>
</div>

@section Scripts { <script src="~/js/tenants.js" asp-append-version="true"></script> }
