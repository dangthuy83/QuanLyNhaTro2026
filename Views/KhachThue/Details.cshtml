@model QuanLyNhaTro.Models.KhachThue
@{
    ViewData["Title"] = "Chi tiết khách thuê";
    ViewData["ActiveMenu"] = "khachthue";
    var lichSuCuTru = ViewBag.LichSuCuTru as IEnumerable<QuanLyNhaTro.Models.HopDongKhachThue> ?? [];
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">@Model.HoTen</h5>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-auto">
        <i class="bi bi-pencil me-1"></i>Sửa
    </a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
          onsubmit="return confirm('Chỉ hồ sơ hoàn toàn chưa sử dụng mới được xóa. Bạn chắc chắn muốn tiếp tục?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Xóa</button>
    </form>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Thông tin cá nhân</h6>
                <dl class="row mb-0">
                    <dt class="col-5">Họ tên</dt><dd class="col-7">@Model.HoTen</dd>
                    <dt class="col-5">Ngày sinh</dt><dd class="col-7">@(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "-")</dd>
                    <dt class="col-5">Điện thoại</dt><dd class="col-7">@(Model.SoDienThoai ?? "-")</dd>
                    <dt class="col-5">CCCD</dt><dd class="col-7">@(Model.CCCD ?? "-")</dd>
                    <dt class="col-5">Ngày cấp</dt><dd class="col-7">@(Model.NgayCapCCCD?.ToString("dd/MM/yyyy") ?? "-")</dd>
                    <dt class="col-5">Biển số xe</dt><dd class="col-7">@(Model.BienSoXe ?? "-")</dd>
                    <dt class="col-5">Loại xe</dt><dd class="col-7">@(Model.LoaiXe ?? "-")</dd>
                    <dt class="col-5">Nghề nghiệp</dt><dd class="col-7">@(Model.NgheNghiep ?? "-")</dd>
                    <dt class="col-5">Quê quán</dt><dd class="col-7">@(Model.QueQuan ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Ảnh CCCD</h6>
                <div class="row g-3">
                    <div class="col-6">
                        @if (!string.IsNullOrEmpty(Model.AnhCCCDMatTruoc))
                        {
                            <img src="@Model.AnhCCCDMatTruoc" alt="CCCD mặt trước" class="img-fluid rounded" style="max-height:180px;" />
                        }
                        else
                        {
                            <p class="text-muted mb-0">Chưa có mặt trước.</p>
                        }
                    </div>
                    <div class="col-6">
                        @if (!string.IsNullOrEmpty(Model.AnhCCCDMatSau))
                        {
                            <img src="@Model.AnhCCCDMatSau" alt="CCCD mặt sau" class="img-fluid rounded" style="max-height:180px;" />
                        }
                        else
                        {
                            <p class="text-muted mb-0">Chưa có mặt sau.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.GhiChu))
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-2">Ghi chú</h6>
                    <p class="mb-0">@Model.GhiChu</p>
                </div>
            </div>
        </div>
    }
</div>

<div class="card shadow-sm mt-3">
    <div class="card-body">
        <h6 class="card-title text-muted mb-3">Lịch sử cư trú</h6>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light"><tr><th>Nhà / Phòng</th><th>Hợp đồng</th><th>Bắt đầu thực tế</th><th>Dự kiến rời</th><th>Kết thúc thực tế</th><th>Vai trò</th></tr></thead>
                <tbody>
                @foreach (var item in lichSuCuTru)
                {
                    <tr>
                        <td>@item.TenNha / @item.TenPhong</td>
                        <td><a asp-controller="HopDong" asp-action="Details" asp-route-id="@item.HopDongId">#@item.HopDongId</a></td>
                        <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                        <td>@(item.NgayKetThucDuKien?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@(item.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Đang mở")</td>
                        <td>@(item.LaDaiDien ? "Đại diện" : "Người ở")</td>
                    </tr>
                }
                @if (!lichSuCuTru.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">Chưa có lịch sử cư trú.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
