@model QuanLyNhaTro.Models.KhachThue

@if (ViewBag.HoSoTrungCccd is QuanLyNhaTro.Models.KhachThue hoSoCu)
{
    <div class="alert alert-warning">
        CCCD này đã thuộc hồ sơ
        <a asp-controller="KhachThue" asp-action="Details" asp-route-id="@hoSoCu.Id" class="alert-link">@hoSoCu.HoTen (#@hoSoCu.Id)</a>.
        Hãy tái sử dụng hồ sơ cũ; hệ thống không tự động gộp hồ sơ.
    </div>
}

@if (ViewBag.HoSoTrungSoDienThoai is IReadOnlyList<QuanLyNhaTro.Models.KhachThue> hoSoTrungSdt && hoSoTrungSdt.Count > 0)
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">Số điện thoại này đang có trong hồ sơ:</div>
        <ul class="mb-2">
            @foreach (var item in hoSoTrungSdt)
            {
                <li><a asp-controller="KhachThue" asp-action="Details" asp-route-id="@item.Id" class="alert-link">@item.HoTen (#@item.Id)</a></li>
            }
        </ul>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" value="true" id="confirmDuplicatePhone" name="confirmDuplicatePhone" required />
            <label class="form-check-label" for="confirmDuplicatePhone">Tôi đã kiểm tra và vẫn muốn lưu thành hồ sơ riêng.</label>
        </div>
    </div>
}

<div class="tenants-form-grid">
<div class="app-field tenants-field-wide">
    <label asp-for="HoTen" class="form-label fw-semibold">
        Họ tên <span class="text-danger">*</span>
    </label>
    <input asp-for="HoTen" class="form-control" required />
    <span asp-validation-for="HoTen" class="text-danger small"></span>
</div>

<div class="app-field">
        <label asp-for="NgaySinh" class="form-label fw-semibold">Ngày sinh</label>
        <input asp-for="NgaySinh" type="date" class="form-control" />
</div>
<div class="app-field">
        <label asp-for="SoDienThoai" class="form-label fw-semibold">Điện thoại</label>
        <input asp-for="SoDienThoai" class="form-control" />
        <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
</div>

<div class="app-field">
        <label asp-for="CCCD" class="form-label fw-semibold">CCCD</label>
        <input asp-for="CCCD" class="form-control" />
        <span asp-validation-for="CCCD" class="text-danger small"></span>
</div><div class="app-field">
        <label asp-for="NgayCapCCCD" class="form-label fw-semibold">Ngày cấp CCCD</label>
        <input asp-for="NgayCapCCCD" type="date" class="form-control" />
</div>

<div class="app-field">
        <label asp-for="BienSoXe" class="form-label fw-semibold">Biển số xe</label>
        <input asp-for="BienSoXe" class="form-control" placeholder="Ví dụ: 59X1-123.45" />
</div><div class="app-field">
        <label asp-for="LoaiXe" class="form-label fw-semibold">Loại xe</label>
        <input asp-for="LoaiXe"
               class="form-control"
               list="loaiXeSuggestions"
               placeholder="Chọn hoặc nhập loại xe" />
        <datalist id="loaiXeSuggestions">
            <option value="Xe máy"></option>
            <option value="Ô tô"></option>
            <option value="Xe máy điện"></option>
            <option value="Ô tô điện"></option>
            <option value="Xe đạp"></option>
            <option value="Xe đạp điện"></option>
        </datalist>
</div>

<div class="app-field">
        <label asp-for="NgheNghiep" class="form-label fw-semibold">Nghề nghiệp</label>
        <input asp-for="NgheNghiep" class="form-control" />
</div><div class="app-field">
        <label asp-for="QueQuan" class="form-label fw-semibold">Quê quán</label>
        <input asp-for="QueQuan" class="form-control" />
</div>

<div class="tenants-photo-field">
        <label class="form-label fw-semibold">Ảnh CCCD mặt trước</label>
        <input type="file"
               name="anhCCCDMatTruoc"
               class="form-control"
               accept=".jpg,.jpeg,.png,.webp" data-photo-input data-preview-target="tenantFrontPreview" />
        <div class="form-text">JPG, PNG hoặc WEBP; tối đa 5 MB.</div>

        @if (!string.IsNullOrEmpty(Model?.AnhCCCDMatTruoc))
        {
            <img id="tenantFrontPreview" src="@Url.Action("Photo", "KhachThue", new { id = Model.Id, side = "front" })"
                 alt="CCCD mặt trước"
                 class="tenants-photo-preview" />
        }
        else { <div id="tenantFrontPreview" class="tenants-photo-preview" data-preview-alt="Xem trước CCCD mặt trước" hidden></div> }
</div>

<div class="tenants-photo-field">
        <label class="form-label fw-semibold">Ảnh CCCD mặt sau</label>
        <input type="file"
               name="anhCCCDMatSau"
               class="form-control"
               accept=".jpg,.jpeg,.png,.webp" data-photo-input data-preview-target="tenantBackPreview" />
        <div class="form-text">JPG, PNG hoặc WEBP; tối đa 5 MB.</div>

        @if (!string.IsNullOrEmpty(Model?.AnhCCCDMatSau))
        {
            <img id="tenantBackPreview" src="@Url.Action("Photo", "KhachThue", new { id = Model.Id, side = "back" })"
                 alt="CCCD mặt sau"
                 class="tenants-photo-preview" />
        }
        else { <div id="tenantBackPreview" class="tenants-photo-preview" data-preview-alt="Xem trước CCCD mặt sau" hidden></div> }
</div>

<div class="app-field tenants-field-wide">
    <label asp-for="GhiChu" class="form-label fw-semibold">Ghi chú</label>
    <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
</div>
</div>
