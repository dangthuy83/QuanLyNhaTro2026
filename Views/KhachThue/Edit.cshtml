@model QuanLyNhaTro.Models.KhachThue
@{
    ViewData["Title"] = "Sửa khách thuê";
    ViewData["ActiveMenu"] = "khachthue";
}

<div class="tenants-page tenants-form-page">
    <header class="app-page-header"><div class="app-page-heading"><a asp-action="Details" asp-route-id="@Model.Id" class="tenants-back-link">← Hồ sơ @Model.HoTen</a><h1>Chỉnh sửa hồ sơ</h1><p class="app-page-subtitle">Ảnh mới chỉ thay thế ảnh cũ sau khi toàn bộ thao tác lưu thành công.</p></div></header>
    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="app-panel tenants-form-panel">
        <div class="app-panel-header"><div><h2>@Model.HoTen</h2><p>Mã hồ sơ #@Model.Id</p></div></div>
        <div class="app-panel-body">
            <div asp-validation-summary="ModelOnly" class="app-notice is-danger" role="alert"></div>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            @await Html.PartialAsync("_KhachThueForm", Model)
        </div>
        <div class="tenants-form-actions"><button type="submit" class="btn btn-primary">Lưu thay đổi</button><a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Hủy</a></div>
    </form>
</div>

@section Scripts { <script src="~/js/tenants.js" asp-append-version="true"></script> }
