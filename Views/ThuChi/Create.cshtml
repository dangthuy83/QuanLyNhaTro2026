@model QuanLyNhaTro.Models.ThuChi
@{ ViewData["Title"] = Model.LaDieuChinh ? "Tạo bút toán điều chỉnh" : "Thêm giao dịch thu chi"; ViewData["ActiveMenu"] = "thuchi"; }
<div class="cashbook-page cashbook-form-page"><header class="app-page-header"><div class="app-page-heading"><a asp-action="Index" class="cashbook-back-link">← Sổ thu chi</a><h1>@ViewData["Title"]</h1><p class="app-page-subtitle">@(Model.LaDieuChinh ? "Giao dịch gốc được giữ nguyên; bút toán mới ghi nhận phần đảo/điều chỉnh." : "Ghi nhận một khoản thu hoặc chi chung vào kỳ đang mở.")</p></div></header><form asp-action="Create" method="post" class="app-panel cashbook-form-panel">@Html.AntiForgeryToken()<div class="app-panel-body"><div asp-validation-summary="ModelOnly" class="app-notice is-danger" role="alert"></div><partial name="_ThuChiForm" model="Model" /></div><div class="cashbook-form-actions"><button class="btn btn-primary">Lưu giao dịch</button><a asp-action="Index" class="btn btn-outline-secondary">Hủy</a></div></form></div>
@section Scripts { <script src="~/js/cashbook.js" asp-append-version="true"></script> }
