@model IEnumerable<QuanLyNhaTro.Models.ThuChi>
@{
    ViewData["Title"] = "Sổ Thu Chi";
    int nam = ViewBag.Nam; int thang = ViewBag.Thang; string loai = ViewBag.Loai ?? "";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Sổ Thu Chi</h4>
    <div class="d-flex gap-2">
        <a asp-action="XuatExcel" asp-route-nam="@nam" asp-route-thang="@thang"
           class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel"></i> Xuất Excel</a>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Thêm</a>
    </div>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="thang" class="form-select form-select-sm">
            @for (int m = 1; m <= 12; m++)
            { <option value="@m" selected="@(m == thang ? "selected" : null)">Tháng @m</option> }
        </select>
    </div>
    <div class="col-auto">
        <input name="nam" type="number" class="form-control form-control-sm" value="@nam" style="width:90px" />
    </div>
    <div class="col-auto">
        <select name="loai" class="form-select form-select-sm">
            <option value="" selected="@(loai==""?"selected":null)">Tất cả</option>
            <option value="Thu" selected="@(loai=="Thu"?"selected":null)">Thu</option>
            <option value="Chi" selected="@(loai=="Chi"?"selected":null)">Chi</option>
        </select>
    </div>
    <div class="col-auto"><button class="btn btn-outline-secondary btn-sm">Lọc</button></div>
</form>
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card border-0 bg-success bg-opacity-10">
            <div class="card-body py-2">
                <div class="text-muted small">Tổng Thu</div>
                <div class="fw-bold text-success fs-5">@((ViewBag.TongThu as decimal? ?? 0m).ToString("N0")) đ</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-danger bg-opacity-10">
            <div class="card-body py-2">
                <div class="text-muted small">Tổng Chi</div>
                <div class="fw-bold text-danger fs-5">@((ViewBag.TongChi as decimal? ?? 0m).ToString("N0")) đ</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        @{ decimal cd = ViewBag.CanDoiThu ?? 0m; }
        <div class="card border-0 @(cd>=0?"bg-primary":"bg-warning") bg-opacity-10">
            <div class="card-body py-2">
                <div class="text-muted small">Cân Đối</div>
                <div class="fw-bold @(cd>=0?"text-primary":"text-warning") fs-5">@cd.ToString("N0") đ</div>
            </div>
        </div>
    </div>
</div>
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr><th>Ngày</th><th>Loại</th><th>Danh mục</th><th>Nội dung</th><th class="text-end">Số tiền</th><th></th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Không có giao dịch nào.</td></tr>
                }
                @foreach (var tc in Model)
                {
                    <tr>
                        <td class="text-nowrap">@tc.NgayPhatSinh.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge @(tc.LoaiGiaoDich=="Thu"?"bg-success":"bg-danger")">@tc.LoaiGiaoDich</span></td>
                        <td>@tc.DanhMuc</td>
                        <td class="text-muted small">@tc.NoiDung</td>
                        <td class="text-end fw-semibold @(tc.LoaiGiaoDich=="Thu"?"text-success":"text-danger")">
                            @tc.SoTien.ToString("N0") đ
                        </td>
                        <td class="text-nowrap">
                            <a asp-action="Edit" asp-route-id="@tc.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@tc.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa giao dịch này?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
