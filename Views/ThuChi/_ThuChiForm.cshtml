@model QuanLyNhaTro.Models.ThuChi
<input type="hidden" asp-for="ThuChiGocId" />
@if (Model.ThuChiGocId.HasValue)
{
    <div class="alert alert-warning py-2">Đây là bút toán điều chỉnh cho giao dịch #@Model.ThuChiGocId. Giao dịch gốc được giữ nguyên.</div>
}
<div class="cashbook-form-grid">
<div class="app-field">
    <label class="form-label">Loại giao dịch <span class="text-danger">*</span></label>
    <select asp-for="LoaiGiaoDich" class="form-select">
        <option value="Thu">Thu</option>
        <option value="Chi">Chi</option>
    </select>
</div>
<div class="app-field">
    <label class="form-label">Danh mục <span class="text-danger">*</span></label>
    <input asp-for="DanhMuc" class="form-control" placeholder="VD: Sửa chữa, Mua sắm, Điện chung..." />
    <span asp-validation-for="DanhMuc" class="text-danger small"></span>
</div>
<div class="app-field cashbook-field-wide">
    <label class="form-label">Nội dung</label>
    <input asp-for="NoiDung" class="form-control" placeholder="VD: Sửa ống nước tầng 2" />
</div>
<div class="app-field">
    <label class="form-label">Số tiền (đ) <span class="text-danger">*</span></label>
    <input asp-for="SoTien" type="number" class="form-control" min="1" step="1" />
    <span asp-validation-for="SoTien" class="text-danger small"></span>
</div>
<div class="app-field">
    <label class="form-label">Ngày phát sinh <span class="text-danger">*</span></label>
    <input asp-for="NgayPhatSinh" type="date" class="form-control" />
    <span asp-validation-for="NgayPhatSinh" class="text-danger small"></span>
</div>
<div class="app-field cashbook-field-wide">
    <label class="form-label">Ghi chú</label>
    <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
</div>
</div>
