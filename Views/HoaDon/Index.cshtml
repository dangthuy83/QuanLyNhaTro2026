@model IEnumerable<QuanLyNhaTro.Models.HoaDon>
@{
    ViewData["Title"] = "Hóa đơn";
    ViewData["ActiveMenu"] = "hoadon";
    var thang = (int)ViewBag.Thang;
    var nam   = (int)ViewBag.Nam;
    var invoices = Model.ToList();
    var today = DateTime.Today;
    var houses = invoices
        .GroupBy(x => new { x.NhaIdSnapshot, x.TenNhaSnapshot })
        .Select(x => x.Key)
        .OrderBy(x => x.TenNhaSnapshot)
        .ToList();
    var tongCong = invoices.Sum(x => x.TongCong);
    var daGhiNhan = invoices.Sum(x => x.SoTienDaThu);
    var thucThu = invoices.Sum(x => x.TienThucThu);
    var conNo = invoices.Sum(x => x.SoTienConLai);
    var noKyTruoc = invoices.Sum(x => x.TienNoKyTruoc);
}

<div class="invoices-page invoices-index-page" data-invoice-list>
    <header class="app-page-header">
        <div class="app-page-heading">
            <h1>Hóa đơn tháng @thang/@nam</h1>
            <p class="app-page-subtitle">Theo dõi số phải thu, tiền đã nhận và công nợ theo từng phòng. Kết chuyển nợ và trừ cọc luôn được tách khỏi tiền thực thu.</p>
        </div>
        <div class="app-page-actions" aria-label="Thao tác module Hóa đơn">
            <a asp-action="ChotHangLoat" asp-route-thang="@thang" asp-route-nam="@nam" class="btn btn-primary"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-check"></use></svg>Chốt hàng loạt</span></a>
        </div>
    </header>

    <section class="app-panel invoices-period-panel" aria-labelledby="invoice-period-heading">
        <div>
            <h2 id="invoice-period-heading">Kỳ hóa đơn</h2>
            <p>Đổi kỳ để xem đúng snapshot hóa đơn đã chốt.</p>
        </div>
        <form method="get" class="invoices-period-form">
            <div><label for="invoice-month">Tháng</label><select id="invoice-month" name="thang" class="form-select">@for (int m = 1; m <= 12; m++) { <option value="@m" selected="@(m == thang)">Tháng @m</option> }</select></div>
            <div><label for="invoice-year">Năm</label><input id="invoice-year" name="nam" type="number" class="form-control" value="@nam" min="2020" max="2099" /></div>
            <button class="btn btn-outline-primary" type="submit"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-refresh"></use></svg>Xem kỳ</span></button>
        </form>
    </section>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="status">@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div>
}

@if (invoices.Any())
{
    <section class="invoices-summary-strip" aria-label="Tổng hợp kỳ hóa đơn">
        <div><span>Tổng hóa đơn</span><strong>@tongCong.ToString("N0") đ</strong><small>@invoices.Count hóa đơn</small></div>
        <div><span>Tiền thực thu</span><strong class="is-success">@thucThu.ToString("N0") đ</strong><small>Tiền mặt + chuyển khoản</small></div>
        <div><span>Đã ghi nhận</span><strong>@daGhiNhan.ToString("N0") đ</strong><small>Gồm bút toán phi tiền mặt</small></div>
        <div><span>Còn nợ</span><strong class="is-danger">@conNo.ToString("N0") đ</strong><small>Sau mọi thanh toán</small></div>
        <div><span>Nợ kỳ trước</span><strong class="@(noKyTruoc > 0 ? "is-warning" : "")">@noKyTruoc.ToString("N0") đ</strong><small>Snapshot khi chốt kỳ</small></div>
    </section>

    <section class="app-panel invoices-filter-panel" aria-labelledby="invoice-filter-heading">
        <h2 id="invoice-filter-heading" class="visually-hidden">Tìm và lọc hóa đơn</h2>
        <div class="invoices-filter-grid">
            <div class="invoices-filter-field invoices-filter-search"><label for="invoice-search">Tìm hóa đơn</label><div class="invoices-search-control"><svg class="app-icon" aria-hidden="true"><use href="#icon-search"></use></svg><input id="invoice-search" class="form-control" type="search" placeholder="Nhà, phòng hoặc khách thuê" autocomplete="off" data-invoice-filter-search /></div></div>
            <div class="invoices-filter-field"><label for="invoice-house-filter">Nhà</label><select id="invoice-house-filter" class="form-select" data-invoice-filter-house><option value="">Tất cả nhà</option>@foreach (var house in houses) { <option value="@house.NhaIdSnapshot">@house.TenNhaSnapshot</option> }</select></div>
            <div class="invoices-filter-field"><label for="invoice-status-filter">Trạng thái</label><select id="invoice-status-filter" class="form-select" data-invoice-filter-status><option value="">Tất cả trạng thái</option><option value="ChuaThu">Chưa thu</option><option value="ThuMotPhan">Thu một phần</option><option value="DaThu">Đã thu</option><option value="QuaHan">Quá hạn</option></select></div>
            <button class="btn btn-outline-secondary invoices-filter-reset" type="button" data-invoice-filter-reset><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-refresh"></use></svg>Đặt lại</span></button>
        </div>
        <div class="invoices-filter-meta"><span>Kết quả cập nhật ngay, không đổi kỳ đang xem.</span><output data-invoice-result-count aria-live="polite">@invoices.Count hóa đơn</output></div>
    </section>
}

<section class="app-panel invoices-list-panel" aria-labelledby="invoice-list-heading">
    <h2 id="invoice-list-heading" class="visually-hidden">Danh sách hóa đơn</h2>
    <div class="table-responsive">
        <table class="table mb-0 align-middle invoices-table">
            <thead>
                <tr>
                    <th>Nhà / phòng / khách</th>
                    <th class="text-end">Tiền phòng</th>
                    <th class="text-end">Dịch vụ</th>
                    <th class="text-end">Nợ kỳ trước</th>
                    <th class="text-end">Tổng cộng</th>
                    <th class="text-end">Đã ghi nhận</th>
                    <th>Hạn thu / trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hd in invoices)
                {
                    var conLai = hd.SoTienConLai;
                    var chuaThuDu = conLai > 0 && hd.TrangThaiThanhToan != "DaThu";
                    var quaHan = chuaThuDu && hd.NgayDenHan.Date < today;
                    var tienThucThu = hd.TienThucThu;
                    var coKetChuyenNo = hd.DanhSachThanhToan.Any(tt => tt.HinhThuc == "KetChuyenNo");
                    var coTruCoc = hd.DanhSachThanhToan.Any(tt => tt.HinhThuc == "TruCoc");
                    var modalId = $"thuNhanhModal{hd.Id}";
                    <tr data-invoice-row data-search="@hd.TenNhaSnapshot @hd.TenPhongSnapshot @hd.TenKhachDaiDienSnapshot" data-house="@hd.NhaIdSnapshot" data-status="@hd.TrangThaiThanhToan" data-overdue="@quaHan.ToString().ToLowerInvariant()">
                        <td data-label="Nhà / phòng / khách">
                            <a asp-action="Details" asp-route-id="@hd.Id" class="invoices-room-name">@hd.TenPhongSnapshot</a>
                            <span class="invoices-cell-meta">@hd.TenNhaSnapshot · @hd.TenKhachDaiDienSnapshot</span>
                            <span class="invoices-cell-meta">Hóa đơn #@hd.Id · Kỳ @hd.Thang/@hd.Nam</span>
                        </td>
                        <td class="text-end" data-label="Tiền phòng"><strong>@hd.TienPhong.ToString("N0") đ</strong></td>
                        <td class="text-end" data-label="Dịch vụ"><strong>@hd.TongTienDichVu.ToString("N0") đ</strong>@if (hd.TongTienPhatSinh > 0) { <span class="invoices-cell-meta">+ @hd.TongTienPhatSinh.ToString("N0") đ phát sinh</span> }</td>
                        <td class="text-end @(hd.TienNoKyTruoc > 0 ? "text-danger" : "")" data-label="Nợ kỳ trước">
                            <div>@hd.TienNoKyTruoc.ToString("N0") đ</div>
                            @if (hd.TienNoKyTruoc > 0)
                            {
                                <span class="app-status-badge is-danger"><span class="app-status-dot" aria-hidden="true"></span>Nợ mang sang</span>
                            }
                        </td>
                        <td class="text-end" data-label="Tổng cộng"><strong class="invoices-total-amount">@hd.TongCong.ToString("N0") đ</strong></td>
                        <td class="text-end" data-label="Đã ghi nhận">
                            <strong>@hd.SoTienDaThu.ToString("N0") đ</strong>
                            <span class="invoices-cell-meta">Thực thu @tienThucThu.ToString("N0") đ</span>
                            @if (coKetChuyenNo || coTruCoc)
                            {
                                <div class="d-flex gap-1 justify-content-end flex-wrap mt-1">
                                    @if (coKetChuyenNo)
                                    {
                                        <span class="app-status-badge is-info"><span class="app-status-dot" aria-hidden="true"></span>Kết chuyển nợ</span>
                                    }
                                    @if (coTruCoc)
                                    {
                                        <span class="app-status-badge is-warning"><span class="app-status-dot" aria-hidden="true"></span>Trừ cọc</span>
                                    }
                                </div>
                            }
                        </td>
                        <td data-label="Hạn thu / trạng thái">
                            @Html.Raw(TrangThaiBadge(hd.TrangThaiThanhToan))
                            @if (quaHan)
                            {
                                <span class="app-status-badge is-danger"><span class="app-status-dot" aria-hidden="true"></span>Quá hạn</span>
                            }
                            <span class="invoices-cell-meta">Hạn @hd.NgayDenHan.ToString("dd/MM/yyyy")</span>
                            @if (chuaThuDu)
                            {
                                <div class="small text-muted mt-1">Còn @conLai.ToString("N0") đ</div>
                            }
                        </td>
                        <td class="text-end" data-label="Thao tác">
                            <div class="invoices-row-actions">
                                @if (chuaThuDu)
                                {
                                    <button type="button"
                                            class="btn btn-outline-success"
                                            data-bs-toggle="modal"
                                            data-bs-target="#@modalId"
                                            data-invoice-modal-trigger>
                                        <span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-wallet"></use></svg>Thu nhanh</span>
                                    </button>
                                }
                                <a asp-action="Details" asp-route-id="@hd.Id"
                                   class="btn btn-outline-primary">
                                <span class="app-button-content">Chi tiết<svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg></span>
                                </a>
                            </div>

                            @if (chuaThuDu)
                            {
                                <div class="modal fade text-start invoices-payment-modal" id="@modalId" tabindex="-1" aria-labelledby="@($"{modalId}Label")" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <form asp-action="ThuTien" method="post" class="modal-content">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="hoaDonId" value="@hd.Id" />
                                            <input type="hidden" name="returnTo" value="Index" />
                                            <input type="hidden" name="thang" value="@thang" />
                                            <input type="hidden" name="nam" value="@nam" />

                                            <div class="modal-header">
                                                <div><span class="invoices-modal-context">@hd.TenNhaSnapshot / @hd.TenPhongSnapshot</span><h2 class="modal-title" id="@($"{modalId}Label")">Ghi nhận tiền thực thu</h2></div>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                                            </div>
                                            <div class="modal-body">
                                                <div class="invoices-payment-balance">
                                                    <span>Còn phải thu</span>
                                                    <strong>@conLai.ToString("N0") đ</strong>
                                                </div>

                                                @if (hd.TienNoKyTruoc > 0 || coKetChuyenNo || coTruCoc)
                                                {
                                                    <div class="app-notice is-info invoices-ledger-notice"><svg class="app-icon" aria-hidden="true"><use href="#icon-info"></use></svg><div>
                                                        @if (hd.TienNoKyTruoc > 0)
                                                        {
                                                            <div>Hóa đơn này có nợ kỳ trước: <strong>@hd.TienNoKyTruoc.ToString("N0") đ</strong>.</div>
                                                        }
                                                        @if (coKetChuyenNo || coTruCoc)
                                                        {
                                                            <div>Các badge Kết chuyển nợ/Trừ cọc là bút toán xử lý công nợ, không phải tiền mới thu.</div>
                                                        }
                                                    </div></div>
                                                }

                                                <div class="invoices-form-field">
                                                    <label for="@($"quick-amount-{hd.Id}")">Số tiền <span aria-hidden="true">*</span></label>
                                                    <div class="input-group">
                                                        <input id="@($"quick-amount-{hd.Id}")" name="soTien"
                                                               type="number"
                                                               min="1"
                                                               max="@FormatInputAmount(conLai)"
                                                               step="1"
                                                               class="form-control"
                                                               value="@FormatInputAmount(conLai)"
                                                               required />
                                                        <button type="button"
                                                                class="btn btn-outline-secondary"
                                                                data-quick-fill
                                                                data-amount="@FormatInputAmount(conLai)">
                                                            Thu đủ
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="invoices-form-field">
                                                    <label for="@($"quick-method-{hd.Id}")">Hình thức <span aria-hidden="true">*</span></label>
                                                    <select id="@($"quick-method-{hd.Id}")" name="hinhThuc" class="form-select" required>
                                                        <option value="TienMat">Tiền mặt</option>
                                                        <option value="ChuyenKhoan">Chuyển khoản</option>
                                                    </select>
                                                </div>
                                                <div class="invoices-form-field">
                                                    <label for="@($"quick-note-{hd.Id}")">Ghi chú</label>
                                                    <input id="@($"quick-note-{hd.Id}")" name="ghiChu" class="form-control" autocomplete="off" />
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                                <button type="submit" class="btn btn-success">
                                                    Xác nhận thu
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            }
                        </td>
                    </tr>
                }
                @if (!invoices.Any())
                {
                    <tr><td colspan="8"><div class="app-empty-state"><div><svg class="app-icon" aria-hidden="true"><use href="#icon-receipt"></use></svg><h3>Chưa có hóa đơn trong kỳ này</h3><p>Kiểm tra dữ liệu hợp đồng, dịch vụ và chỉ số trước khi chốt.</p></div></div></td></tr>
                }
            </tbody>
            @if (invoices.Any())
            {
                <tfoot class="table-light fw-semibold">
                    <tr>
                        <td>Tổng</td>
                        <td class="text-end">@invoices.Sum(h => h.TienPhong).ToString("N0")</td>
                        <td class="text-end">@invoices.Sum(h => h.TongTienDichVu).ToString("N0")</td>
                        <td class="text-end">@invoices.Sum(h => h.TienNoKyTruoc).ToString("N0")</td>
                        <td class="text-end">@invoices.Sum(h => h.TongCong).ToString("N0")</td>
                        <td class="text-end">@invoices.Sum(h => h.SoTienDaThu).ToString("N0")</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</section>
@if (invoices.Any())
{
    <div class="app-empty-state invoices-filter-empty" data-invoice-filter-empty hidden><div><svg class="app-icon" aria-hidden="true"><use href="#icon-search"></use></svg><h3>Không có hóa đơn phù hợp</h3><p>Thử đổi từ khóa, Nhà hoặc trạng thái để xem lại danh sách.</p></div></div>
}
</div>

@section Scripts {
    <script src="~/js/invoices.js" asp-append-version="true"></script>
}

@functions {
    static string TrangThaiBadge(string tt) => tt switch
    {
        "DaThu"      => "<span class='app-status-badge is-success'><span class='app-status-dot' aria-hidden='true'></span>Đã thu</span>",
        "ThuMotPhan" => "<span class='app-status-badge is-warning'><span class='app-status-dot' aria-hidden='true'></span>Thu một phần</span>",
        _            => "<span class='app-status-badge is-danger'><span class='app-status-dot' aria-hidden='true'></span>Chưa thu</span>"
    };

    static string FormatInputAmount(decimal amount)
        => decimal.Round(amount, 0).ToString("0", System.Globalization.CultureInfo.InvariantCulture);
}
