@model QuanLyNhaTro.Models.HoaDonHangLoatPreviewViewModel
@{
    ViewData["Title"] = "Xem trước chốt hóa đơn";
    ViewData["ActiveMenu"] = "hoadon";
}

<div class="invoices-page invoices-bulk-page" data-invoice-bulk>
    <a asp-action="Index" asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam" class="invoices-back-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Danh sách hóa đơn</a>
    <header class="app-page-header"><div class="app-page-heading"><h1>Chốt hóa đơn @Model.Thang/@Model.Nam</h1><p class="app-page-subtitle">Bắt đầu từ kỳ, rà từng blocker rồi chỉ chọn các dòng server xác định là sẵn sàng.</p></div></header>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="status">@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div>
}

<section class="app-panel invoices-bulk-filter-panel" aria-labelledby="bulk-filter-heading">
    <div class="app-panel-header"><div><h2 id="bulk-filter-heading">Kỳ và bộ lọc</h2><p>Kết quả, tổng tiền và lựa chọn đều theo bộ lọc hiện tại.</p></div></div>
<form method="get" class="invoices-bulk-filter-form">
    <div class="row g-2 align-items-end">
        <div class="col-6 col-md-2 col-lg-1">
            <label class="form-label" for="bulk-month">Tháng</label>
            <select id="bulk-month" name="thang" class="form-select">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(m == Model.Thang)">Tháng @m</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2 col-lg-1">
            <label class="form-label" for="bulk-year">Năm</label>
            <input id="bulk-year" name="nam" type="number" class="form-control"
                   value="@Model.Nam" min="2020" max="2099" />
        </div>
        <div class="col-md-3 col-lg-2">
            <label class="form-label" for="bulk-house">Nhà</label>
            <select id="bulk-house" name="nhaId" class="form-select">
                <option value="">Tất cả nhà</option>
                @foreach (var nha in Model.DanhSachNha)
                {
                    <option value="@nha.Id" selected="@(Model.NhaId == nha.Id)">@nha.TenNha</option>
                }
            </select>
        </div>
        <div class="col-md-3 col-lg-2">
            <label class="form-label" for="bulk-status">Trạng thái dòng</label>
            <select id="bulk-status" name="trangThaiDong" class="form-select">
                <option value="TatCa" selected="@(Model.TrangThaiDong == "TatCa")">Tất cả</option>
                <option value="SanSang" selected="@(Model.TrangThaiDong == "SanSang")">Sẵn sàng chốt</option>
                <option value="CanKiemTra" selected="@(Model.TrangThaiDong == "CanKiemTra")">Cần kiểm tra</option>
                <option value="ThieuChiSo" selected="@(Model.TrangThaiDong == "ThieuChiSo")">Thiếu chỉ số</option>
                <option value="DaCoHoaDon" selected="@(Model.TrangThaiDong == "DaCoHoaDon")">Đã có hóa đơn</option>
                <option value="ThieuDichVu" selected="@(Model.TrangThaiDong == "ThieuDichVu")">Thiếu dịch vụ</option>
                <option value="ThieuKhach" selected="@(Model.TrangThaiDong == "ThieuKhach")">Thiếu khách</option>
            </select>
        </div>
        <div class="col-md-4 col-lg-4">
            <label class="form-label" for="bulk-search">Tìm phòng/khách</label>
            <input id="bulk-search" name="tuKhoa" class="form-control"
                   value="@Model.TuKhoa" placeholder="Tên phòng, mã HĐ, khách thuê, SĐT" />
        </div>
        <div class="col-md-12 col-lg-2 d-flex gap-2">
            <button class="btn btn-primary flex-fill">Lọc</button>
            <a asp-action="ChotHangLoat" asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam"
               class="btn btn-outline-secondary flex-fill">Xóa lọc</a>
        </div>
    </div>
</form>
</section>

<section class="invoices-summary-strip invoices-bulk-summary" aria-label="Tổng hợp dòng theo bộ lọc">
    <div>
            <div class="text-muted small">Dòng theo bộ lọc</div>
            <div class="fs-5 fw-semibold">@Model.Rows.Count</div>
    </div>
    <div>
            <div class="text-muted small">Sẵn sàng chốt</div>
            <div class="fs-5 fw-semibold text-success">@Model.SoDongSanSang</div>
    </div>
    <div>
            <div class="text-muted small">Cần kiểm tra</div>
            <div class="fs-5 fw-semibold text-warning">@Model.SoDongCanKiemTra</div>
    </div>
    <div>
            <div class="text-muted small">Tổng dự kiến hợp lệ</div>
            <div class="fs-5 fw-semibold">@Model.TongDuKien.ToString("N0") đ</div>
    </div>
</section>

<form asp-action="ChotHangLoat" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="thang" value="@Model.Thang" />
    <input type="hidden" name="nam" value="@Model.Nam" />
    <input type="hidden" name="nhaId" value="@Model.NhaId" />
    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
    <input type="hidden" name="trangThaiDong" value="@Model.TrangThaiDong" />

    <section class="app-panel invoices-bulk-list-panel" aria-labelledby="bulk-list-heading">
        <h2 id="bulk-list-heading" class="visually-hidden">Các hợp đồng trong kỳ</h2>
        <div class="table-responsive">
            <table class="table mb-0 align-middle invoices-bulk-table">
                <thead>
                    <tr>
                        <th class="invoices-select-column">
                            <input class="form-check-input" type="checkbox" id="checkAllReady" aria-label="Chọn tất cả dòng sẵn sàng theo bộ lọc" data-bulk-check-all />
                        </th>
                        <th>Nhà / phòng / hợp đồng</th>
                        <th>Dịch vụ và chỉ số</th>
                        <th class="text-end">Tiền phòng</th>
                        <th class="text-end">Dịch vụ</th>
                        <th class="text-end">Nợ kỳ trước</th>
                        <th class="text-end">Tổng dự kiến</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        var tenNha = Model.DanhSachNha.FirstOrDefault(n => n.Id == row.HopDong?.Phong?.NhaId)?.TenNha;
                        <tr class="@(!row.SanSangChot ? "is-blocked" : "")" data-bulk-row data-ready="@row.SanSangChot.ToString().ToLowerInvariant()">
                            <td data-label="Chọn">
                                <input class="form-check-input ready-check" aria-label="Chọn hợp đồng #@row.HopDongId phòng @row.HopDong?.Phong?.TenPhong"
                                       type="checkbox"
                                       name="hopDongIds"
                                       value="@row.HopDongId"
                                       disabled="@(!row.SanSangChot)" />
                            </td>
                            <td data-label="Nhà / phòng / hợp đồng">
                                <div class="text-muted small">@(tenNha ?? $"Nhà #{row.HopDong?.Phong?.NhaId}")</div>
                                <div class="fw-semibold">@row.HopDong?.Phong?.TenPhong</div>
                                <div class="text-muted small">
                                    HĐ #@row.HopDongId
                                    @if (row.SoNgayO.HasValue && row.SoNgayTrongThang.HasValue)
                                    {
                                        <span> · @row.SoNgayO/@row.SoNgayTrongThang ngày</span>
                                    }
                                </div>
                                @if (row.HopDong?.DanhSachKhach.Any() == true)
                                {
                                    <div class="small">@string.Join(", ", row.HopDong.DanhSachKhach.Select(k => k.HoTen))</div>
                                }
                                <div class="text-muted small">
                                    Từ @row.HopDong?.NgayBatDau.ToString("dd/MM/yyyy")
                                </div>
                            </td>
                            <td data-label="Dịch vụ và chỉ số">
                                @if (row.ChiTiet.Any() || row.KhoanPhatSinh.Any())
                                {
                                    <div class="d-flex flex-column gap-1">
                                        @foreach (var ct in row.ChiTiet)
                                        {
                                            <div class="small">
                                                <span class="fw-semibold">@ct.TenDichVu</span>
                                                <span class="text-muted">
                                                    @ct.SoLuong.ToString("N2") x @ct.DonGia.ToString("N0") = @ct.ThanhTien.ToString("N0") đ
                                                </span>
                                                @if (ct.CanChiSo)
                                                {
                                                    <span class="app-status-badge is-success"><span class="app-status-dot" aria-hidden="true"></span>Đã có chỉ số</span>
                                                }
                                            </div>
                                        }
                                        @foreach (var khoan in row.KhoanPhatSinh)
                                        {
                                            <div class="small text-danger">
                                                <span class="fw-semibold">@khoan.MoTa</span>
                                                <span class="text-muted">@khoan.SoTienConLai.ToString("N0") đ</span>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small">Chưa có dòng dịch vụ phát sinh.</span>
                                }
                            </td>
                            <td class="text-end" data-label="Tiền phòng">@row.TienPhong.ToString("N0") đ</td>
                            <td class="text-end" data-label="Dịch vụ">
                                @row.TongTienDichVu.ToString("N0")
                                @if (row.TongTienPhatSinh > 0)
                                {
                                    <div class="small text-danger">+ @row.TongTienPhatSinh.ToString("N0") phát sinh</div>
                                }
                            </td>
                            <td class="text-end @(row.TienNoKyTruoc > 0 ? "text-danger fw-semibold" : "")" data-label="Nợ kỳ trước">@row.TienNoKyTruoc.ToString("N0") đ</td>
                            <td class="text-end fw-semibold" data-label="Tổng dự kiến">@row.TongCong.ToString("N0") đ</td>
                            <td data-label="Trạng thái">
                                <div class="d-flex flex-wrap gap-1 mb-1">
                                    @if (row.CoHoaDonDaCo)
                                    {
                                        <a asp-action="Details" asp-route-id="@row.HoaDonDaCo!.Id"
                                           class="app-status-badge is-neutral text-decoration-none"><span class="app-status-dot" aria-hidden="true"></span>Đã có hóa đơn #@row.HoaDonDaCo!.Id</a>
                                    }
                                    @if (row.ThieuChiSo)
                                    {
                                        <span class="app-status-badge is-danger"><span class="app-status-dot" aria-hidden="true"></span>Thiếu chỉ số</span>
                                    }
                                    @if (row.ThieuDichVu)
                                    {
                                        <span class="app-status-badge is-warning"><span class="app-status-dot" aria-hidden="true"></span>Thiếu dịch vụ</span>
                                    }
                                    @if (row.ThieuKhach)
                                    {
                                        <span class="app-status-badge is-danger"><span class="app-status-dot" aria-hidden="true"></span>Thiếu khách</span>
                                    }
                                    @if (row.CoNoKyTruoc)
                                    {
                                        <span class="app-status-badge is-warning"><span class="app-status-dot" aria-hidden="true"></span>Có nợ kỳ trước</span>
                                    }
                                    @if (row.SanSangChot)
                                    {
                                        <span class="app-status-badge is-success"><span class="app-status-dot" aria-hidden="true"></span>Sẵn sàng chốt</span>
                                    }
                                </div>

                                @foreach (var loi in row.Loi)
                                {
                                    <div class="small text-danger">@loi</div>
                                }
                                @foreach (var canhBao in row.CanhBao)
                                {
                                    <div class="small text-muted">@canhBao</div>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">Không có dòng nào khớp bộ lọc.</td>
                        </tr>
                    }
                </tbody>
                @if (Model.Rows.Any())
                {
                    <tfoot class="table-light fw-semibold">
                        <tr>
                            <td colspan="3">Tổng các dòng sẵn sàng theo bộ lọc</td>
                            <td class="text-end">@Model.Rows.Where(x => x.SanSangChot).Sum(x => x.TienPhong).ToString("N0")</td>
                            <td class="text-end">@Model.Rows.Where(x => x.SanSangChot).Sum(x => x.TongTienDichVu + x.TongTienPhatSinh).ToString("N0")</td>
                            <td class="text-end">@Model.Rows.Where(x => x.SanSangChot).Sum(x => x.TienNoKyTruoc).ToString("N0")</td>
                            <td class="text-end">@Model.TongDuKien.ToString("N0")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center p-3 border-top flex-wrap gap-2">
            <div><strong><output data-bulk-selected-count aria-live="polite">0 dòng đã chọn</output></strong><div class="small text-muted">@Model.SoDongCanKiemTra dòng cần kiểm tra sẽ không được chốt.</div></div>
            <button type="submit" class="btn btn-primary" disabled="@(Model.SoDongSanSang == 0)">
                Chốt các dòng đã chọn
            </button>
        </div>
    </section>
</form>

@section Scripts {
    <script src="~/js/invoices.js" asp-append-version="true"></script>
}
</div>
