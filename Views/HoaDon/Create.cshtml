@{
    ViewData["Title"] = "Lập hóa đơn";
    ViewData["ActiveMenu"] = "hoadon";
    var hopDong = ViewBag.HopDong as QuanLyNhaTro.Models.HopDong;
    var thang   = (int)ViewBag.Thang;
    var nam     = (int)ViewBag.Nam;
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-controller="HopDong" asp-action="Details" asp-route-id="@hopDong?.Id"
       class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Lập hóa đơn — @hopDong?.Phong?.TenPhong</h5>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card shadow-sm" style="max-width:420px">
    <div class="card-body">
        <p class="text-muted small mb-3">
            Hệ thống sẽ tự tính tiền phòng, dịch vụ và nợ kỳ trước dựa trên chỉ số điện nước đã nhập.
        </p>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="hopDongId" value="@hopDong?.Id" />

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">Kỳ tháng <span class="text-danger">*</span></label>
                    <select name="thang" class="form-select">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == thang)">Tháng @m</option>
                        }
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Năm <span class="text-danger">*</span></label>
                    <input name="nam" type="number" class="form-control"
                           value="@nam" min="2020" max="2099" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-receipt me-1"></i>Tạo hóa đơn
                </button>
                <a asp-controller="HopDong" asp-action="Details" asp-route-id="@hopDong?.Id"
                   class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>
    </div>
</div>
