@model QuanLyNhaTro.Models.PhieuThuHtmlViewModel
@{
    ViewData["Title"] = $"Phiếu thu #{Model.HoaDon.Id}";
    ViewData["ActiveMenu"] = "hoadon";
    var conLai = Model.ConLai;
    var tienThucThu = Model.TienThucThu;
    var butToanPhiTienMat = Model.ButToanPhiTienMat;
}

<div class="invoices-page receipt-page" data-invoice-receipt>
    <div class="receipt-toolbar">
        <div class="d-flex gap-2">
            <a asp-action="Details" asp-route-id="@Model.HoaDon.Id" class="btn btn-outline-secondary">
                <span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Chi tiết</span>
            </a>
            <a asp-action="XuatPhieuThu" asp-route-id="@Model.HoaDon.Id" class="btn btn-outline-success">
                Xuất Excel
            </a>
        </div>
        <button type="button" class="btn btn-primary" data-print-receipt>
            <span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-receipt"></use></svg>In phiếu thu</span>
        </button>
    </div>

    <main class="receipt-sheet" aria-label="Phiếu thu tiền phòng">
        <div class="text-center mb-4">
            <div class="text-uppercase fw-semibold">@Model.HoaDon.TenNhaSnapshot</div>
            <h4 class="receipt-title fw-bold mt-2 mb-1">PHIẾU THU TIỀN PHÒNG</h4>
            <div class="text-muted">Kỳ tháng @Model.HoaDon.Thang/@Model.HoaDon.Nam · Phiếu #@Model.HoaDon.Id</div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-7">
                <table class="receipt-meta w-100">
                    <tr>
                        <td class="text-muted receipt-meta-label">Phòng</td>
                        <td class="fw-semibold">@Model.HoaDon.TenPhongSnapshot</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Khách thuê</td>
                        <td>@Model.TenKhach</td>
                    </tr>
                    <tr>
                        <td class="text-muted">CCCD</td>
                        <td>@(Model.HoaDon.CccdKhachDaiDienSnapshot ?? "—")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Hợp đồng</td>
                        <td>#@Model.HoaDon.HopDongId</td>
                    </tr>
                </table>
            </div>
            <div class="col-md-5">
                <table class="receipt-meta w-100">
                    <tr>
                        <td class="text-muted receipt-meta-label">Ngày lập</td>
                        <td>@Model.HoaDon.NgayLap.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Ngày in</td>
                        <td>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Trạng thái</td>
                        <td>@Html.Raw(TrangThaiBadge(Model.HoaDon.TrangThaiThanhToan))</td>
                    </tr>
                </table>
            </div>
        </div>

        @if (Model.CoButToanPhiTienMat)
        {
            <div class="alert alert-info py-2 small">
                Các dòng <strong>Kết chuyển nợ</strong> và <strong>Trừ cọc</strong> là bút toán xử lý công nợ,
                không phải tiền mặt/chuyển khoản mới thu.
            </div>
        }

        <section class="receipt-payment-summary" aria-label="Tổng hợp thanh toán">
            <div><span>Tiền thực thu</span><strong>@tienThucThu.ToString("N0") đ</strong><small>Tiền mặt + chuyển khoản</small></div>
            <div><span>Bút toán phi tiền mặt</span><strong>@butToanPhiTienMat.ToString("N0") đ</strong><small>Kết chuyển nợ + trừ cọc</small></div>
            <div><span>Còn lại</span><strong>@Math.Max(0, conLai).ToString("N0") đ</strong><small>Sau mọi khoản đã ghi nhận</small></div>
        </section>

        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th class="receipt-col-index">STT</th>
                    <th>Nội dung</th>
                    <th class="receipt-col-unit">ĐVT</th>
                    <th class="text-end receipt-col-quantity">Số lượng</th>
                    <th class="text-end receipt-col-price">Đơn giá</th>
                    <th class="text-end receipt-col-total">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var stt = 1;
                }
                <tr>
                    <td>@stt</td>
                    <td>
                        Tiền phòng
                        @if (Model.HoaDon.SoNgayO.HasValue)
                        {
                            <span class="text-muted">(@Model.HoaDon.SoNgayO/@Model.HoaDon.SoNgayTrongThang ngày)</span>
                        }
                    </td>
                    <td>Tháng</td>
                    <td class="text-end">1</td>
                    <td class="text-end">@Model.HoaDon.TienPhong.ToString("N0")</td>
                    <td class="text-end fw-semibold">@Model.HoaDon.TienPhong.ToString("N0")</td>
                </tr>
                @foreach (var ct in Model.ChiTiet)
                {
                    stt++;
                    <tr>
                        <td>@stt</td>
                        <td>@ct.TenDichVuSnapshot</td>
                        <td>@ct.DonViTinhSnapshot</td>
                        <td class="text-end">@ct.SoLuong.ToString("N2")</td>
                        <td class="text-end">@ct.DonGia.ToString("N0")</td>
                        <td class="text-end fw-semibold">@ct.ThanhTien.ToString("N0")</td>
                    </tr>
                }
                @foreach (var khoan in Model.KhoanPhatSinh)
                {
                    stt++;
                    <tr>
                        <td>@stt</td>
                        <td>@khoan.MoTaTrenHoaDon</td>
                        <td>@khoan.LoaiKhoan</td>
                        <td class="text-end">1</td>
                        <td class="text-end">@khoan.SoTienTrenHoaDon.ToString("N0")</td>
                        <td class="text-end fw-semibold">@khoan.SoTienTrenHoaDon.ToString("N0")</td>
                    </tr>
                }
                @if (Model.HoaDon.TienNoKyTruoc != 0)
                {
                    stt++;
                    <tr class="@(Model.HoaDon.TienNoKyTruoc > 0 ? "text-danger" : "text-success")">
                        <td>@stt</td>
                        <td>@(Model.HoaDon.TienNoKyTruoc > 0 ? "Nợ kỳ trước" : "Dư kỳ trước")</td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td class="text-end fw-semibold">@Model.HoaDon.TienNoKyTruoc.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="5" class="text-end fw-semibold">Tổng cộng</td>
                    <td class="text-end fw-bold">@Model.HoaDon.TongCong.ToString("N0")</td>
                </tr>
                <tr>
                    <td colspan="5" class="text-end">Đã thu</td>
                    <td class="text-end text-success fw-semibold">@Model.HoaDon.SoTienDaThu.ToString("N0")</td>
                </tr>
                <tr>
                    <td colspan="5" class="text-end fw-semibold">@(conLai > 0 ? "Còn lại" : "Dư")</td>
                    <td class="text-end fw-bold @(conLai > 0 ? "text-danger" : "text-success")">@Math.Abs(conLai).ToString("N0")</td>
                </tr>
            </tfoot>
        </table>

        @if (Model.LichSuThanhToan.Any())
        {
            <h6 class="mt-4 mb-2">Lịch sử thanh toán</h6>
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ngày</th>
                        <th>Hình thức</th>
                        <th class="text-end">Số tiền</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tt in Model.LichSuThanhToan)
                    {
                        <tr>
                            <td>@tt.NgayThu.ToString("dd/MM/yyyy")</td>
                            <td>@HinhThucText(tt.HinhThuc)</td>
                            <td class="text-end">@tt.SoTien.ToString("N0")</td>
                            <td>@tt.GhiChu</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="row text-center mt-5">
            <div class="col-6">
                <div class="fw-semibold">Người nộp tiền</div>
                <div class="text-muted small">(Ký, ghi rõ họ tên)</div>
                <div class="signature-box"></div>
            </div>
            <div class="col-6">
                <div class="fw-semibold">Người thu tiền</div>
                <div class="text-muted small">(Ký, ghi rõ họ tên)</div>
                <div class="signature-box"></div>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <script src="~/js/invoices.js" asp-append-version="true"></script>
}

@functions {
    static string HinhThucText(string? hinhThuc) => hinhThuc switch
    {
        "TienMat" => "Tiền mặt",
        "ChuyenKhoan" => "Chuyển khoản",
        "KetChuyenNo" => "Kết chuyển nợ",
        "TruCoc" => "Trừ cọc",
        null or "" => "Không rõ",
        _ => hinhThuc
    };

    static string TrangThaiBadge(string? trangThai) => trangThai switch
    {
        "DaThu" => "<span class='app-status-badge is-success'><span class='app-status-dot' aria-hidden='true'></span>Đã thu đủ</span>",
        "ThuMotPhan" => "<span class='app-status-badge is-warning'><span class='app-status-dot' aria-hidden='true'></span>Thu một phần</span>",
        _ => "<span class='app-status-badge is-danger'><span class='app-status-dot' aria-hidden='true'></span>Chưa thu</span>"
    };
}
