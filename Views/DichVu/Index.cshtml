@model IEnumerable<QuanLyNhaTro.Models.DichVu>
@using System.Globalization
@{ ViewData["Title"] = "Dịch vụ và giá"; ViewData["ActiveMenu"] = "dichvu"; }
<div class="services-page">
    <header class="app-page-header"><div class="app-page-heading"><h1>Dịch vụ và giá</h1><p class="app-page-subtitle">Cấu hình loại tính phí, đơn vị, giá gợi ý và hình thức áp dụng theo kỳ.</p></div><div class="app-page-actions"><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#modalThemDV">Thêm dịch vụ</button></div></header>
    @if (TempData["Success"] != null) { <div class="app-notice is-success" role="status">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="app-notice is-danger" role="alert">@TempData["Error"]</div> }
    <div class="app-notice is-info"><div><strong>Giá mặc định chỉ là giá gợi ý.</strong><p>Giá áp dụng cho từng phòng/hợp đồng và lịch sử theo kỳ vẫn do dữ liệu server hiện hữu quyết định.</p></div></div>
    <section class="app-panel"><div class="app-panel-header"><div><h2>Danh mục dịch vụ</h2><p>@Model.Count() dịch vụ đang cấu hình.</p></div></div>
    @if (!Model.Any()) { <div class="app-empty-state"><div><h3>Chưa có dịch vụ</h3><p>Thêm dịch vụ đầu tiên và chọn cách tính phí phù hợp.</p></div></div> }
    else { <div class="services-table-wrap"><table class="services-table"><thead><tr><th>Dịch vụ</th><th>Hình thức tính</th><th>Đăng ký</th><th>Đơn vị</th><th>Giá mặc định</th><th>Thao tác</th></tr></thead><tbody>@foreach (var dv in Model) { <tr><td data-label="Dịch vụ"><strong>@dv.TenDichVu</strong></td><td data-label="Hình thức tính"><span class="app-status-badge @(dv.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiTheoChiSo ? "is-info" : "is-neutral")">@dv.LoaiTinhPhiHienThi</span><small>@(dv.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh ? dv.CachTinhCoDinhHienThi : "Theo lượng tiêu thụ")</small></td><td data-label="Đăng ký"><span class="app-status-badge @(dv.BatBuocKhiThue ? "is-danger" : "is-neutral")">@(dv.BatBuocKhiThue ? "Bắt buộc" : "Tùy chọn")</span></td><td data-label="Đơn vị">@(dv.DonViTinh ?? "Chưa đặt")</td><td data-label="Giá mặc định" class="services-price">@dv.DonGiaMacDinh.ToString("N0") đ</td><td data-label="Thao tác" class="services-actions"><a asp-controller="HinhThucDichVu" asp-action="Create" asp-route-dichVuId="@dv.Id" class="btn btn-sm btn-outline-primary">Hình thức theo kỳ</a><button class="btn btn-sm btn-outline-secondary btn-edit-service" type="button" data-id="@dv.Id" data-ten="@dv.TenDichVu" data-loai="@dv.LoaiTinhPhi" data-cachtinh="@dv.CachTinhCoDinh" data-donvi="@dv.DonViTinh" data-dongia="@dv.DonGiaMacDinh.ToString("0.##", CultureInfo.InvariantCulture)" data-batbuoc="@dv.BatBuocKhiThue.ToString().ToLowerInvariant()">Chỉnh sửa</button></td></tr> }</tbody></table></div> }
    </section>
</div>

<div class="modal fade services-page" id="modalThemDV" tabindex="-1" aria-labelledby="createServiceTitle" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="Create" method="post">@Html.AntiForgeryToken()<div class="modal-header"><h2 class="modal-title fs-5" id="createServiceTitle">Thêm dịch vụ</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button></div><div class="modal-body"><partial name="_DichVuForm" model="new QuanLyNhaTro.Models.DichVu()" /></div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu dịch vụ</button></div></form></div></div></div>
<div class="modal fade services-page" id="modalSuaDV" tabindex="-1" aria-labelledby="editServiceTitle" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="Edit" method="post">@Html.AntiForgeryToken()<input type="hidden" name="Id" /><div class="modal-header"><h2 class="modal-title fs-5" id="editServiceTitle">Chỉnh sửa dịch vụ</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button></div><div class="modal-body"><partial name="_DichVuForm" model="new QuanLyNhaTro.Models.DichVu()" /></div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu thay đổi</button></div></form></div></div></div>
@section Scripts { <script src="~/js/services.js" asp-append-version="true"></script> }
