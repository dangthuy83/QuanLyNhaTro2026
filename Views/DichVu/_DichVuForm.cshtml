@model QuanLyNhaTro.Models.DichVu
@using System.Globalization

<div class="mb-2">
    <label class="form-label small fw-semibold">Tên dịch vụ <span class="text-danger">*</span></label>
    <input name="TenDichVu" class="form-control form-control-sm" value="@Model.TenDichVu" required />
</div>
<div class="mb-2">
    <label class="form-label small fw-semibold">Loại tính phí</label>
    <select name="LoaiTinhPhi" class="form-select form-select-sm">
        <option value="CoDinh" selected="@(Model.LoaiTinhPhi == "CoDinh")">Cố định</option>
        <option value="TheoChiSo" selected="@(Model.LoaiTinhPhi == "TheoChiSo")">Theo chỉ số</option>
    </select>
</div>
<div class="mb-2">
    <label class="form-label small fw-semibold">Cách tính cố định</label>
    <select name="CachTinhCoDinh" class="form-select form-select-sm">
        <option value="TheoPhong" selected="@(Model.CachTinhCoDinh == "TheoPhong")">Theo phòng</option>
        <option value="TheoNguoi" selected="@(Model.CachTinhCoDinh == "TheoNguoi")">Theo người</option>
    </select>
    <div class="form-text small">Chỉ áp dụng khi loại tính phí là cố định.</div>
</div>
<div class="mb-2">
    <label class="form-label small fw-semibold">Đơn vị</label>
    <input name="DonViTinh" class="form-control form-control-sm" value="@Model.DonViTinh" placeholder="kWh, m3, tháng..." />
</div>
<div class="mb-2">
    <label class="form-label small fw-semibold">Đơn giá mặc định</label>
    <input name="DonGiaMacDinh" type="number" min="0" step="1"
           class="form-control form-control-sm" value="@Model.DonGiaMacDinh.ToString("0.##", CultureInfo.InvariantCulture)" />
    <div class="form-text small">Chỉ dùng làm gợi ý khi gán dịch vụ cho phòng.</div>
</div>
