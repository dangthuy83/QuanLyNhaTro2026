@model QuanLyNhaTro.Models.ChuyenPhongViewModel
@{
    ViewData["Title"] = "Chuyển phòng";
    var selectedIds = string.Join(",", Model.PhongDichVuIds ?? []);
}

<div class="lifecycle-page lifecycle-transfer-page"
     data-lifecycle="transfer"
     data-selected-service-ids="@selectedIds"
     data-restore-selection="@((Model.PhongDichVuIds?.Length ?? 0) > 0 ? "true" : "false")"
     data-meter-url="@Url.Action("NhapTheoPhong", "ChiSo")"
     data-service-url="@Url.Action("DichVuTheoPhong", "HopDong")"
     data-old-contract-id="@Model.HopDongCuId">
    <header class="app-page-header">
        <div>
            <span class="app-page-eyebrow">Vòng đời hợp đồng</span>
            <h1>Chuyển phòng từ @Model.TenPhongCu</h1>
            <p>Chọn ngày bàn giao và phòng mới. Hệ thống hiện hữu quyết định hóa đơn, chỉ số và hợp đồng kế tiếp.</p>
        </div>
        <a asp-controller="HopDong" asp-action="Details" asp-route-id="@Model.HopDongCuId" class="btn btn-outline-secondary">Về hợp đồng</a>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="app-notice app-notice-success" role="status">
            <strong>Đã xử lý.</strong> @TempData["Success"]
        </div>
    }

    <div class="app-notice app-notice-info" role="note">
        <strong>Mốc cần nhớ:</strong> ngày chuyển đi là ngày cuối ở phòng cũ; phòng mới tính từ ngày kế tiếp.
        Khoản phát sinh đến hết ngày chuyển thuộc hóa đơn phòng cũ.
    </div>

    <form asp-action="Create" method="post" class="app-panel lifecycle-form-panel">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="HopDongCuId" />
        <div class="app-panel-header">
            <div>
                <h2>Thông tin bàn giao</h2>
                <p>Giá trị tiền và dịch vụ được gửi về server theo đúng contract hiện hữu.</p>
            </div>
        </div>
        <div class="app-panel-body lifecycle-form-grid">
            <div class="lifecycle-field-wide">
                <label asp-for="NgayChuyenDi" class="form-label">Ngày chuyển đi <span class="text-danger" aria-hidden="true">*</span></label>
                <input asp-for="NgayChuyenDi" type="date" class="form-control" />
                <span asp-validation-for="NgayChuyenDi" class="text-danger small"></span>
            </div>

            <section class="lifecycle-room-card" aria-labelledby="new-room-title">
                <h3 id="new-room-title">1. Chọn phòng mới</h3>
                <label asp-for="PhongMoiId" class="form-label">Phòng trống <span class="text-danger" aria-hidden="true">*</span></label>
                <select asp-for="PhongMoiId" class="form-select">
                    <option value="">-- Chọn phòng trống --</option>
                    @foreach (var room in Model.DsPhongTrong)
                    {
                        <option value="@room.Id">@room.TenPhong - @room.GiaThueMacDinh.ToString("N0") đ/tháng</option>
                    }
                </select>
                <span asp-validation-for="PhongMoiId" class="text-danger small"></span>
                <a id="linkNhapChiSoPhongMoi" href="#" class="btn btn-outline-primary disabled" aria-disabled="true">
                    Nhập chỉ số phòng mới
                </a>
                <p class="form-text">Dịch vụ theo chỉ số cần có chỉ số kỳ chuyển trước khi xác nhận.</p>
            </section>

            <section class="lifecycle-room-card" aria-labelledby="new-contract-title">
                <h3 id="new-contract-title">2. Giá trị hợp đồng mới</h3>
                <div class="lifecycle-money-grid">
                    <div>
                        <label asp-for="TienThueMoi" class="form-label">Tiền thuê mới (đ) <span class="text-danger" aria-hidden="true">*</span></label>
                        <input asp-for="TienThueMoi" type="number" class="form-control" min="0" step="50000" />
                        <span asp-validation-for="TienThueMoi" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="TienCocMoi" class="form-label">Tiền cọc mới (đ)</label>
                        <input asp-for="TienCocMoi" type="number" class="form-control" min="0" step="100000" />
                        <p class="form-text">Cọc phòng cũ: <strong>@Model.TienCocCu.ToString("N0") đ</strong></p>
                    </div>
                </div>
            </section>

            <section class="lifecycle-field-wide lifecycle-services" aria-labelledby="new-services-title">
                <h3 id="new-services-title">3. Dịch vụ hợp đồng mới</h3>
                <div id="dichVuPhongMoi" class="lifecycle-service-list" aria-live="polite">
                    <p class="text-muted small mb-0">Chọn phòng mới để tải dịch vụ.</p>
                </div>
                <p class="form-text">Dịch vụ bắt buộc được đánh dấu bằng chữ và không thể bỏ chọn.</p>
            </section>

            <div class="lifecycle-field-wide app-notice app-notice-warning" role="note">
                Dịch vụ cố định và theo chỉ số được tính theo quy tắc hiện hữu của service. JavaScript trên màn hình này không tính tiền hay quyết định khả năng chuyển.
            </div>
        </div>
        <div class="lifecycle-form-actions">
            <a asp-controller="HopDong" asp-action="Details" asp-route-id="@Model.HopDongCuId" class="btn btn-outline-secondary">Hủy</a>
            <button class="btn btn-primary">Xác nhận chuyển phòng</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/lifecycle.js" asp-append-version="true"></script>
}
