@model QuanLyNhaTro.Models.ChuyenPhongViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Chuyển phòng";
    var selectedJson = JsonSerializer.Serialize(Model.PhongDichVuIds ?? []);
    var restoreSelection = Model.PhongDichVuIds?.Length > 0;
}

<h4>Chuyển phòng - <span class="text-primary">@Model.TenPhongCu</span></h4>
<p class="text-muted">Tự động sinh 2 hóa đơn tháng chuyển và tạo hợp đồng mới.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2" style="max-width:560px">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm" style="max-width:560px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="HopDongCuId" />
            <div class="mb-3">
                <label class="form-label">Ngày chuyển đi <span class="text-danger">*</span></label>
                <input asp-for="NgayChuyenDi" type="date" class="form-control" />
                <div class="form-text">Ngày cuối ở phòng cũ. Phòng mới tính từ ngày hôm sau.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Dịch vụ hợp đồng mới</label>
                <div id="dichVuPhongMoi" class="border rounded p-2">
                    <p class="text-muted small mb-0">Chọn phòng mới để tải dịch vụ.</p>
                </div>
                <div class="form-text">Dịch vụ bắt buộc không thể bỏ.</div>
            </div>

            <hr>
            <h6 class="fw-bold">Phòng mới</h6>
            <div class="mb-3">
                <label class="form-label">Chọn phòng <span class="text-danger">*</span></label>
                <select asp-for="PhongMoiId" class="form-select">
                    <option value="">-- Chọn phòng trống --</option>
                    @foreach (var p in Model.DsPhongTrong)
                    {
                        <option value="@p.Id">@p.TenPhong - @p.GiaThueMacDinh.ToString("N0") đ/tháng</option>
                    }
                </select>
                <span asp-validation-for="PhongMoiId" class="text-danger small"></span>
                <div class="form-text">
                    Nếu phòng mới có dịch vụ theo chỉ số, hãy nhập chỉ số kỳ chuyển trước khi xác nhận.
                </div>
                <a id="linkNhapChiSoPhongMoi"
                   href="#"
                   class="btn btn-sm btn-outline-primary mt-2 disabled"
                   aria-disabled="true">
                    <i class="bi bi-speedometer2"></i> Nhập chỉ số phòng mới
                </a>
            </div>

            <div class="row g-3 mb-3">
                <div class="col">
                    <label class="form-label">Tiền thuê mới (đ) <span class="text-danger">*</span></label>
                    <input asp-for="TienThueMoi" type="number" class="form-control" min="0" step="50000" />
                    <span asp-validation-for="TienThueMoi" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label class="form-label">Tiền cọc mới (đ)</label>
                    <input asp-for="TienCocMoi" type="number" class="form-control" min="0" step="100000" />
                    <div class="form-text">Cọc cũ: @Model.TienCocCu.ToString("N0") đ</div>
                </div>
            </div>

            <div class="alert alert-info py-2 small">
                <i class="bi bi-info-circle"></i>
                DV <strong>Cố định</strong> chỉ tính ở hóa đơn phòng mới.
                DV <strong>Theo chỉ số</strong> cần có chỉ số phòng cũ và phòng mới trong kỳ chuyển.
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary">Xác nhận chuyển phòng</button>
                <a asp-controller="HopDong" asp-action="Details"
                   asp-route-id="@Model.HopDongCuId" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

<script>
    (() => {
        const phongSelect = document.querySelector("[name='PhongMoiId']");
        const ngayChuyenDiInput = document.querySelector("[name='NgayChuyenDi']");
        const link = document.getElementById("linkNhapChiSoPhongMoi");
        const serviceContainer = document.getElementById('dichVuPhongMoi');
        let restoreSelection = @restoreSelection.ToString().ToLowerInvariant();
        const selectedIds = new Set(@Html.Raw(selectedJson));
        const baseUrl = "@Url.Action("NhapTheoPhong", "ChiSo")";
        const serviceUrl = "@Url.Action("DichVuTheoPhong", "HopDong")";
        const hopDongCuId = "@Model.HopDongCuId";

        const syncLink = () => {
            const phongId = phongSelect?.value;
            const ngayChuyenDi = ngayChuyenDiInput?.value;

            if (!phongId || !ngayChuyenDi) {
                link.href = "#";
                link.classList.add("disabled");
                link.setAttribute("aria-disabled", "true");
                return;
            }

            const date = new Date(`${ngayChuyenDi}T00:00:00`);
            const thang = date.getMonth() + 1;
            const nam = date.getFullYear();
            const params = new URLSearchParams({
                phongId,
                thang,
                nam,
                returnHopDongId: hopDongCuId
            });

            link.href = `${baseUrl}?${params.toString()}`;
            link.classList.remove("disabled");
            link.removeAttribute("aria-disabled");
        };

        const loadServices = async () => {
            const phongId = phongSelect?.value;
            if (!phongId) {
                serviceContainer.innerHTML = '<p class="text-muted small mb-0">Chọn phòng mới để tải dịch vụ.</p>';
                return;
            }
            const response = await fetch(`${serviceUrl}?phongId=${encodeURIComponent(phongId)}`);
            if (!response.ok) {
                serviceContainer.innerHTML = '<p class="text-danger small mb-0">Không tải được dịch vụ.</p>';
                return;
            }
            const rows = await response.json();
            serviceContainer.innerHTML = rows.map(item => {
                const checked = item.batBuoc || !restoreSelection || selectedIds.has(item.id);
                const lock = item.batBuoc ? 'onclick="return false"' : '';
                const badge = item.batBuoc ? '<span class="badge bg-danger ms-1">Bắt buộc</span>' : '';
                return `<div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" name="PhongDichVuIds"
                           value="${item.id}" id="pdv_${item.id}" ${checked ? 'checked' : ''} ${lock}>
                    <label class="form-check-label" for="pdv_${item.id}">
                        ${item.tenDichVu} ${badge}
                        <span class="text-muted small">— ${Number(item.donGia || 0).toLocaleString('vi-VN')} đ</span>
                    </label>
                </div>`;
            }).join('') || '<p class="text-warning small mb-0">Phòng chưa cấu hình dịch vụ.</p>';
        };

        phongSelect?.addEventListener("change", () => {
            selectedIds.clear();
            restoreSelection = false;
            syncLink();
            loadServices();
        });
        ngayChuyenDiInput?.addEventListener("change", syncLink);
        syncLink();
        loadServices();
    })();
</script>
