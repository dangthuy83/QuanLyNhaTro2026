@model QuanLyNhaTro.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0">Tổng quan — tháng @Model.Thang/@Model.Nam</h5>
    <a asp-controller="HoaDon" asp-action="Index"
       asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam"
       class="btn btn-sm btn-outline-primary">
        <i class="bi bi-receipt me-1"></i>Xem hóa đơn kỳ này
    </a>
</div>

<!-- KPI: Phòng -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-primary">@Model.TongSoPhong</div>
                <div class="text-muted small">Tổng số phòng</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-success">@Model.SoPhongDangThue</div>
                <div class="text-muted small">Đang thuê</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-secondary">@Model.SoPhongTrong</div>
                <div class="text-muted small">Đang trống</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-warning">@Model.SoPhongDangSuaChua</div>
                <div class="text-muted small">Đang sửa chữa</div>
            </div>
        </div>
    </div>
</div>

<!-- KPI: Thu tiền -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body py-3">
                <div class="text-muted small mb-1">Phải thu tháng này</div>
                <div class="fs-5 fw-bold">@Model.TongPhaiThu.ToString("N0") đ</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body py-3">
                <div class="text-muted small mb-1">Đã thu</div>
                <div class="fs-5 fw-bold text-success">@Model.TongDaThu.ToString("N0") đ</div>
                @{
                    var pct = Model.TongPhaiThu > 0
                        ? (int)Math.Round(Model.TongDaThu / Model.TongPhaiThu * 100) : 0;
                }
                <div class="progress mt-1" style="height:4px">
                    <div class="progress-bar bg-success" style="width:@pct%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body py-3">
                <div class="text-muted small mb-1">Còn lại chưa thu</div>
                <div class="fs-5 fw-bold @(Model.TongConLai > 0 ? "text-danger" : "text-success")">
                    @Model.TongConLai.ToString("N0") đ
                </div>
                <div class="text-muted small">@Model.SoHoaDonChuaThu hóa đơn chưa đủ</div>
            </div>
        </div>
    </div>
</div>

<!-- Chi tiết -->
<div class="row g-3">
    <!-- Hóa đơn chưa thu -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                <span class="fw-semibold">Chưa thu / thu một phần</span>
                <span class="badge bg-danger rounded-pill">@Model.HoaDonChuaThu.Count</span>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.HoaDonChuaThu.Any())
                {
                    @foreach (var hd in Model.HoaDonChuaThu.Take(10))
                    {
                        var conLai = hd.TongCong - hd.SoTienDaThu;
                        <a asp-controller="HoaDon" asp-action="Details" asp-route-id="@hd.Id"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                            <div>
                                <span class="fw-semibold">@hd.HopDong?.Phong?.TenPhong</span>
                                @if (hd.TrangThaiThanhToan == "ThuMotPhan")
                                {
                                    <span class="badge bg-warning text-dark ms-1 small">Một phần</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger ms-1 small">Chưa thu</span>
                                }
                            </div>
                            <span class="text-danger fw-semibold small">@conLai.ToString("N0") đ</span>
                        </a>
                    }
                    @if (Model.HoaDonChuaThu.Count > 10)
                    {
                        <div class="list-group-item text-muted text-center small py-2">
                            +@(Model.HoaDonChuaThu.Count - 10) hóa đơn khác
                        </div>
                    }
                }
                else
                {
                    <div class="list-group-item text-muted text-center py-3">
                        <i class="bi bi-check-circle text-success me-1"></i>Đã thu đủ tháng này
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Phòng trống + Sắp hết hạn -->
    <div class="col-md-6">
        @if (Model.HopDongSapHetHan.Any())
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                    <span class="fw-semibold">Hợp đồng sắp hết hạn</span>
                    <span class="badge bg-warning text-dark rounded-pill">@Model.HopDongSapHetHan.Count</span>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var hopDong in Model.HopDongSapHetHan)
                    {
                        var soNgay = (hopDong.NgayKetThuc!.Value - DateTime.Today).Days;
                        <a asp-controller="HopDong" asp-action="Details" asp-route-id="@hopDong.Id"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                            <span class="fw-semibold">@hopDong.Phong?.TenPhong</span>
                            <span class="text-warning small">còn @soNgay ngày (@hopDong.NgayKetThuc.Value.ToString("dd/MM"))</span>
                        </a>
                    }
                </div>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                <span class="fw-semibold">Phòng đang trống</span>
                <span class="badge bg-secondary rounded-pill">@Model.PhongTrong.Count</span>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.PhongTrong.Any())
                {
                    @foreach (var p in Model.PhongTrong)
                    {
                        <a asp-controller="HopDong" asp-action="Create" asp-route-phongId="@p.Id"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                            <span>@p.TenPhong</span>
                            <span class="text-muted small">
                                @p.GiaThueMacDinh.ToString("N0") đ
                                <i class="bi bi-plus-circle ms-1 text-primary"></i>
                            </span>
                        </a>
                    }
                }
                else
                {
                    <div class="list-group-item text-muted text-center py-3">Không có phòng trống</div>
                }
            </div>
        </div>
    </div>
</div>
