@model QuanLyNhaTro.Models.GiaoDichCocViewModel
@{
    ViewData["Title"] = "Ledger cọc";
    string FormatDelta(decimal value) => value >= 0 ? $"+{value:N0}" : value.ToString("N0");
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-controller="HopDong" asp-action="Details" asp-route-id="@Model.HopDong.Id"
       class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Ledger cọc - @Model.HopDong.Phong?.TenPhong</h5>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.CanXuLyChenhLechCoc)
{
    var chenhLech = Model.ChenhLechCoc;
    <div class="alert alert-warning shadow-sm">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <div class="fw-semibold mb-1">Chênh lệch cọc chuyển phòng chưa xử lý</div>
                <div class="small">
                    Cọc thỏa thuận: <strong>@Model.HopDong.TienCoc.ToString("N0") đ</strong>
                    <span class="mx-2">|</span>
                    Số dư đang giữ: <strong>@Model.SoDuCoc.ToString("N0") đ</strong>
                    <span class="mx-2">|</span>
                    Chênh lệch:
                    <strong class="@(chenhLech > 0 ? "text-success" : "text-danger")">
                        @FormatDelta(chenhLech) đ
                    </strong>
                </div>
                <div class="small text-muted mt-1">
                    @(chenhLech > 0
                        ? "Cần thu thêm cọc để khớp hợp đồng mới."
                        : chenhLech < 0
                            ? "Cần hoàn lại cọc để khớp hợp đồng mới."
                            : "Số dư đã khớp, chỉ cần đánh dấu hoàn tất.")
                </div>
            </div>
            <form asp-action="XuLyChenhLech" method="post" class="d-flex flex-wrap align-items-end gap-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="hopDongId" value="@Model.HopDong.Id" />
                <div>
                    <label class="form-label small mb-1">Ngày giao dịch</label>
                    <input name="ngayGiaoDich" type="date" class="form-control form-control-sm"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div>
                    <label class="form-label small mb-1">Ghi chú</label>
                    <input name="ghiChu" class="form-control form-control-sm"
                           value="Xử lý chênh lệch cọc chuyển phòng" />
                </div>
                <button class="btn btn-warning btn-sm">
                    Xử lý chênh lệch
                </button>
            </form>
        </div>
    </div>
}
else if (Model.LaHopDongChuyenPhong)
{
    <div class="alert alert-success py-2">
        Chênh lệch cọc chuyển phòng đã được xử lý.
    </div>
}

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="card-title text-muted mb-0">Lịch sử giao dịch</h6>
                    <span class="badge bg-primary fs-6">Số dư: @Model.SoDuCoc.ToString("N0") đ</span>
                </div>

                @if (Model.GiaoDich.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Ngày</th>
                                    <th>Loại</th>
                                    <th class="text-end">Phát sinh</th>
                                    <th class="text-end">Số dư sau</th>
                                    <th>Hóa đơn</th>
                                    <th>Ghi chú</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var gd in Model.GiaoDich)
                                {
                                    <tr>
                                        <td>@gd.NgayGiaoDich.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge bg-light text-dark border">@LoaiGiaoDichHienThi(gd.LoaiGiaoDich)</span></td>
                                        <td class="text-end fw-semibold @(gd.SoTien >= 0 ? "text-success" : "text-danger")">
                                            @FormatDelta(gd.SoTien)
                                        </td>
                                        <td class="text-end">@gd.SoDuSauGiaoDich.ToString("N0")</td>
                                        <td>
                                            @if (gd.HoaDonId.HasValue)
                                            {
                                                <a asp-controller="HoaDon" asp-action="Details" asp-route-id="@gd.HoaDonId">#@gd.HoaDonId</a>
                                            }
                                        </td>
                                        <td>@gd.GhiChu</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có giao dịch cọc. Số dư đang lấy từ HopDong.TienCoc.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Ghi nhận giao dịch</h6>
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="hopDongId" value="@Model.HopDong.Id" />

                    <div class="mb-3">
                        <label class="form-label">Loại giao dịch</label>
                        <select name="loaiGiaoDich" class="form-select">
                            <option value="ThuThemCoc">Thu thêm cọc</option>
                            <option value="HoanCoc">Hoàn cọc</option>
                            <option value="TruNo">Trừ nợ</option>
                            <option value="DieuChinh">Điều chỉnh</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số tiền</label>
                        <input name="soTien" type="number" step="10000" class="form-control" required />
                        <div class="form-text">Điều chỉnh cho phép nhập số âm nếu cần giảm số dư.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ngày giao dịch</label>
                        <input name="ngayGiaoDich" type="date" class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hóa đơn liên quan</label>
                        <input name="hoaDonId" type="number" min="1" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ghi chú</label>
                        <input name="ghiChu" class="form-control" />
                    </div>
                    <button class="btn btn-primary w-100">Lưu giao dịch</button>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string LoaiGiaoDichHienThi(string? loaiGiaoDich) => loaiGiaoDich switch
    {
        "ThuThemCoc" => "Thu thêm cọc",
        "HoanCoc" => "Hoàn cọc",
        "TruNo" => "Trừ nợ",
        "DieuChinh" => "Điều chỉnh",
        _ => loaiGiaoDich ?? string.Empty
    };
}
