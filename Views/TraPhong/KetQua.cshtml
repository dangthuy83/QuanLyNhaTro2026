@model QuanLyNhaTro.Models.KetQuaTraPhongViewModel
@{ ViewData["Title"] = "Trả phòng thành công"; }

<div class="lifecycle-page lifecycle-result-page">
    <header class="lifecycle-result-header">
        <span class="lifecycle-success-mark" aria-hidden="true">✓</span>
        <span class="app-page-eyebrow">Đã hoàn tất</span>
        <h1>Trả phòng thành công</h1>
        <p>@Model.TenKhachChinh · @Model.TenPhong · @Model.NgayTraPhong.ToString("dd/MM/yyyy")</p>
    </header>

    <section class="app-panel lifecycle-result-panel" aria-labelledby="result-title">
        <div class="app-panel-header"><h2 id="result-title">Kết quả quyết toán</h2></div>
        <div class="app-panel-body">
            <dl class="lifecycle-settlement-list">
                <div><dt>Tiền cọc</dt><dd>@Model.TienCoc.ToString("N0") đ</dd></div>
                <div><dt>Tổng nợ còn lại</dt><dd>@Model.TongNoConLai.ToString("N0") đ</dd></div>
                @if (Model.TongTienPhatSinhConLai > 0)
                {
                    <div><dt>Phát sinh còn lại</dt><dd>@Model.TongTienPhatSinhConLai.ToString("N0") đ</dd></div>
                }
                <div class="lifecycle-settlement-total">
                    <dt>@(Model.KhachConNoThem > 0 ? "Khách còn nợ thêm" : "Hoàn cọc cho khách")</dt>
                    <dd>@((Model.KhachConNoThem > 0 ? Model.KhachConNoThem : Model.TienHoanCoc).ToString("N0")) đ</dd>
                </div>
            </dl>
            @if (Model.CoNoTon)
            {
                <div class="app-notice app-notice-warning" role="alert">Còn nợ tồn. Theo dõi tại <a asp-controller="BaoCao" asp-action="CongNo">Báo cáo công nợ</a>.</div>
            }
            @if (Model.HoaDonCuoiId.HasValue)
            {
                <div class="app-notice app-notice-info" role="status">Đã sinh hóa đơn tháng cuối <a asp-controller="HoaDon" asp-action="Details" asp-route-id="@Model.HoaDonCuoiId">#@Model.HoaDonCuoiId</a>.</div>
            }
        </div>
        <div class="lifecycle-result-actions">
            <a asp-controller="ChiSoNgoaiHopDong" asp-action="Index" asp-route-phongId="@Model.PhongId" class="btn btn-warning">Ghi chỉ số ngoài hợp đồng</a>
            <a asp-controller="Phong" asp-action="Index" class="btn btn-primary">Danh sách phòng</a>
            <a asp-controller="BaoCao" asp-action="CongNo" class="btn btn-outline-secondary">Xem công nợ</a>
        </div>
    </section>
</div>
