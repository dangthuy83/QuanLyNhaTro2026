@model QuanLyNhaTro.Models.TraPhongViewModel
@{ ViewData["Title"] = "Xác nhận trả phòng"; }

<div class="lifecycle-page lifecycle-checkout-page" data-lifecycle="checkout">
    <header class="app-page-header">
        <div>
            <span class="app-page-eyebrow">Kết thúc hợp đồng</span>
            <h1>Trả phòng @Model.TenPhong</h1>
            <p>Khách chính: <strong>@Model.TenKhachChinh</strong>. Preview dưới đây lấy nguyên từ service trả phòng.</p>
        </div>
        <a asp-controller="HopDong" asp-action="Details" asp-route-id="@Model.HopDongId" class="btn btn-outline-secondary">Về hợp đồng</a>
    </header>

    <div class="lifecycle-checkout-grid">
        <aside class="app-panel lifecycle-date-panel">
            <div class="app-panel-header"><h2>Ngày trả phòng</h2></div>
            <div class="app-panel-body">
                <form method="get" asp-action="Confirm" data-auto-submit="date-change">
                    <input type="hidden" name="hopDongId" value="@Model.HopDongId" />
                    <label class="form-label" for="ngayTraPhong">Ngày bàn giao</label>
                    <input id="ngayTraPhong" type="date" name="ngayTraPhong" class="form-control"
                           value="@Model.NgayTraPhong.ToString("yyyy-MM-dd")" />
                    <p class="form-text">Đổi ngày để server cập nhật lại preview.</p>
                    <button class="btn btn-outline-primary w-100">Cập nhật preview</button>
                </form>
            </div>
        </aside>

        <section class="app-panel lifecycle-settlement-panel" aria-labelledby="settlement-title">
            <div class="app-panel-header">
                <div><h2 id="settlement-title">Quyết toán cuối</h2><p>Số liệu và quyền thực hiện do service cung cấp.</p></div>
            </div>
            <div class="app-panel-body">
                @if (!Model.CoTheTraPhong)
                {
                    <div class="app-notice app-notice-danger" role="alert">
                        <strong>Chưa thể trả phòng.</strong> @Model.LyDoChanTraPhong
                        @if (Model.HoaDonKyTraPhongId.HasValue)
                        {
                            <a asp-controller="HoaDon" asp-action="Details" asp-route-id="@Model.HoaDonKyTraPhongId.Value">Mở hóa đơn #@Model.HoaDonKyTraPhongId.Value</a>
                        }
                    </div>
                }
                else if (Model.CanSinhHoaDonMoi)
                {
                    <div class="app-notice app-notice-warning" role="status">Sẽ sinh hóa đơn kỳ cuối tính <strong>@Model.SoNgayO / @Model.SoNgayTrongThang ngày</strong>.</div>
                }
                else
                {
                    <div class="app-notice app-notice-info" role="status">Hóa đơn kỳ trả phòng hiện hữu đã khớp số ngày ở; không sinh hóa đơn mới.</div>
                }

                <dl class="lifecycle-settlement-list">
                    @if (Model.CanSinhHoaDonMoi)
                    {
                        <div><dt>Tiền phòng tháng cuối</dt><dd>@Model.TienPhongProRata.ToString("N0") đ</dd></div>
                        <div><dt>Dịch vụ tháng cuối</dt><dd>@Model.TongTienDichVuThangCuoi.ToString("N0") đ</dd></div>
                    }
                    @if (Model.TongTienPhatSinhChuaXuLy > 0)
                    {
                        <div><dt>Phát sinh chưa xử lý</dt><dd>@Model.TongTienPhatSinhChuaXuLy.ToString("N0") đ</dd></div>
                    }
                    <div><dt>Tổng nợ còn lại</dt><dd>@Model.TongNoConLai.ToString("N0") đ</dd></div>
                    @if (Model.TienTruNoTuCoc > 0)
                    {
                        <div><dt>Trừ nợ vào cọc</dt><dd>@Model.TienTruNoTuCoc.ToString("N0") đ</dd></div>
                    }
                    <div><dt>Tiền cọc</dt><dd>@Model.TienCoc.ToString("N0") đ</dd></div>
                    <div class="lifecycle-settlement-total">
                        <dt>@(Model.KhachConNoThem > 0 ? "Khách còn nợ thêm" : "Hoàn cọc cho khách")</dt>
                        <dd>@((Model.KhachConNoThem > 0 ? Model.KhachConNoThem : Model.TienHoanCoc).ToString("N0")) đ</dd>
                    </div>
                </dl>

                <form asp-action="Execute" method="post" data-confirm="Xác nhận trả phòng ngày @Model.NgayTraPhong.ToString("dd/MM/yyyy")? Thao tác không thể hoàn tác.">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="hopDongId" value="@Model.HopDongId" />
                    <input type="hidden" name="ngayTraPhong" value="@Model.NgayTraPhong.ToString("yyyy-MM-dd")" />
                    <label class="form-label" for="ghiChu">Ghi chú (tùy chọn)</label>
                    <input id="ghiChu" name="ghiChu" class="form-control" placeholder="Ví dụ: thỏa thuận hoàn cọc" />
                    <div class="lifecycle-form-actions">
                        <a asp-controller="HopDong" asp-action="Details" asp-route-id="@Model.HopDongId" class="btn btn-outline-secondary">Hủy</a>
                        @if (Model.CoTheTraPhong)
                        {
                            <button class="btn btn-danger">Xác nhận trả phòng</button>
                        }
                        else
                        {
                            <button class="btn btn-danger" type="button" disabled>Chưa thể trả phòng</button>
                        }
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

@section Scripts { <script src="~/js/lifecycle.js" asp-append-version="true"></script> }
