@model IEnumerable<QuanLyNhaTro.Models.ChiSoNgoaiHopDong>
@{
    ViewData["Title"] = "Chỉ số ngoài hợp đồng";
    ViewData["ActiveMenu"] = "chiso-ngoai";
    var rooms = ViewBag.DanhSachPhong as IEnumerable<QuanLyNhaTro.Models.Phong> ?? [];
    var services = ViewBag.DichVuTheoChiSo as IEnumerable<QuanLyNhaTro.Models.DichVu> ?? [];
    int? selectedRoom = ViewBag.PhongId as int?;
    int? selectedService = ViewBag.DichVuId as int?;
    decimal? suggestedStart = ViewBag.GoiYTuChiSo as decimal?;
    string? suggestedSource = ViewBag.NguonGoiYTuChiSo as string;
    var rows = Model.ToList();
    var inv = System.Globalization.CultureInfo.InvariantCulture;
}

<div class="meters-page meters-offcontract-page" data-meter-offcontract>
    <header class="app-page-header">
        <div class="app-page-heading"><h1>Chỉ số ngoài hợp đồng</h1><p class="app-page-subtitle">Ghi nhận mốc điện nước khi phòng trống, sửa chữa hoặc chủ nhà sử dụng mà không tính vào hóa đơn khách thuê.</p></div>
        <div class="app-page-actions"><a asp-controller="ChiSo" asp-action="Index" class="btn btn-outline-secondary"><svg class="app-icon" aria-hidden="true"><use href="#icon-meter"></use></svg>Chỉ số theo kỳ</a></div>
    </header>

    @if (TempData["Success"] != null) { <div class="app-notice is-success" role="status"><svg class="app-icon" aria-hidden="true"><use href="#icon-check"></use></svg><div><strong>Đã cập nhật chuỗi</strong><p>@TempData["Success"]</p></div></div> }
    @if (TempData["Error"] != null) { <div class="app-notice is-danger" role="alert"><svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg><div><strong>Không thể thay đổi</strong><p>@TempData["Error"]</p></div></div> }

    <div class="meters-offcontract-layout">
        <section class="app-panel meters-offcontract-create" aria-labelledby="offcontract-create-heading">
            <div class="app-panel-header"><div><h2 id="offcontract-create-heading">Ghi một mốc mới</h2><p>Mốc cuối có thể trở thành mốc đầu của hợp đồng hoặc kỳ sau.</p></div></div>
            <div class="app-panel-body">
                <form asp-action="Create" method="post" data-meter-row>
                    @Html.AntiForgeryToken()
                    <div class="meters-offcontract-fields">
                        <div class="app-field"><label for="off-room">Phòng <span aria-hidden="true">*</span></label><select id="off-room" name="PhongId" class="form-select" required><option value="">Chọn phòng</option>@foreach (var room in rooms) { <option value="@room.Id" selected="@(selectedRoom == room.Id)">@room.Nha?.TenNha · @room.TenPhong</option> }</select></div>
                        <div class="app-field"><label for="off-service">Dịch vụ <span aria-hidden="true">*</span></label><select id="off-service" name="DichVuId" class="form-select" required><option value="">Chọn dịch vụ</option>@foreach (var service in services) { <option value="@service.Id" selected="@(selectedService == service.Id)">@service.TenDichVu</option> }</select></div>
                        <div class="app-field"><label for="off-type">Loại ghi nhận</label><select id="off-type" name="LoaiGhiNhan" class="form-select" data-meter-type><option value="BinhThuong">Bình thường</option><option value="Reset">Reset / thay đồng hồ</option></select></div>
                        <div class="app-field"><label for="off-date">Ngày ghi nhận</label><input id="off-date" name="NgayGhiNhan" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required /></div>
                        <div class="app-field"><label for="off-start">Từ số</label><input id="off-start" name="TuChiSo" type="number" step="0.01" min="0" class="form-control meters-reading-input" value="@suggestedStart?.ToString(inv)" data-start-input required />@if (!string.IsNullOrWhiteSpace(suggestedSource)) { <small>Nguồn gợi ý: @suggestedSource</small> }</div>
                        <div class="app-field"><label for="off-end">Đến số</label><input id="off-end" name="DenChiSo" type="number" step="0.01" min="0" class="form-control meters-reading-input" data-meter-end-input required /></div>
                        <div class="meters-reset-panel d-none" data-reset-fields><div class="meters-reset-heading"><svg class="app-icon" aria-hidden="true"><use href="#icon-refresh"></use></svg><div><strong>Thông tin reset</strong><p>Hai mốc trước/sau reset là bắt buộc để nối đúng chuỗi.</p></div></div><div class="meters-reset-fields"><div class="app-field"><label>Chỉ số trước reset</label><input name="ChiSoTruocReset" type="number" step="0.01" min="0" class="form-control" /></div><div class="app-field"><label>Chỉ số sau reset</label><input name="ChiSoSauReset" type="number" step="0.01" min="0" class="form-control" placeholder="0" /></div><div class="app-field meters-reason-field"><label>Lý do điều chỉnh</label><input name="LyDoDieuChinh" maxlength="255" class="form-control" placeholder="Ví dụ: thay đồng hồ hỏng" /></div></div></div>
                        <div class="app-field meters-reason-field"><label for="off-reason">Lý do sử dụng ngoài hợp đồng <span aria-hidden="true">*</span></label><input id="off-reason" name="LyDo" maxlength="255" class="form-control" placeholder="Sửa phòng, phòng trống…" required /></div>
                        <div class="app-field meters-reason-field"><label for="off-note">Ghi chú</label><textarea id="off-note" name="GhiChu" maxlength="1000" class="form-control" rows="3" placeholder="Thông tin bổ sung nếu cần"></textarea></div>
                    </div>
                    <div class="meters-consumption-preview" aria-live="polite"><span>Sản lượng dự kiến</span><strong data-meter-consumption>0,00</strong><small>server sẽ kiểm tra chuỗi và tính lại</small></div>
                    <button type="submit" class="btn btn-primary meters-create-submit"><svg class="app-icon" aria-hidden="true"><use href="#icon-save"></use></svg>Lưu mốc ngoài hợp đồng</button>
                </form>
            </div>
        </section>

        <aside class="app-notice is-warning meters-chain-notice"><svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg><div><strong>Đây là một mắt xích của chuỗi đồng hồ</strong><p>Mỗi dòng phải nối đúng mốc gần nhất và không trùng ngày của cùng phòng/dịch vụ. Xóa một mốc đã được dữ liệu sau tham chiếu sẽ bị server chặn.</p></div></aside>
    </div>

    <section class="app-panel meters-history-panel" aria-labelledby="offcontract-history-heading">
        <div class="app-panel-header"><div><h2 id="offcontract-history-heading">Lịch sử mốc ngoài hợp đồng</h2><p>Rà theo nhà, phòng, dịch vụ và thứ tự ngày trước khi xóa.</p></div><span class="meters-result-count">@rows.Count mốc</span></div>
        <div class="app-panel-body meters-history-filters"><form method="get"><div class="app-field"><label for="history-room">Phòng</label><select id="history-room" name="phongId" class="form-select"><option value="">Tất cả phòng</option>@foreach (var room in rooms) { <option value="@room.Id" selected="@(selectedRoom == room.Id)">@room.Nha?.TenNha · @room.TenPhong</option> }</select></div><div class="app-field"><label for="history-service">Dịch vụ</label><select id="history-service" name="dichVuId" class="form-select"><option value="">Tất cả dịch vụ</option>@foreach (var service in services) { <option value="@service.Id" selected="@(selectedService == service.Id)">@service.TenDichVu</option> }</select></div><button class="btn btn-outline-primary">Lọc lịch sử</button><a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a></form></div>
        @if (!rows.Any()) { <div class="app-empty-state"><svg class="app-icon" aria-hidden="true"><use href="#icon-tools"></use></svg><h3>Chưa có mốc ngoài hợp đồng</h3><p>Dùng biểu mẫu phía trên khi phát sinh tiêu thụ không thuộc hợp đồng.</p></div> }
        else
        {
            <div class="meters-table-wrap"><table class="meters-table meters-history-table"><thead><tr><th>Nhà / phòng</th><th>Dịch vụ</th><th>Chuỗi chỉ số</th><th>Ghi nhận</th><th>Lý do</th><th><span class="visually-hidden">Xóa</span></th></tr></thead><tbody>@foreach (var row in rows) { <tr><td data-label="Nhà / phòng"><strong>@row.Phong?.TenPhong</strong><span>@row.TenNha</span></td><td data-label="Dịch vụ"><strong>@row.DichVu?.TenDichVu</strong><small>@row.DichVu?.DonViTinh</small></td><td data-label="Chuỗi chỉ số"><span class="meters-chain-reading"><strong>@row.TuChiSo.ToString("N2")</strong><svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg><strong>@row.DenChiSo.ToString("N2")</strong></span><small>Sản lượng @row.SanLuong.ToString("N2")</small>@if (row.LaReset) { <span class="app-status-badge is-warning">Reset @row.ChiSoTruocReset?.ToString("N2") → @row.ChiSoSauReset?.ToString("N2")</span> }</td><td data-label="Ghi nhận"><strong>@row.NgayGhiNhan.ToString("dd/MM/yyyy")</strong><small>@(row.LaReset ? row.LyDoDieuChinh : "Bình thường")</small></td><td data-label="Lý do"><strong>@row.LyDo</strong>@if (!string.IsNullOrWhiteSpace(row.GhiChu)) { <small>@row.GhiChu</small> }</td><td class="meters-row-action"><form asp-action="Delete" method="post" data-meter-delete-form data-meter-delete-label="@row.Phong?.TenPhong · @row.DichVu?.TenDichVu · @row.NgayGhiNhan.ToString("dd/MM/yyyy")">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@row.Id" /><button class="btn btn-outline-danger" type="submit" aria-label="Xóa mốc @row.Id"><svg class="app-icon" aria-hidden="true"><use href="#icon-trash"></use></svg>Xóa</button></form></td></tr> }</tbody></table></div>
        }
    </section>
</div>

@section Scripts { <script src="~/js/meters.js" asp-append-version="true"></script> }
