@model IEnumerable<QuanLyNhaTro.Models.ChiSoNgoaiHopDong>
@{
    ViewData["Title"] = "Chỉ số ngoài hợp đồng";
    ViewData["ActiveMenu"] = "chiso-ngoai";
    var phongId = ViewBag.PhongId as int?;
    var dichVuId = ViewBag.DichVuId as int?;
    var danhSachPhong = ViewBag.DanhSachPhong as List<QuanLyNhaTro.Models.Phong> ?? [];
    var dichVuTheoChiSo = ViewBag.DichVuTheoChiSo as List<QuanLyNhaTro.Models.DichVu> ?? [];
    decimal? goiYTuChiSo = ViewBag.GoiYTuChiSo as decimal?;
    var inv = System.Globalization.CultureInfo.InvariantCulture;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h5 class="mb-1">Chỉ số ngoài hợp đồng</h5>
        <div class="text-muted small">Ghi nhận điện/nước phát sinh khi phòng trống, sửa phòng hoặc chủ nhà sử dụng, không tính vào hóa đơn khách thuê.</div>
    </div>
    <a asp-controller="ChiSo" asp-action="Index" class="btn btn-sm btn-outline-secondary">Chỉ số theo kỳ</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Create" method="post" class="border rounded p-3 mb-3">
    @Html.AntiForgeryToken()
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Phòng <span class="text-danger">*</span></label>
            <select name="PhongId" class="form-select form-select-sm" required>
                <option value="">Chọn phòng</option>
                @foreach (var phong in danhSachPhong)
                {
                    <option value="@phong.Id" selected="@(phongId == phong.Id)">
                        @(phong.Nha?.TenNha != null ? $"{phong.Nha.TenNha} - " : "")@phong.TenPhong
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Dịch vụ <span class="text-danger">*</span></label>
            <select name="DichVuId" class="form-select form-select-sm" required>
                <option value="">Chọn dịch vụ</option>
                @foreach (var dichVu in dichVuTheoChiSo)
                {
                    <option value="@dichVu.Id" selected="@(dichVuId == dichVu.Id)">@dichVu.TenDichVu</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-1">
            <label class="form-label small text-muted mb-1">Từ số</label>
            <input name="TuChiSo" type="number" step="0.01" min="0" class="form-control form-control-sm"
                   value="@(goiYTuChiSo?.ToString(inv) ?? "")" required />
            @if (goiYTuChiSo.HasValue)
            {
                <div class="form-text">Gợi ý từ mốc gần nhất.</div>
            }
        </div>
        <div class="col-6 col-md-1">
            <label class="form-label small text-muted mb-1">Đến số</label>
            <input name="DenChiSo" type="number" step="0.01" min="0" class="form-control form-control-sm" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Ngày ghi nhận</label>
            <input name="NgayGhiNhan" type="date" class="form-control form-control-sm"
                   value="@DateTime.Today.ToString("yyyy-MM-dd", inv)" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Lý do <span class="text-danger">*</span></label>
            <input name="LyDo" class="form-control form-control-sm" maxlength="255"
                   placeholder="Sửa phòng, phòng trống..." required />
        </div>
        <div class="col-md-1">
            <button class="btn btn-sm btn-primary w-100">Lưu</button>
        </div>
        <div class="col-12">
            <input name="GhiChu" class="form-control form-control-sm" maxlength="255"
                   placeholder="Ghi chú thêm nếu cần" />
        </div>
    </div>
</form>

<form method="get" class="d-flex gap-2 align-items-center mb-2 flex-wrap">
    <select name="phongId" class="form-select form-select-sm" style="max-width:260px">
        <option value="">Tất cả phòng</option>
        @foreach (var phong in danhSachPhong)
        {
            <option value="@phong.Id" selected="@(phongId == phong.Id)">
                @(phong.Nha?.TenNha != null ? $"{phong.Nha.TenNha} - " : "")@phong.TenPhong
            </option>
        }
    </select>
    <select name="dichVuId" class="form-select form-select-sm" style="max-width:180px">
        <option value="">Tất cả dịch vụ</option>
        @foreach (var dichVu in dichVuTheoChiSo)
        {
            <option value="@dichVu.Id" selected="@(dichVuId == dichVu.Id)">@dichVu.TenDichVu</option>
        }
    </select>
    <button class="btn btn-sm btn-outline-primary">Lọc</button>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Xóa lọc</a>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Phòng</th>
                    <th>Dịch vụ</th>
                    <th class="text-end">Từ số</th>
                    <th class="text-end">Đến số</th>
                    <th class="text-end">Sản lượng</th>
                    <th>Ngày</th>
                    <th>Lý do</th>
                    <th>Ghi chú</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Phong?.TenPhong</td>
                        <td>@item.DichVu?.TenDichVu</td>
                        <td class="text-end">@item.TuChiSo.ToString("N2")</td>
                        <td class="text-end">@item.DenChiSo.ToString("N2")</td>
                        <td class="text-end fw-semibold">@item.SanLuong.ToString("N2")</td>
                        <td class="text-nowrap">@item.NgayGhiNhan.ToString("dd/MM/yyyy")</td>
                        <td>@item.LyDo</td>
                        <td class="small text-muted">@item.GhiChu</td>
                        <td class="text-end">
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa dòng chỉ số ngoài hợp đồng này?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">Chưa có chỉ số ngoài hợp đồng.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
