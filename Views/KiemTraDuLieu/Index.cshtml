@model QuanLyNhaTro.Models.KiemTraDuLieuViewModel
@{
    ViewData["Title"] = "Sẵn sàng vận hành";
    ViewData["ActiveMenu"] = "kiemtra";
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h5 class="mb-1">Sẵn sàng vận hành - @Model.Thang/@Model.Nam</h5>
        <div class="text-muted small">Kiểm tra dữ liệu phòng, hợp đồng, khách, dịch vụ, đơn giá và chỉ số trước khi chốt hóa đơn.</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Phong" asp-action="GanDichVuHangLoat" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-layers"></i> Gán dịch vụ hàng loạt
        </a>
        <a asp-controller="HoaDon" asp-action="ChotHangLoat" asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam" asp-route-nhaId="@Model.NhaId"
           class="btn btn-sm btn-primary">
            <i class="bi bi-receipt"></i> Xem trước chốt hóa đơn
        </a>
    </div>
</div>

<form method="get" class="border rounded p-3 mb-3 bg-light">
    <div class="row g-2 align-items-end">
        <div class="col-6 col-md-2 col-lg-1">
            <label class="form-label small text-muted mb-1">Tháng</label>
            <select name="thang" class="form-select form-select-sm">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(m == Model.Thang)">Tháng @m</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2 col-lg-1">
            <label class="form-label small text-muted mb-1">Năm</label>
            <input name="nam" type="number" class="form-control form-control-sm" value="@Model.Nam" min="2020" max="2099" />
        </div>
        <div class="col-md-3 col-lg-2">
            <label class="form-label small text-muted mb-1">Nhà</label>
            <select name="nhaId" class="form-select form-select-sm">
                <option value="">Tất cả nhà</option>
                @foreach (var nha in Model.DanhSachNha)
                {
                    <option value="@nha.Id" selected="@(Model.NhaId == nha.Id)">@nha.TenNha</option>
                }
            </select>
        </div>
        <div class="col-md-3 col-lg-2">
            <label class="form-label small text-muted mb-1">Trạng thái</label>
            <select name="trangThaiDong" class="form-select form-select-sm">
                <option value="TatCa" selected="@(Model.TrangThaiDong == "TatCa")">Tất cả</option>
                <option value="SanSang" selected="@(Model.TrangThaiDong == "SanSang")">Sẵn sàng</option>
                <option value="CanXuLy" selected="@(Model.TrangThaiDong == "CanXuLy")">Cần xử lý</option>
                <option value="ThieuKhach" selected="@(Model.TrangThaiDong == "ThieuKhach")">Thiếu khách</option>
                <option value="ThieuDichVu" selected="@(Model.TrangThaiDong == "ThieuDichVu")">Thiếu dịch vụ</option>
                <option value="ThieuDonGia" selected="@(Model.TrangThaiDong == "ThieuDonGia")">Thiếu đơn giá</option>
                <option value="ThieuChiSo" selected="@(Model.TrangThaiDong == "ThieuChiSo")">Thiếu chỉ số</option>
                <option value="DaCoHoaDon" selected="@(Model.TrangThaiDong == "DaCoHoaDon")">Đã có hóa đơn</option>
            </select>
        </div>
        <div class="col-md-4 col-lg-4">
            <label class="form-label small text-muted mb-1">Tìm phòng/khách</label>
            <input name="tuKhoa" class="form-control form-control-sm" value="@Model.TuKhoa" placeholder="Tên nhà, phòng, khách, mã HĐ" />
        </div>
        <div class="col-md-12 col-lg-2 d-flex gap-2">
            <button class="btn btn-sm btn-primary flex-fill">Lọc</button>
            <a asp-action="Index" asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam"
               class="btn btn-sm btn-outline-secondary flex-fill">Xóa lọc</a>
        </div>
    </div>
</form>

<div class="card border-info mb-3">
    <div class="card-header bg-info bg-opacity-10 d-flex justify-content-between">
        <strong>Đối soát snapshot/ledger chỉ đọc</strong>
        <span class="badge bg-@(Model.CanhBaoDoiSoat.Count == 0 ? "success" : "warning")">@Model.CanhBaoDoiSoat.Count cảnh báo</span>
    </div>
    <div class="card-body">
        <p class="small text-muted">Khối này chỉ chạy SELECT để so sánh dữ liệu đã lưu; không có nút tự sửa và không ghi database.</p>
        @if (Model.CanhBaoDoiSoat.Count == 0)
        {
            <div class="text-success">Chưa phát hiện lệch snapshot, ledger hoặc liên kết trong dữ liệu hiện có.</div>
        }
        else
        {
            <div class="list-group list-group-flush">
            @foreach (var issue in Model.CanhBaoDoiSoat)
            {
                <div class="list-group-item px-0 d-flex justify-content-between gap-3">
                    <div><span class="badge bg-warning text-dark me-2">@issue.Loai</span><strong>@issue.DoiTuong #@issue.DoiTuongId</strong><div class="small text-muted">@issue.LyDo</div></div>
                    @if (!string.IsNullOrEmpty(issue.LinkController)) { <a asp-controller="@issue.LinkController" asp-action="@issue.LinkAction" asp-route-id="@issue.DoiTuongId" class="btn btn-sm btn-outline-primary align-self-center">Xử lý</a> }
                </div>
            }
            </div>
        }
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3 col-xl-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Dòng theo bộ lọc</div>
            <div class="fs-5 fw-semibold">@Model.Rows.Count</div>
        </div>
    </div>
    <div class="col-md-3 col-xl-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Sẵn sàng</div>
            <div class="fs-5 fw-semibold text-success">@Model.SoDongSanSang</div>
        </div>
    </div>
    <div class="col-md-3 col-xl-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Cần xử lý</div>
            <div class="fs-5 fw-semibold text-warning">@Model.SoDongCanXuLy</div>
        </div>
    </div>
    <div class="col-md-3 col-xl-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Thiếu khách</div>
            <div class="fs-5 fw-semibold text-danger">@Model.SoDongThieuKhach</div>
        </div>
    </div>
    <div class="col-md-3 col-xl-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Thiếu đơn giá</div>
            <div class="fs-5 fw-semibold text-danger">@Model.SoDongThieuDonGia</div>
        </div>
    </div>
    <div class="col-md-3 col-xl-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Thiếu chỉ số</div>
            <div class="fs-5 fw-semibold text-danger">@Model.SoDongThieuChiSo</div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nhà / phòng / hợp đồng</th>
                    <th>Khách</th>
                    <th>Dịch vụ</th>
                    <th>Chỉ số kỳ @Model.Thang/@Model.Nam</th>
                    <th class="text-end">Dự kiến</th>
                    <th>Trạng thái</th>
                    <th style="width:220px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr class="@(row.CanXuLy ? "table-warning" : "")">
                        <td>
                            <div class="text-muted small">@row.TenNha</div>
                            <a asp-controller="Phong" asp-action="Details" asp-route-id="@row.PhongId" class="fw-semibold text-decoration-none">@row.TenPhong</a>
                            <div class="small text-muted">
                                HĐ #@row.HopDongId - từ @row.NgayBatDau.ToString("dd/MM/yyyy")
                            </div>
                        </td>
                        <td>
                            @if (row.SoKhach > 0)
                            {
                                <div class="fw-semibold">@row.SoKhach khách</div>
                                <div class="small text-muted">@row.TenKhach</div>
                            }
                            else
                            {
                                <span class="badge bg-danger">Thiếu khách</span>
                            }
                            @if (row.SoDichVuTheoNguoi > 0)
                            {
                                <div class="small text-muted">Theo người: @row.DichVuTheoNguoi</div>
                            }
                        </td>
                        <td>
                            @if (row.SoDichVuDangApDung == 0)
                            {
                                <span class="badge bg-warning text-dark">Chưa gán dịch vụ</span>
                            }
                            else
                            {
                                <div>@row.SoDichVuDangApDung dịch vụ đang áp dụng</div>
                            }
                            @if (row.ThieuDonGia)
                            {
                                <div class="small text-danger">Đơn giá cần kiểm tra: @row.DichVuDonGiaKhongHopLe</div>
                            }
                        </td>
                        <td>
                            @if (row.SoDichVuTheoChiSo == 0)
                            {
                                <span class="text-muted small">Không có dịch vụ theo chỉ số</span>
                            }
                            else if (row.ThieuChiSo)
                            {
                                <span class="badge bg-danger">@row.SoChiSoTheoChiSo/@row.SoDichVuTheoChiSo đã có chỉ số</span>
                                <div class="small text-muted">@row.DichVuTheoChiSo</div>
                            }
                            else
                            {
                                <span class="badge bg-success">@row.SoChiSoTheoChiSo/@row.SoDichVuTheoChiSo đã có chỉ số</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (row.DuKien != null)
                            {
                                <div class="fw-semibold">@row.DuKien.TongCong.ToString("N0") đ</div>
                                <div class="small text-muted">DV @row.DuKien.TongTienDichVu.ToString("N0")</div>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 mb-1">
                                @if (row.SanSangVanHanh)
                                {
                                <span class="badge bg-success">Sẵn sàng</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Cần xử lý</span>
                                }
                                @if (row.DaCoHoaDon)
                                {
                                    <a asp-controller="HoaDon" asp-action="Details" asp-route-id="@row.DuKien!.HoaDonDaCo!.Id"
                                       class="badge bg-secondary text-decoration-none">Đã có hóa đơn #@row.DuKien!.HoaDonDaCo!.Id</a>
                                }
                                @if (row.CoNoKyTruoc)
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Có nợ kỳ trước</span>
                                }
                                @if (row.SanSangChot)
                                {
                                    <span class="badge bg-primary">Có thể chốt</span>
                                }
                            </div>
                            @if (row.DuKien != null)
                            {
                                foreach (var loi in row.DuKien.Loi)
                                {
                                    <div class="small text-danger">@loi</div>
                                }
                                foreach (var canhBao in row.DuKien.CanhBao)
                                {
                                    <div class="small text-muted">@canhBao</div>
                                }
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-controller="HopDong" asp-action="Details" asp-route-id="@row.HopDongId" class="btn btn-sm btn-outline-secondary">HĐ</a>
                                <a asp-controller="Phong" asp-action="GanDichVuHangLoat" asp-route-nhaId="@row.NhaId" class="btn btn-sm btn-outline-secondary">Dịch vụ</a>
                                <a asp-controller="ChiSo" asp-action="Nhap" asp-route-hopDongId="@row.HopDongId" asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam" class="btn btn-sm btn-outline-secondary">Chỉ số</a>
                                <a asp-controller="HoaDon" asp-action="ChotHangLoat" asp-route-thang="@Model.Thang" asp-route-nam="@Model.Nam" asp-route-nhaId="@row.NhaId" asp-route-tuKhoa="@row.HopDongId" class="btn btn-sm btn-outline-primary">Xem trước</a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Rows.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Không có hợp đồng hiệu lực nào khớp bộ lọc.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
