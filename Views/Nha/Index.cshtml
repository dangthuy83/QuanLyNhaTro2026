@model IEnumerable<QuanLyNhaTro.Models.Nha>
@{ ViewData["Title"] = "Nhà trọ"; ViewData["ActiveMenu"] = "nha"; }
<div class="houses-page">
    <header class="app-page-header"><div class="app-page-heading"><h1>Nhà trọ</h1><p class="app-page-subtitle">Quản lý địa điểm và kiểm soát số phòng trước khi xóa.</p></div><div class="app-page-actions"><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#modalThemNha">Thêm nhà trọ</button></div></header>
    @if (TempData["Success"] != null) { <div class="app-notice is-success" role="status">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="app-notice is-danger" role="alert">@TempData["Error"]</div> }
    <section class="app-panel"><div class="app-panel-header"><div><h2>Danh sách địa điểm</h2><p>@Model.Count() nhà trọ đang được quản lý.</p></div></div>
    @if (!Model.Any()) { <div class="app-empty-state"><div><h3>Chưa có nhà trọ</h3><p>Thêm địa điểm đầu tiên để bắt đầu tạo phòng.</p><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#modalThemNha">Thêm nhà trọ</button></div></div> }
    else { <div class="houses-list">@foreach (var nha in Model) { <article class="houses-row"><div class="houses-main"><span class="houses-mark" aria-hidden="true"><svg class="app-icon"><use href="#icon-building"></use></svg></span><div><h3>@nha.TenNha</h3><p>@(string.IsNullOrWhiteSpace(nha.DiaChi) ? "Chưa cập nhật địa chỉ" : nha.DiaChi)</p>@if (!string.IsNullOrWhiteSpace(nha.GhiChu)) { <small>@nha.GhiChu</small> }</div></div><div class="houses-room-count"><strong>@nha.SoPhong</strong><span>phòng</span></div><div class="houses-meta"><span>Tạo ngày</span><strong>@nha.NgayTao.ToString("dd/MM/yyyy")</strong></div><div class="houses-actions"><button type="button" class="btn btn-outline-secondary btn-edit-house" data-id="@nha.Id" data-ten="@nha.TenNha" data-diachi="@nha.DiaChi" data-ghichu="@nha.GhiChu">Chỉnh sửa</button><form asp-action="Delete" asp-route-id="@nha.Id" method="post" data-confirm="Xóa nhà @nha.TenNha? Chỉ nhà không còn phòng mới xóa được.">@Html.AntiForgeryToken()<button class="btn btn-outline-danger" disabled="@(nha.SoPhong > 0)" aria-describedby="houseDeleteHint-@nha.Id">Xóa nhà</button></form>@if (nha.SoPhong > 0) { <small id="houseDeleteHint-@nha.Id">Cần chuyển hoặc xóa @nha.SoPhong phòng trước.</small> }</div></article> }</div> }
    </section>
</div>

<div class="modal fade houses-page" id="modalThemNha" tabindex="-1" aria-labelledby="createHouseTitle" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="Create" method="post">@Html.AntiForgeryToken()<div class="modal-header"><h2 class="modal-title fs-5" id="createHouseTitle">Thêm nhà trọ</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button></div><div class="modal-body houses-form"><div class="app-field"><label for="createHouseName">Tên nhà <span class="text-danger">*</span></label><input id="createHouseName" name="TenNha" class="form-control" maxlength="255" required /></div><div class="app-field"><label for="createHouseAddress">Địa chỉ</label><input id="createHouseAddress" name="DiaChi" class="form-control" maxlength="500" /></div><div class="app-field"><label for="createHouseNote">Ghi chú</label><textarea id="createHouseNote" name="GhiChu" class="form-control" rows="3"></textarea></div></div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu nhà trọ</button></div></form></div></div></div>
<div class="modal fade houses-page" id="modalSuaNha" tabindex="-1" aria-labelledby="editHouseTitle" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="Edit" method="post">@Html.AntiForgeryToken()<input type="hidden" name="Id" id="editNhaId" /><div class="modal-header"><h2 class="modal-title fs-5" id="editHouseTitle">Chỉnh sửa nhà trọ</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button></div><div class="modal-body houses-form"><div class="app-field"><label for="editTenNha">Tên nhà <span class="text-danger">*</span></label><input name="TenNha" id="editTenNha" class="form-control" maxlength="255" required /></div><div class="app-field"><label for="editDiaChi">Địa chỉ</label><input name="DiaChi" id="editDiaChi" class="form-control" maxlength="500" /></div><div class="app-field"><label for="editGhiChu">Ghi chú</label><textarea name="GhiChu" id="editGhiChu" class="form-control" rows="3"></textarea></div></div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu thay đổi</button></div></form></div></div></div>
@section Scripts { <script src="~/js/houses.js" asp-append-version="true"></script> }
