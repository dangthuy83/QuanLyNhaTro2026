@model string
@{ Layout = null; ViewData["Title"] = "Đăng nhập quản trị"; }
<!doctype html><html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Đăng nhập quản trị</title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/></head>
<body class="bg-light"><main class="container py-5"><div class="card shadow-sm mx-auto" style="max-width:420px"><div class="card-body p-4"><h4 class="mb-1">Quản lý nhà trọ</h4><p class="text-muted">Đăng nhập tài khoản quản trị duy nhất.</p>
<form method="post">@Html.AntiForgeryToken()<input type="hidden" name="returnUrl" value="@Model"/><div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
<div class="mb-3"><label class="form-label">Tên đăng nhập</label><input name="username" class="form-control" autocomplete="username" required/></div>
<div class="mb-3"><label class="form-label">Mật khẩu</label><input name="password" type="password" class="form-control" autocomplete="current-password" required/></div>
<button class="btn btn-primary w-100">Đăng nhập</button></form></div></div></main></body></html>
