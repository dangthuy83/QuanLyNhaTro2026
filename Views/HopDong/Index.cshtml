@model IEnumerable<QuanLyNhaTro.Models.HopDong>
@{
    ViewData["Title"] = "Hợp đồng";
    ViewData["ActiveMenu"] = "hopdong";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Danh sách hợp đồng</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Tạo hợp đồng
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Phòng</th>
                    <th>Ngày bắt đầu</th>
                    <th>Ngày kết thúc</th>
                    <th class="text-end">Giá thuê TT</th>
                    <th class="text-end">Tiền cọc</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hd in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@hd.Id" class="fw-semibold text-decoration-none">
                                @hd.Phong?.TenPhong
                            </a>
                        </td>
                        <td>@hd.NgayBatDau.ToString("dd/MM/yyyy")</td>
                        <td>@(hd.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Không xác định")</td>
                        <td class="text-end">@hd.TienThueThoaThuan.ToString("N0") đ</td>
                        <td class="text-end">@hd.TienCoc.ToString("N0") đ</td>
                        <td>@Html.Raw(TrangThaiBadge(hd.TrangThai))</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@hd.Id"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Chưa có hợp đồng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    static string TrangThaiBadge(string tt) => tt switch
    {
        "DangHieuLuc"    => "<span class='badge bg-success'>Đang hiệu lực</span>",
        "DaKetThuc"      => "<span class='badge bg-secondary'>Đã kết thúc</span>",
        "DaHuy"          => "<span class='badge bg-danger'>Đã huỷ</span>",
        "DaChuyenPhong"  => "<span class='badge bg-info text-dark'>Đã chuyển phòng</span>",
        _                => $"<span class='badge bg-light text-dark'>{tt}</span>"
    };
}
