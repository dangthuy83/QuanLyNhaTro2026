@model QuanLyNhaTro.Models.CapNhatDichVuHopDongViewModel
@{
    ViewData["Title"] = "Dịch vụ hợp đồng";
    ViewData["ActiveMenu"] = "hopdong";
    var selected = Model.PhongDichVuIds.ToHashSet();
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Details" asp-route-id="@Model.HopDongId" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h5 class="mb-0">Dịch vụ hợp đồng — @Model.TenPhong</h5>
</div>

<div class="card shadow-sm" style="max-width:720px">
    <div class="card-body">
        <form asp-action="DichVu" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="HopDongId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">Tháng áp dụng</label>
                    <input asp-for="ThangApDung" type="number" min="1" max="12" class="form-control" />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Năm áp dụng</label>
                    <input asp-for="NamApDung" type="number" min="2000" class="form-control" />
                </div>
            </div>

            <div class="alert alert-info py-2 small">
                Thay đổi có hiệu lực từ kỳ sử dụng đã chọn. Hóa đơn đã lập không bị thay đổi.
            </div>

            <div class="border rounded p-3 mb-3">
                @foreach (var pdv in Model.DanhSachDichVu)
                {
                    var batBuoc = pdv.DichVu?.BatBuocKhiThue == true;
                    var isChecked = batBuoc || selected.Contains(pdv.Id);
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox"
                               name="PhongDichVuIds" value="@pdv.Id" id="pdv_@pdv.Id"
                               checked="@isChecked" onclick="@(batBuoc ? "return false" : null)" />
                        <label class="form-check-label" for="pdv_@pdv.Id">
                            <strong>@pdv.DichVu?.TenDichVu</strong>
                            @if (batBuoc)
                            {
                                <span class="badge bg-danger ms-1">Bắt buộc</span>
                            }
                            @if (!pdv.DangApDung)
                            {
                                <span class="badge bg-secondary ms-1">Phòng đã ngừng cung cấp</span>
                            }
                            <span class="text-muted small ms-1">
                                @pdv.DonGia.ToString("N0") đ — @pdv.DichVu?.LoaiTinhPhiHienThi
                            </span>
                        </label>
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary">Lưu dịch vụ</button>
                <a asp-action="Details" asp-route-id="@Model.HopDongId" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>
