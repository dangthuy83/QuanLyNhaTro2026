@model QuanLyNhaTro.Models.CapNhatDichVuHopDongViewModel
@{
    ViewData["Title"] = "Dịch vụ hợp đồng";
    ViewData["ActiveMenu"] = "hopdong";
    var selected = Model.PhongDichVuIds.ToHashSet();
}

<div class="contracts-page contracts-service-page">
    <a asp-action="Details" asp-route-id="@Model.HopDongId" class="contracts-back-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Chi tiết hợp đồng</a>
    <header class="app-page-header">
        <div class="app-page-heading">
            <h1>Dịch vụ hợp đồng — @Model.TenPhong</h1>
            <p class="app-page-subtitle">Chọn dịch vụ có hiệu lực từ kỳ sử dụng mới; hóa đơn đã lập giữ nguyên snapshot.</p>
        </div>
    </header>

    <div class="app-notice is-info contracts-service-impact" role="note">
        <svg class="app-icon" aria-hidden="true"><use href="#icon-info"></use></svg>
        <div><strong>Thay đổi theo kỳ, không hồi tố.</strong><p>Thêm hoặc bỏ dịch vụ chỉ ảnh hưởng từ tháng/năm áp dụng. Đơn giá và cách tính hiển thị là cấu hình của phòng tại thời điểm này.</p></div>
    </div>

    <section class="app-panel contracts-service-panel" aria-labelledby="contract-service-form-heading">
        <div class="app-panel-header"><div><h2 id="contract-service-form-heading">Kỳ áp dụng và dịch vụ</h2><p data-selected-service-count aria-live="polite"></p></div></div>
        <div class="app-panel-body">
        <form asp-action="DichVu" method="post" class="contracts-form" data-contract-service-form>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="HopDongId" />
            <div asp-validation-summary="ModelOnly" class="contracts-validation-summary"></div>

            <div class="contracts-period-controls">
                <div class="contracts-form-field">
                    <label asp-for="ThangApDung" class="form-label">Tháng áp dụng <span class="contracts-required">*</span></label>
                    <input asp-for="ThangApDung" type="number" min="1" max="12" class="form-control" />
                </div>
                <div class="contracts-form-field">
                    <label asp-for="NamApDung" class="form-label">Năm áp dụng <span class="contracts-required">*</span></label>
                    <input asp-for="NamApDung" type="number" min="2000" max="2100" class="form-control" />
                </div>
                <div class="contracts-period-explanation"><svg class="app-icon" aria-hidden="true"><use href="#icon-service"></use></svg><span>Dịch vụ bên dưới đang được đọc và sẽ được lưu cho kỳ <strong>@Model.ThangApDung/@Model.NamApDung</strong>.</span></div>
            </div>

            @if (Model.DanhSachDichVu.Any())
            {
                <div class="contracts-service-options contracts-service-editor">
                    @foreach (var pdv in Model.DanhSachDichVu)
                    {
                        var batBuoc = pdv.DichVu?.BatBuocKhiThue == true;
                        var isChecked = batBuoc || selected.Contains(pdv.Id);
                        var cachTinh = pdv.DichVu?.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh
                            ? pdv.DichVu.CachTinhCoDinhHienThi
                            : "Theo mức sử dụng trong kỳ";
                        <div class="contracts-service-option @(!pdv.DangApDung ? "is-inactive" : null)">
                            <div class="contracts-service-option-main">
                                <input class="form-check-input" type="checkbox" name="PhongDichVuIds" value="@pdv.Id" id="pdv_@pdv.Id"
                                       checked="@isChecked" data-required-service="@batBuoc.ToString().ToLowerInvariant()" aria-describedby="@(batBuoc ? $"service-{pdv.Id}-help" : null)" />
                                <label class="form-check-label" for="pdv_@pdv.Id">
                                    <span class="contracts-service-option-title">
                                        @pdv.DichVu?.TenDichVu
                                        @if (batBuoc) { <span class="app-status-badge is-danger"><span class="app-status-dot" aria-hidden="true"></span>Bắt buộc</span> }
                                        @if (!pdv.DangApDung) { <span class="app-status-badge is-neutral"><span class="app-status-dot" aria-hidden="true"></span>Phòng đã ngừng cung cấp</span> }
                                    </span>
                                    <span class="contracts-service-option-meta" id="service-@pdv.Id-help">@pdv.DichVu?.LoaiTinhPhiHienThi · @cachTinh</span>
                                </label>
                            </div>
                            <strong class="contracts-service-option-price">@pdv.DonGia.ToString("N0") đ</strong>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="app-empty-state contracts-service-empty"><div><svg class="app-icon" aria-hidden="true"><use href="#icon-service"></use></svg><h3>Phòng chưa có dịch vụ</h3><p>Hãy cấu hình dịch vụ tại module Phòng trước khi cập nhật hợp đồng.</p></div></div>
            }

            <div class="contracts-form-actions">
                <button class="btn btn-primary"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-save"></use></svg>Lưu dịch vụ</span></button>
                <a asp-action="Details" asp-route-id="@Model.HopDongId" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
        </div>
    </section>
    </div>

@section Scripts {
    <script src="~/js/contracts.js" asp-append-version="true"></script>
}
