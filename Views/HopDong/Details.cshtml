@model QuanLyNhaTro.Models.HopDong
@{
    ViewData["Title"] = "Chi tiết hợp đồng";
    ViewData["ActiveMenu"] = "hopdong";
    var danhSachKhach = (ViewBag.DanhSachKhach as IEnumerable<QuanLyNhaTro.Models.HopDongKhachThue> ?? []).ToList();
    var khoanPhatSinh = ViewBag.KhoanPhatSinh as IEnumerable<QuanLyNhaTro.Models.KhoanPhatSinhHopDong> ?? [];
    var dichVuHopDong = ViewBag.DichVuHopDong as IEnumerable<QuanLyNhaTro.Models.PhongDichVu> ?? [];
    bool dangHieuLuc = Model.TrangThai == "DangHieuLuc";
    bool choHieuLuc = Model.TrangThai == "ChoHieuLuc";
    decimal soDuCoc = ViewBag.SoDuCoc is decimal value ? value : Model.TienCoc;
    var kyDichVu = ViewBag.KyDichVu is DateTime ky ? ky : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    var khachDangO = danhSachKhach.Where(x => x.DangCuTru).ToList();
}

<div class="contracts-page contracts-details-page">
    <a asp-action="Index" class="contracts-back-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Danh sách hợp đồng</a>
    <header class="app-page-header contracts-details-header">
        <div class="app-page-heading">
            <div class="contracts-heading-status"><partial name="_StatusBadge" model="Model.TrangThai" /><span>HĐ #@Model.Id</span></div>
            <h1>Hợp đồng — @Model.Phong?.TenPhong</h1>
            <p class="app-page-subtitle">@(Model.Phong?.Nha?.TenNha ?? $"Nhà #{Model.Phong?.NhaId}") · Từ @Model.NgayBatDau.ToString("dd/MM/yyyy") đến @(Model.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "không xác định").</p>
        </div>
        @if (dangHieuLuc || choHieuLuc)
        {
            <div class="app-page-actions" aria-label="Thao tác chỉnh sửa hợp đồng">
                @if (dangHieuLuc)
                {
                    <a asp-controller="Gia" asp-action="HopDong" asp-route-hopDongId="@Model.Id" class="btn btn-outline-secondary"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-edit"></use></svg>Thay đổi giá thuê</span></a>
                }
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-edit"></use></svg>Sửa hợp đồng</span></a>
            </div>
        }
    </header>

    @if (TempData["Error"] != null || TempData["Success"] != null)
    {
        <div class="contracts-flash-stack" aria-live="polite">
            @if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show" role="alert">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div> }
            @if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show" role="status">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng thông báo"></button></div> }
        </div>
    }

@if (Model.HopDongTruocId.HasValue && !Model.DaXuLyChenhLechCoc)
{
    <div class="app-notice is-warning contracts-deposit-notice">
        <svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg>
        <div>
            <strong>Chênh lệch cọc chuyển phòng chưa xử lý.</strong>
            <p>Vào ledger cọc để thu thêm hoặc hoàn lại phần chênh lệch trước khi quyết toán.</p>
        </div>
        <a asp-controller="GiaoDichCoc" asp-action="Index" asp-route-hopDongId="@Model.Id"
           class="btn btn-outline-secondary">
            Xử lý cọc
        </a>
    </div>
}

<div class="contracts-details-grid">
    <section class="app-panel contracts-overview-panel" aria-labelledby="contract-overview-heading">
            <div class="app-panel-header"><h2 id="contract-overview-heading">Thông tin hợp đồng</h2></div>
            <div class="app-panel-body">
                <dl class="contracts-definition-list">
                    <div><dt>Nhà</dt><dd>@(Model.Phong?.Nha?.TenNha ?? $"Nhà #{Model.Phong?.NhaId}")</dd></div>
                    <div><dt>Phòng</dt><dd>
                        <a asp-controller="Phong" asp-action="Details" asp-route-id="@Model.PhongId">
                            @Model.Phong?.TenPhong
                        </a>
                    </dd></div>
                    <div><dt>Số dư cọc thực giữ</dt><dd>
                        <a asp-controller="GiaoDichCoc" asp-action="Index" asp-route-hopDongId="@Model.Id">
                            @soDuCoc.ToString("N0") đ
                        </a>
                    </dd></div>
                    <div><dt>Ngày bắt đầu</dt><dd>@Model.NgayBatDau.ToString("dd/MM/yyyy")</dd></div>
                    <div><dt>Ngày kết thúc</dt><dd>@(Model.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Không xác định")</dd></div>
                    <div><dt>Giá thuê thỏa thuận</dt><dd>@Model.TienThueThoaThuan.ToString("N0") đ / tháng</dd></div>
                    <div><dt>Tiền cọc thỏa thuận</dt><dd>@Model.TienCoc.ToString("N0") đ</dd></div>
                    <div><dt>Ngày thanh toán</dt><dd>Ngày @Model.NgayThanhToanHangThang hàng tháng</dd></div>
                    <div><dt>Trạng thái</dt><dd><partial name="_StatusBadge" model="Model.TrangThai" /></dd></div>
                </dl>
            </div>
    </section>

    <section class="app-panel contracts-residents-summary" aria-labelledby="contract-residents-heading">
            <div class="app-panel-header"><div><h2 id="contract-residents-heading">Người đang ở</h2><p>@khachDangO.Count người hiện diện theo ngày</p></div></div>
            <div class="app-panel-body">
                @if (khachDangO.Any())
                {
                    <ul class="contracts-resident-list">
                        @foreach (var hdk in khachDangO.OrderByDescending(x => x.LaDaiDien).ThenBy(x => x.KhachThue?.HoTen))
                        {
                            <li>
                                <a asp-controller="KhachThue" asp-action="Details"
                                   asp-route-id="@hdk.KhachThueId">
                                    @hdk.KhachThue?.HoTen
                                </a>
                                @if (hdk.LaDaiDien)
                                {
                                    <span class="app-status-badge is-info"><span class="app-status-dot" aria-hidden="true"></span>Đại diện</span>
                                }
                                <small>@(hdk.KhachThue?.SoDienThoai ?? "Chưa có SĐT") · từ @hdk.NgayBatDau.ToString("dd/MM/yyyy")</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="contracts-inline-empty is-warning"><svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg><span>Không có người đang cư trú theo ngày hiện tại.</span></div>
                }
            </div>
    </section>

    <section class="app-panel contracts-operations-panel" aria-labelledby="contract-operations-heading">
        <div class="app-panel-header"><div><h2 id="contract-operations-heading">Thao tác vận hành</h2><p>Các đích ngoài module giữ nguyên luồng hiện có.</p></div></div>
        <div class="app-panel-body">
            @if (dangHieuLuc || choHieuLuc)
            {
                <div class="contracts-operation-actions">
                    @if (dangHieuLuc)
                    {
                        <a asp-controller="ChuyenPhong" asp-action="Create" asp-route-hopDongId="@Model.Id" class="contracts-operation-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-refresh"></use></svg><span><strong>Chuyển phòng</strong><small>Kết thúc phòng cũ và tạo hợp đồng phòng mới.</small></span><svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg></a>
                        <a asp-controller="TraPhong" asp-action="Confirm" asp-route-hopDongId="@Model.Id" class="contracts-operation-link is-danger"><svg class="app-icon" aria-hidden="true"><use href="#icon-door"></use></svg><span><strong>Trả phòng</strong><small>Quyết toán hóa đơn, chỉ số, công nợ và cọc.</small></span><svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg></a>
                    }
                    <a asp-controller="HoaDon" asp-action="Create" asp-route-hopDongId="@Model.Id" class="contracts-operation-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-receipt"></use></svg><span><strong>Lập hóa đơn</strong><small>Tạo hóa đơn cho một kỳ sử dụng.</small></span><svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg></a>
                    <a asp-controller="GiaoDichCoc" asp-action="Index" asp-route-hopDongId="@Model.Id" class="contracts-operation-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-wallet"></use></svg><span><strong>Ledger cọc</strong><small>Xem số dư thực giữ và các giao dịch cọc.</small></span><svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg></a>
                    <a asp-controller="KhoanPhatSinh" asp-action="Index" asp-route-hopDongId="@Model.Id" class="contracts-operation-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg><span><strong>Khoản phát sinh</strong><small>Quản lý phụ thu hoặc đền bù một lần.</small></span><svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg></a>
                </div>
            }
            else
            {
                <div class="contracts-inline-empty"><svg class="app-icon" aria-hidden="true"><use href="#icon-info"></use></svg><span>Thao tác tạo mới đã khóa vì hợp đồng không còn ở trạng thái chờ/đang hiệu lực.</span></div>
                <div class="contracts-reference-actions"><a asp-controller="GiaoDichCoc" asp-action="Index" asp-route-hopDongId="@Model.Id">Xem ledger cọc</a><a asp-controller="KhoanPhatSinh" asp-action="Index" asp-route-hopDongId="@Model.Id">Xem khoản phát sinh</a></div>
            }
        </div>
    </section>
</div>

<section class="app-panel contracts-danger-zone" aria-labelledby="contract-danger-heading">
    <div class="app-panel-header"><div><h2 id="contract-danger-heading">Thao tác nguy hiểm</h2><p>Hủy không thay thế cho Trả phòng.</p></div></div>
    <div class="app-panel-body contracts-danger-content">
        @if ((dangHieuLuc || choHieuLuc) && Model.NgayBatDau.Date > DateTime.Today)
        {
            <div><strong>Hủy hợp đồng tương lai</strong><p>Chỉ thành công khi chưa phát sinh hóa đơn, chỉ số, cọc, thanh toán hoặc khoản phát sinh.</p></div>
            <form asp-action="Huy" asp-route-id="@Model.Id" method="post" data-contract-cancel-form
                  data-confirm-message="Chỉ có thể hủy hợp đồng tương lai chưa phát sinh hóa đơn, chỉ số, cọc, thanh toán hoặc khoản phát sinh. Tiếp tục?">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger" type="submit"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-trash"></use></svg>Hủy hợp đồng</span></button>
            </form>
        }
        else
        {
            <div><strong>Hủy hợp đồng không khả dụng</strong><p>@(dangHieuLuc ? "Hợp đồng đã bắt đầu; phải dùng Trả phòng để quyết toán đầy đủ." : choHieuLuc ? "Ngày bắt đầu đã đến; không còn thuộc điều kiện hủy hợp đồng tương lai." : "Hợp đồng đã kết thúc, đã hủy hoặc đã chuyển phòng nên không thể hủy lại.")</p></div>
            <span class="app-status-badge is-neutral"><span class="app-status-dot" aria-hidden="true"></span>Đã khóa</span>
        }
    </div>
</section>

<section class="app-panel contracts-section-panel" aria-labelledby="contract-services-heading">
        <div class="app-panel-header">
            <div><h2 id="contract-services-heading">Dịch vụ hợp đồng</h2><p>Kỳ đang xem: @kyDichVu.ToString("MM/yyyy")</p></div>
            @if (dangHieuLuc)
            {
                <a asp-action="DichVu" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                    <span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-service"></use></svg>Cập nhật từ kỳ tiếp theo</span>
                </a>
            }
        </div>
    <div class="app-panel-body contracts-table-body">
        @if (dichVuHopDong.Any())
        {
            <div class="table-responsive contracts-data-table">
                <table class="table mb-0">
                    <thead><tr><th>Dịch vụ</th><th>Cách tính</th><th class="text-end">Đơn giá</th></tr></thead>
                    <tbody>
                    @foreach (var pdv in dichVuHopDong)
                    {
                        <tr>
                            <td>
                                @pdv.DichVu?.TenDichVu
                                @if (pdv.DichVu?.BatBuocKhiThue == true)
                                {
                                    <span class="app-status-badge is-danger"><span class="app-status-dot" aria-hidden="true"></span>Bắt buộc</span>
                                }
                            </td>
                            <td><strong>@pdv.DichVu?.LoaiTinhPhiHienThi</strong><small>@(pdv.DichVu?.LoaiTinhPhi == QuanLyNhaTro.Models.DichVu.LoaiCoDinh ? pdv.DichVu.CachTinhCoDinhHienThi : "Theo mức sử dụng trong kỳ")</small></td>
                            <td class="text-end">@pdv.DonGia.ToString("N0") đ</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="contracts-inline-empty is-warning"><svg class="app-icon" aria-hidden="true"><use href="#icon-alert"></use></svg><span>Hợp đồng chưa đăng ký dịch vụ trong kỳ @kyDichVu.ToString("MM/yyyy").</span></div>
        }
    </div>
</section>

<section class="app-panel contracts-section-panel" aria-labelledby="contract-charges-heading">
        <div class="app-panel-header">
            <div><h2 id="contract-charges-heading">Khoản phát sinh</h2><p>Các khoản một lần gắn với hợp đồng.</p></div>
            <a asp-controller="KhoanPhatSinh" asp-action="Index" asp-route-hopDongId="@Model.Id"
               class="btn btn-outline-secondary">
                <span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-arrow"></use></svg>Quản lý</span>
            </a>
        </div>
    <div class="app-panel-body contracts-table-body">
        @if (khoanPhatSinh.Any())
        {
            <div class="table-responsive contracts-data-table">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr><th>Ngày</th><th>Nội dung</th><th class="text-end">Số tiền</th><th>Trạng thái</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in khoanPhatSinh.Take(5))
                        {
                            <tr>
                                <td>@item.NgayPhatSinh.ToString("dd/MM/yyyy")</td>
                                <td>@item.MoTa</td>
                                <td class="text-end">@item.SoTien.ToString("N0") đ</td>
                                <td>@TrangThaiKhoanPhatSinh(item.TrangThai)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="contracts-inline-empty"><svg class="app-icon" aria-hidden="true"><use href="#icon-info"></use></svg><span>Chưa có khoản phát sinh nào.</span></div>
        }
    </div>
</section>

<section class="app-panel contracts-section-panel contracts-residency-panel" aria-labelledby="contract-residency-heading">
    <div class="app-panel-header"><div><h2 id="contract-residency-heading">Lịch sử cư trú</h2><p>Ngày thực tế quyết định số người và dịch vụ Theo người.</p></div></div>
    <div class="app-panel-body contracts-table-body">
        <div class="table-responsive contracts-data-table contracts-residency-table">
            <table class="table align-middle">
                <thead>
                    <tr><th>Khách</th><th>Bắt đầu thực tế</th><th>Dự kiến rời</th><th>Kết thúc thực tế</th><th>Vai trò</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var item in danhSachKhach.OrderByDescending(x => x.NgayBatDau).ThenByDescending(x => x.Id))
                {
                    <tr>
                        <td><a asp-controller="KhachThue" asp-action="Details" asp-route-id="@item.KhachThueId">@item.KhachThue?.HoTen</a></td>
                        <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                        <td>@(item.NgayKetThucDuKien?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@(item.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Đang mở")</td>
                        <td>@(item.LaDaiDien ? "Đại diện" : "Người ở")</td>
                        <td class="text-end">
                            @if (!item.NgayKetThuc.HasValue && (dangHieuLuc || choHieuLuc))
                            {
                                <form asp-action="KetThucCuTru" asp-route-id="@Model.Id" method="post" class="contracts-end-residency-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cuTruId" value="@item.Id" />
                                    <label class="visually-hidden" for="resident-end-@item.Id">Ngày rời của @item.KhachThue?.HoTen</label>
                                    <input id="resident-end-@item.Id" type="date" name="ngayKetThuc" class="form-control" required />
                                    <button class="btn btn-outline-danger">Ghi nhận rời</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!danhSachKhach.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">Chưa có lịch sử cư trú.</td></tr>
                }
                </tbody>
            </table>
        </div>

        @if (dangHieuLuc || choHieuLuc)
        {
            <div class="contracts-resident-form-heading"><h3>Thêm người ở</h3><p>Tái sử dụng hồ sơ khách cũ để mở giai đoạn cư trú mới.</p></div>
            <form asp-action="ThemNguoiO" asp-route-id="@Model.Id" method="post" class="contracts-resident-form" data-resident-form data-tenant-search-url="@Url.Action("Search", "KhachThue")">
                @Html.AntiForgeryToken()
                <input type="hidden" id="residentTenantId" name="khachThueId" required />
                <div class="contracts-form-field contracts-resident-search-field">
                    <label class="form-label" for="residentSearch">Tìm hồ sơ khách cũ <span class="contracts-required">*</span></label>
                    <input id="residentSearch" class="form-control" autocomplete="off" placeholder="Tên, SĐT, CCCD, biển số" data-resident-search />
                    <div id="residentResults" class="contracts-search-results" data-resident-results hidden></div>
                    <div id="residentSelected" class="contracts-form-hint" data-resident-selected>Chưa chọn hồ sơ.</div>
                </div>
                <div class="contracts-form-field">
                    <label class="form-label" for="resident-start">Bắt đầu thực tế <span class="contracts-required">*</span></label>
                    <input id="resident-start" type="date" name="ngayBatDau" class="form-control" value="@((Model.NgayBatDau > DateTime.Today ? Model.NgayBatDau : DateTime.Today).ToString("yyyy-MM-dd"))" required />
                </div>
                <div class="contracts-form-field">
                    <label class="form-label" for="resident-planned-end">Dự kiến rời</label>
                    <input id="resident-planned-end" type="date" name="ngayKetThucDuKien" class="form-control" />
                </div>
                <div class="contracts-resident-representative">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="laDaiDien" value="true" id="laDaiDien" />
                        <label class="form-check-label" for="laDaiDien">Đại diện</label>
                    </div>
                </div>
                <div class="contracts-resident-submit"><button class="btn btn-primary"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-plus"></use></svg>Thêm người ở</span></button></div>
            </form>
        }
    </div>
</section>

</div>

@section Scripts {
    <script src="~/js/contracts.js" asp-append-version="true"></script>
}

@functions {
    private static string TrangThaiKhoanPhatSinh(string? trangThai) => trangThai switch
    {
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiChuaXuLy => "Chưa xử lý",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaDuaVaoHoaDon => "Đã đưa vào hóa đơn",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaThu => "Đã thu",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaTruCoc => "Đã trừ cọc",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaHuy => "Đã hủy",
        _ => trangThai ?? string.Empty
    };
}
