@model QuanLyNhaTro.Models.HopDong
@{
    ViewData["Title"] = "Chi tiết hợp đồng";
    ViewData["ActiveMenu"] = "hopdong";
    var danhSachKhach = (ViewBag.DanhSachKhach as IEnumerable<QuanLyNhaTro.Models.HopDongKhachThue> ?? []).ToList();
    var khoanPhatSinh = ViewBag.KhoanPhatSinh as IEnumerable<QuanLyNhaTro.Models.KhoanPhatSinhHopDong> ?? [];
    var dichVuHopDong = ViewBag.DichVuHopDong as IEnumerable<QuanLyNhaTro.Models.PhongDichVu> ?? [];
    bool dangHieuLuc = Model.TrangThai == "DangHieuLuc";
    bool choHieuLuc = Model.TrangThai == "ChoHieuLuc";
    decimal soDuCoc = ViewBag.SoDuCoc is decimal value ? value : Model.TienCoc;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Hợp đồng — @Model.Phong?.TenPhong</h5>
    @if (dangHieuLuc || choHieuLuc)
    {
        @if (dangHieuLuc)
        {
            <a asp-controller="Gia" asp-action="HopDong" asp-route-hopDongId="@Model.Id"
               class="btn btn-sm btn-outline-warning ms-auto">
                <i class="bi bi-tag me-1"></i>Thay đổi giá thuê
            </a>
        }
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary @(choHieuLuc ? "ms-auto" : "me-1")">
            <i class="bi bi-pencil me-1"></i>Sửa
        </a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.HopDongTruocId.HasValue && !Model.DaXuLyChenhLechCoc)
{
    <div class="alert alert-warning d-flex align-items-center justify-content-between gap-3">
        <div>
            <strong>Chênh lệch cọc chuyển phòng chưa xử lý.</strong>
            Vào ledger cọc để thu thêm hoặc hoàn lại phần chênh lệch.
        </div>
        <a asp-controller="GiaoDichCoc" asp-action="Index" asp-route-hopDongId="@Model.Id"
           class="btn btn-sm btn-warning">
            Xử lý cọc
        </a>
    </div>
}

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Thông tin hợp đồng</h6>
                <dl class="row mb-0">
                    <dt class="col-5">Phòng</dt>
                    <dd class="col-7">
                        <a asp-controller="Phong" asp-action="Details" asp-route-id="@Model.PhongId">
                            @Model.Phong?.TenPhong
                        </a>
                    </dd>
                    <dt class="col-5">Số dư cọc</dt>
                    <dd class="col-7">
                        <a asp-controller="GiaoDichCoc" asp-action="Index" asp-route-hopDongId="@Model.Id">
                            @soDuCoc.ToString("N0") đ
                        </a>
                    </dd>
                    <dt class="col-5">Ngày bắt đầu</dt> <dd class="col-7">@Model.NgayBatDau.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-5">Ngày kết thúc</dt><dd class="col-7">@(Model.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Không xác định")</dd>
                    <dt class="col-5">Giá thuê TT</dt>   <dd class="col-7">@Model.TienThueThoaThuan.ToString("N0") đ</dd>
                    <dt class="col-5">Tiền cọc</dt>      <dd class="col-7">@Model.TienCoc.ToString("N0") đ</dd>
                    <dt class="col-5">Ngày thanh toán</dt><dd class="col-7">Ngày @Model.NgayThanhToanHangThang hàng tháng</dd>
                    <dt class="col-5">Trạng thái</dt>
                    <dd class="col-7">
                        @Html.Raw(Model.TrangThai switch {
                            "DangHieuLuc"   => "<span class='badge bg-success'>Đang hiệu lực</span>",
                            "ChoHieuLuc"    => "<span class='badge bg-warning text-dark'>Chờ hiệu lực</span>",
                            "DaKetThuc"     => "<span class='badge bg-secondary'>Đã kết thúc</span>",
                            "DaHuy"         => "<span class='badge bg-danger'>Đã huỷ</span>",
                            _               => $"<span class='badge bg-light text-dark border'>{Model.TrangThai}</span>"
                        })
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Khách thuê</h6>
                @if (danhSachKhach.Any())
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var hdk in danhSachKhach)
                        {
                            <li class="mb-1">
                                <a asp-controller="KhachThue" asp-action="Details"
                                   asp-route-id="@hdk.KhachThueId" class="text-decoration-none">
                                    @hdk.KhachThue?.HoTen
                                </a>
                                @if (hdk.LaDaiDien)
                                {
                                    <span class="badge bg-primary ms-1">Chính</span>
                                }
                                <small class="text-muted ms-1">@hdk.KhachThue?.SoDienThoai</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có khách.</p>
                }
            </div>
        </div>

        @if (dangHieuLuc || choHieuLuc)
        {
            <div class="card shadow-sm border-warning">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-3">Thao tác</h6>
                    <div class="d-flex gap-2 flex-wrap">
                        @if (dangHieuLuc)
                        {
                            <a asp-controller="ChuyenPhong" asp-action="Create"
                               asp-route-hopDongId="@Model.Id"
                               class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-arrow-left-right"></i> Chuyển phòng
                            </a>
                            <a asp-controller="TraPhong" asp-action="Confirm"
                               asp-route-hopDongId="@Model.Id"
                               class="btn btn-sm btn-danger me-1">
                                <i class="bi bi-door-open"></i> Trả phòng
                            </a>
                        }
                        <a asp-controller="HoaDon" asp-action="Create" asp-route-hopDongId="@Model.Id"
                           class="btn btn-sm btn-success">
                            <i class="bi bi-receipt me-1"></i>Lập hóa đơn
                        </a>
                        <a asp-controller="GiaoDichCoc" asp-action="Index" asp-route-hopDongId="@Model.Id"
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-wallet2 me-1"></i>Ledger cọc
                        </a>
                        <a asp-controller="KhoanPhatSinh" asp-action="Index" asp-route-hopDongId="@Model.Id"
                           class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-exclamation-diamond me-1"></i>Khoản phát sinh
                        </a>
                        @if (Model.NgayBatDau.Date > DateTime.Today)
                        {
                            <form asp-action="Huy" asp-route-id="@Model.Id" method="post"
                                  onsubmit="return confirm('Chỉ có thể huỷ hợp đồng tương lai chưa phát sinh hóa đơn, chỉ số, cọc, thanh toán hoặc khoản phát sinh. Tiếp tục?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger">Huỷ HĐ</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mt-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="card-title text-muted mb-0">Dịch vụ hợp đồng</h6>
            @if (dangHieuLuc)
            {
                <a asp-action="DichVu" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-sliders me-1"></i>Cập nhật từ kỳ tiếp theo
                </a>
            }
        </div>
        @if (dichVuHopDong.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Dịch vụ</th><th>Loại</th><th class="text-end">Đơn giá hiện tại</th></tr></thead>
                    <tbody>
                    @foreach (var pdv in dichVuHopDong)
                    {
                        <tr>
                            <td>
                                @pdv.DichVu?.TenDichVu
                                @if (pdv.DichVu?.BatBuocKhiThue == true)
                                {
                                    <span class="badge bg-danger ms-1">Bắt buộc</span>
                                }
                            </td>
                            <td>@pdv.DichVu?.LoaiTinhPhiHienThi</td>
                            <td class="text-end">@pdv.DonGia.ToString("N0") đ</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-warning mb-0">Hợp đồng chưa đăng ký dịch vụ trong kỳ đang xem.</p>
        }
    </div>
</div>

<div class="card shadow-sm mt-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="card-title text-muted mb-0">Khoản phát sinh</h6>
            <a asp-controller="KhoanPhatSinh" asp-action="Index" asp-route-hopDongId="@Model.Id"
               class="btn btn-sm btn-outline-danger">
                <i class="bi bi-plus-lg me-1"></i>Quản lý
            </a>
        </div>
        @if (khoanPhatSinh.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>Ngày</th><th>Nội dung</th><th class="text-end">Số tiền</th><th>Trạng thái</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in khoanPhatSinh.Take(5))
                        {
                            <tr>
                                <td>@item.NgayPhatSinh.ToString("dd/MM/yyyy")</td>
                                <td>@item.MoTa</td>
                                <td class="text-end">@item.SoTien.ToString("N0") đ</td>
                                <td>@TrangThaiKhoanPhatSinh(item.TrangThai)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">Chưa có khoản phát sinh nào.</p>
        }
    </div>
</div>

<div class="card shadow-sm mt-3">
    <div class="card-body">
        <h6 class="card-title text-muted mb-3">Lịch sử cư trú</h6>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead class="table-light">
                    <tr><th>Khách</th><th>Bắt đầu thực tế</th><th>Dự kiến rời</th><th>Kết thúc thực tế</th><th>Vai trò</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var item in danhSachKhach.OrderByDescending(x => x.NgayBatDau).ThenByDescending(x => x.Id))
                {
                    <tr>
                        <td><a asp-controller="KhachThue" asp-action="Details" asp-route-id="@item.KhachThueId">@item.KhachThue?.HoTen</a></td>
                        <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                        <td>@(item.NgayKetThucDuKien?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@(item.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Đang mở")</td>
                        <td>@(item.LaDaiDien ? "Đại diện" : "Người ở")</td>
                        <td class="text-end">
                            @if (!item.NgayKetThuc.HasValue && (dangHieuLuc || choHieuLuc))
                            {
                                <form asp-action="KetThucCuTru" asp-route-id="@Model.Id" method="post" class="d-flex gap-1 justify-content-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cuTruId" value="@item.Id" />
                                    <input type="date" name="ngayKetThuc" class="form-control form-control-sm" style="max-width:145px" required />
                                    <button class="btn btn-sm btn-outline-danger">Ghi nhận rời</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!danhSachKhach.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">Chưa có lịch sử cư trú.</td></tr>
                }
                </tbody>
            </table>
        </div>

        @if (dangHieuLuc || choHieuLuc)
        {
            <hr />
            <form asp-action="ThemNguoiO" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" id="residentTenantId" name="khachThueId" required />
                <div class="col-lg-4 position-relative">
                    <label class="form-label small">Tìm hồ sơ khách cũ</label>
                    <input id="residentSearch" class="form-control" autocomplete="off" placeholder="Tên, SĐT, CCCD, biển số" />
                    <div id="residentResults" class="list-group position-absolute w-100" style="z-index:10"></div>
                    <div id="residentSelected" class="form-text"></div>
                </div>
                <div class="col-sm-3 col-lg-2">
                    <label class="form-label small">Bắt đầu thực tế</label>
                    <input type="date" name="ngayBatDau" class="form-control" value="@((Model.NgayBatDau > DateTime.Today ? Model.NgayBatDau : DateTime.Today).ToString("yyyy-MM-dd"))" required />
                </div>
                <div class="col-sm-3 col-lg-2">
                    <label class="form-label small">Dự kiến rời</label>
                    <input type="date" name="ngayKetThucDuKien" class="form-control" />
                </div>
                <div class="col-sm-3 col-lg-2">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="laDaiDien" value="true" id="laDaiDien" />
                        <label class="form-check-label" for="laDaiDien">Đại diện</label>
                    </div>
                </div>
                <div class="col-sm-3 col-lg-2"><button class="btn btn-primary w-100">Thêm người ở</button></div>
            </form>
        }
    </div>
</div>

@section Scripts {
<script>
(() => {
    const input = document.getElementById('residentSearch');
    if (!input) return;
    const idInput = document.getElementById('residentTenantId');
    const results = document.getElementById('residentResults');
    const selected = document.getElementById('residentSelected');
    let timer;
    const esc = value => String(value ?? '').replace(/[&<>'"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
    input.addEventListener('input', () => {
        clearTimeout(timer); idInput.value = ''; selected.textContent = '';
        const term = input.value.trim();
        if (term.length < 2) { results.innerHTML = ''; return; }
        timer = setTimeout(async () => {
            const response = await fetch(`@Url.Action("Search", "KhachThue")?term=${encodeURIComponent(term)}&limit=20`);
            const rows = response.ok ? await response.json() : [];
            results.innerHTML = rows.map(x => `<button type="button" class="list-group-item list-group-item-action"><strong>${esc(x.hoTen)}</strong><br><small>${esc(x.soDienThoai)} · ${esc(x.cccd)} · ${esc(x.bienSoXe)}</small></button>`).join('');
            results.querySelectorAll('button').forEach((button, index) => button.onclick = () => {
                const row = rows[index]; idInput.value = row.id; input.value = row.hoTen;
                selected.textContent = `Đã chọn hồ sơ #${row.id}`; results.innerHTML = '';
            });
        }, 300);
    });
})();
</script>
}

@functions {
    private static string TrangThaiKhoanPhatSinh(string? trangThai) => trangThai switch
    {
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiChuaXuLy => "Chưa xử lý",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaDuaVaoHoaDon => "Đã đưa vào hóa đơn",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaThu => "Đã thu",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaTruCoc => "Đã trừ cọc",
        QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiDaHuy => "Đã hủy",
        _ => trangThai ?? string.Empty
    };
}
