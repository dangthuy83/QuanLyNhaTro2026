@model QuanLyNhaTro.Models.HopDong
@using System.Text.Json
@{
    ViewData["Title"] = "Tạo hợp đồng";
    ViewData["ActiveMenu"] = "hopdong";
    var danhSachPhong = ViewBag.DanhSachPhong as IEnumerable<QuanLyNhaTro.Models.Phong> ?? [];
    var danhSachKhach = ViewBag.DanhSachKhach as IEnumerable<QuanLyNhaTro.Models.KhachThue> ?? [];
    int? phongIdMacDinh = ViewBag.PhongIdMacDinh;
    var selectedIds = ViewBag.PhongDichVuIdsDaChon as int[];
    var selectedJson = JsonSerializer.Serialize(selectedIds ?? []);
    var restoreSelection = selectedIds != null;
    int? khachChinhIdDaChon = ViewBag.KhachChinhIdDaChon;
}

<div class="contracts-page contracts-form-page contracts-create-page"
     data-contract-create
     data-services-url="@Url.Action("DichVuTheoPhong")"
     data-tenant-search-url="@Url.Action("Search", "KhachThue")"
     data-selected-service-ids="@selectedJson"
     data-restore-selection="@restoreSelection.ToString().ToLowerInvariant()">
    <a asp-action="Index" class="contracts-back-link"><svg class="app-icon" aria-hidden="true"><use href="#icon-back"></use></svg>Danh sách hợp đồng</a>
    <header class="app-page-header">
        <div class="app-page-heading">
            <h1>Tạo hợp đồng mới</h1>
            <p class="app-page-subtitle">Chọn phòng, thời hạn, dịch vụ và đúng một khách đại diện trước khi lưu hợp đồng.</p>
        </div>
    </header>

    <section class="app-panel contracts-form-panel" aria-labelledby="contract-create-form-heading">
        <div class="app-panel-header"><div><h2 id="contract-create-form-heading">Thông tin hợp đồng</h2><p>Thông tin có dấu <span class="contracts-required">*</span> là bắt buộc.</p></div></div>
        <div class="app-panel-body">
        <form asp-action="Create" method="post" class="contracts-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="contracts-validation-summary"></div>

            <div class="mb-3">
                <label class="form-label" for="contract-room">Phòng <span class="contracts-required">*</span></label>
                <select id="contract-room" name="PhongId" class="form-select" required>
                    <option value="">— Chọn phòng —</option>
                    @foreach (var p in danhSachPhong)
                    {
                        <option value="@p.Id" data-price="@p.GiaThueMacDinh.ToString("0")" selected="@(p.Id == phongIdMacDinh || p.Id == Model?.PhongId)">
                            @(p.Nha?.TenNha ?? $"Nhà #{p.NhaId}") · @p.TenPhong (@p.TrangThai)
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label" id="contract-services-label">Dịch vụ đăng ký</label>
                <div id="dichVuHopDong" class="contracts-service-options" data-contract-services aria-labelledby="contract-services-label">
                    <div class="contracts-inline-empty"><svg class="app-icon" aria-hidden="true"><use href="#icon-service"></use></svg><span>Chọn phòng để tải dịch vụ có thể đăng ký.</span></div>
                </div>
                <div id="required-service-help" class="contracts-form-hint">Tất cả dịch vụ của phòng được chọn sẵn; dịch vụ bắt buộc không thể bỏ.</div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label" for="contract-start">Ngày bắt đầu <span class="contracts-required">*</span></label>
                    <input id="contract-start" asp-for="NgayBatDau" type="date" class="form-control" required
                           value="@((Model?.NgayBatDau == default ? DateTime.Today : Model!.NgayBatDau).ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-6">
                    <label class="form-label" for="contract-end">Ngày kết thúc</label>
                    <input id="contract-end" asp-for="NgayKetThuc" type="date" class="form-control" />
                    <div class="form-text">Để trống nếu không xác định.</div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="NgayThanhToanHangThang" class="form-label">
                    Ngày thanh toán hàng tháng <span class="contracts-required">*</span>
                </label>
                <input asp-for="NgayThanhToanHangThang" type="number" min="1" max="31"
                       value="@(Model?.NgayThanhToanHangThang ?? 5)" class="form-control" required />
                <span asp-validation-for="NgayThanhToanHangThang" class="text-danger small"></span>
                <div class="form-text">Hóa đơn kỳ N đến hạn vào ngày này trong tháng N+1; tháng thiếu ngày dùng ngày cuối tháng.</div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label" for="tienThue">Giá thuê thỏa thuận (đ) <span class="contracts-required">*</span></label>
                    <input name="TienThueThoaThuan" id="tienThue" type="number" min="0" class="form-control" required value="@(Model?.TienThueThoaThuan.ToString("0") ?? "")" data-contract-money-preview="rent-preview" />
                    <div id="rent-preview" class="contracts-money-preview" aria-live="polite"></div>
                </div>
                <div class="col-6">
                    <label class="form-label" for="tienCoc">Tiền cọc (đ)</label>
                    <input name="TienCoc" id="tienCoc" type="number" min="0" class="form-control" value="@(Model?.TienCoc.ToString("0") ?? "")" data-contract-money-preview="deposit-preview" />
                    <div id="deposit-preview" class="contracts-money-preview" aria-live="polite"></div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="tenantSearch">Khách thuê và người đại diện <span class="contracts-required">*</span></label>
                <input id="tenantSearch" type="search" class="form-control" autocomplete="off" data-tenant-search
                       placeholder="Tìm theo tên, SĐT, CCCD hoặc biển số (ít nhất 2 ký tự)" />
                <div id="tenantSearchResults" class="contracts-search-results" data-tenant-results hidden></div>
                <div id="selectedTenants" class="contracts-selected-tenants" data-selected-tenants>
                    @foreach (var k in danhSachKhach)
                    {
                        <div class="contracts-tenant-row" data-tenant-row data-tenant-id="@k.Id">
                            <input type="hidden" name="khachThueIds" value="@k.Id" />
                            <label class="contracts-representative-choice"><input type="radio" name="khachChinhId" value="@k.Id" checked="@(k.Id == khachChinhIdDaChon)" /><span><strong>@k.HoTen</strong><small>@(k.SoDienThoai ?? "Chưa có SĐT") · CCCD @(k.CCCD ?? "chưa có")</small></span></label>
                            <button type="button" class="btn btn-outline-danger" data-remove-tenant aria-label="Bỏ @k.HoTen khỏi hợp đồng">Bỏ</button>
                        </div>
                    }
                    <div class="contracts-inline-empty" data-selected-tenants-empty><svg class="app-icon" aria-hidden="true"><use href="#icon-users"></use></svg><span>Chưa chọn khách thuê.</span></div>
                </div>
                <div class="contracts-form-hint">Chọn hồ sơ cũ để tạo giai đoạn cư trú mới; nút tròn đánh dấu đúng một người đại diện.</div>
                <a asp-controller="KhachThue" asp-action="Create" class="contracts-text-link">Chưa có hồ sơ? Thêm khách mới</a>
            </div>

            <div class="mb-3">
                <label class="form-label" for="contract-note">Ghi chú</label>
                <textarea id="contract-note" name="GhiChu" class="form-control" rows="3">@Model?.GhiChu</textarea>
            </div>

            <div class="contracts-form-actions">
                <button type="submit" class="btn btn-primary"><span class="app-button-content"><svg class="app-icon" aria-hidden="true"><use href="#icon-save"></use></svg>Tạo hợp đồng</span></button>
                <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>
        </div>
    </section>
    </div>

@section Scripts {
    <script src="~/js/contracts.js" asp-append-version="true"></script>
}
