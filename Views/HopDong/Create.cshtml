@{
    ViewData["Title"] = "Tạo hợp đồng";
    ViewData["ActiveMenu"] = "hopdong";
    var danhSachPhong = ViewBag.DanhSachPhong as IEnumerable<QuanLyNhaTro.Models.Phong> ?? [];
    var danhSachKhach = ViewBag.DanhSachKhach as IEnumerable<QuanLyNhaTro.Models.KhachThue> ?? [];
    int? phongIdMacDinh = ViewBag.PhongIdMacDinh;
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">Tạo hợp đồng mới</h5>
</div>

<div class="card shadow-sm" style="max-width:640px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">Phòng <span class="text-danger">*</span></label>
                <select name="PhongId" class="form-select" required>
                    <option value="">— Chọn phòng —</option>
                    @foreach (var p in danhSachPhong)
                    {
                        <option value="@p.Id" selected="@(p.Id == phongIdMacDinh)">
                            @p.TenPhong (@p.TrangThai)
                        </option>
                    }
                </select>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">Ngày bắt đầu <span class="text-danger">*</span></label>
                    <input name="NgayBatDau" type="date" class="form-control" required
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Ngày kết thúc</label>
                    <input name="NgayKetThuc" type="date" class="form-control" />
                    <div class="form-text">Để trống nếu không xác định.</div>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">Giá thuê thỏa thuận (đ) <span class="text-danger">*</span></label>
                    <input name="TienThueThoaThuan" type="number" min="0" class="form-control" required />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Tiền cọc (đ)</label>
                    <input name="TienCoc" type="number" min="0" class="form-control" value="0" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Khách thuê</label>
                <div class="border rounded p-2" style="max-height:200px; overflow-y:auto">
                    @foreach (var k in danhSachKhach)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   name="khachThueIds" value="@k.Id" id="k_@k.Id" />
                            <label class="form-check-label" for="k_@k.Id">
                                @k.HoTen @(k.SoDienThoai != null ? $"({k.SoDienThoai})" : "")
                                <input type="radio" name="khachChinhId" value="@k.Id"
                                       class="ms-2" title="Đánh dấu khách chính" />
                                <small class="text-muted">chính</small>
                            </label>
                        </div>
                    }
                    @if (!danhSachKhach.Any())
                    {
                        <p class="text-muted mb-0 small">Chưa có khách. <a asp-controller="KhachThue" asp-action="Create">Thêm khách mới</a></p>
                    }
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Ghi chú</label>
                <textarea name="GhiChu" class="form-control" rows="2"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Tạo hợp đồng</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>
    </div>
</div>
