@model ThayDoiHinhThucDichVuViewModel
@{ ViewData["Title"] = "Thay đổi hình thức dịch vụ"; }
<div class="d-flex justify-content-between mb-3"><div><h4>Thay đổi hình thức theo kỳ</h4><div class="text-muted">@Model.DichVu?.TenDichVu</div></div><a asp-controller="DichVu" asp-action="Index" class="btn btn-outline-secondary">Quay lại</a></div>
@if(TempData["Success"]!=null){<div class="alert alert-success">@TempData["Success"]</div>}
<div asp-validation-summary="All" class="text-danger mb-3"></div>
<form method="post" class="card mb-4"><input type="hidden" asp-for="DichVuId"/><div class="card-body row g-3">
<div class="col-md-3"><label class="form-label">Loại tính mới</label><select asp-for="LoaiTinhPhiMoi" class="form-select" id="loaiMoi"><option value="CoDinh">Cố định</option><option value="TheoChiSo">Theo chỉ số</option></select></div>
<div class="col-md-3"><label class="form-label">Cách tính cố định</label><select asp-for="CachTinhCoDinhMoi" class="form-select" id="cachMoi"><option value="TheoPhong">Theo phòng</option><option value="TheoNguoi">Theo người</option></select></div>
<div class="col-md-2"><label class="form-label">Tháng áp dụng</label><input asp-for="ThangApDung" min="1" max="12" class="form-control"/></div><div class="col-md-2"><label class="form-label">Năm áp dụng</label><input asp-for="NamApDung" min="2000" class="form-control"/></div>
<div class="col-12"><label class="form-label">Lý do</label><textarea asp-for="LyDo" required class="form-control"></textarea></div>
<div class="col-12" id="opening"><div class="alert alert-warning">Chuyển sang theo chỉ số: khai báo chỉ số đầu cho mọi phòng đã gắn dịch vụ.</div><div class="row g-2">
@for(var i=0;i<Model.PhongLienQuan.Count;i++){<input type="hidden" asp-for="PhongLienQuan[i].PhongId"/><input type="hidden" asp-for="PhongLienQuan[i].TenPhong"/><div class="col-md-4"><label class="form-label">@Model.PhongLienQuan[i].TenPhong</label><input asp-for="PhongLienQuan[i].ChiSoDau" type="number" min="0" step="0.01" class="form-control"/></div>}
</div></div></div><div class="card-footer"><button class="btn btn-primary">Ghi nhận thay đổi</button></div></form>
<div class="card"><div class="card-header">Lịch sử</div><table class="table mb-0"><thead><tr><th>Kỳ</th><th>Cũ</th><th>Mới</th><th>Lý do</th></tr></thead><tbody>@foreach(var x in Model.LichSu){<tr><td>@x.KyApDung.ToString("MM/yyyy")</td><td>@x.LoaiTinhPhiCu / @x.CachTinhCoDinhCu</td><td>@x.LoaiTinhPhiMoi / @x.CachTinhCoDinhMoi</td><td>@x.LyDo</td></tr>}</tbody></table></div>
<script>function sync(){let m=document.getElementById('loaiMoi').value==='TheoChiSo';document.getElementById('cachMoi').disabled=m;document.getElementById('opening').style.display=m?'block':'none'}document.getElementById('loaiMoi').addEventListener('change',sync);sync();</script>
