@model IEnumerable<QuanLyNhaTro.Models.KhoanPhatSinhHopDong>
@{ var hopDong = ViewBag.HopDong as QuanLyNhaTro.Models.HopDong; ViewData["Title"] = "Khoản phát sinh"; ViewData["ActiveMenu"] = "hopdong"; }
<div class="contract-finance-page incidents-page">
    <header class="app-page-header"><div class="app-page-heading"><a asp-controller="HopDong" asp-action="Details" asp-route-id="@hopDong?.Id" class="contract-finance-back-link">← Hợp đồng #@hopDong?.Id</a><h1>Khoản phát sinh · @hopDong?.Phong?.TenPhong</h1><p class="app-page-subtitle">Theo dõi khoản chưa xử lý, đã đưa vào hóa đơn, đã thu, đã trừ cọc hoặc đã hủy.</p></div></header>
    @if (TempData["Success"] != null) { <div class="app-notice is-success" role="status">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="app-notice is-danger" role="alert">@TempData["Error"]</div> }
    <div class="contract-finance-grid">
        <section class="app-panel"><div class="app-panel-header"><div><h2>Ghi nhận khoản phát sinh</h2><p>Khoản mới ở trạng thái chưa xử lý cho đến khi được đưa vào flow server.</p></div></div><form asp-action="Create" method="post" class="app-panel-body contract-finance-form">@Html.AntiForgeryToken()<input type="hidden" name="HopDongId" value="@hopDong?.Id" /><div class="app-field"><label for="incidentDate">Ngày phát sinh</label><input id="incidentDate" name="NgayPhatSinh" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required /></div><div class="app-field"><label for="incidentType">Loại khoản</label><select id="incidentType" name="LoaiKhoan" class="form-select"><option value="HuHongTaiSan">Đền bù hư hỏng tài sản</option><option value="MatChiaKhoa">Mất chìa khóa/thẻ xe</option><option value="PhatViPham">Phạt vi phạm</option><option value="PhuThu">Phụ thu</option><option value="Khac">Khác</option></select></div><div class="app-field"><label for="incidentDescription">Mô tả</label><input id="incidentDescription" name="MoTa" class="form-control" maxlength="500" required /></div><div class="app-field"><label for="incidentAmount">Số tiền</label><input id="incidentAmount" name="SoTien" type="number" min="1" step="1" class="form-control" required /></div><div class="app-field"><label for="incidentNote">Ghi chú</label><input id="incidentNote" name="GhiChu" class="form-control" maxlength="255" /></div><button class="btn btn-primary">Lưu khoản phát sinh</button></form></section>
        <section class="app-panel"><div class="app-panel-header"><div><h2>Danh sách khoản phát sinh</h2><p>@Model.Count() khoản đã ghi nhận.</p></div></div>@if (!Model.Any()) { <div class="app-empty-state"><div><h3>Chưa có khoản phát sinh</h3><p>Các khoản ghi nhận cho hợp đồng sẽ xuất hiện tại đây.</p></div></div> } else { <div class="contract-finance-table-wrap"><table class="contract-finance-table"><thead><tr><th>Ngày / nội dung</th><th>Số tiền</th><th>Trạng thái</th><th>Thao tác</th></tr></thead><tbody>@foreach (var item in Model) { <tr><td data-label="Nội dung"><strong>@item.MoTa</strong><small>@item.NgayPhatSinh.ToString("dd/MM/yyyy") · @item.LoaiKhoan @item.GhiChu</small></td><td data-label="Số tiền" class="contract-finance-amount"><span>@item.SoTien.ToString("N0") đ</span>@if (item.SoTienConLai != item.SoTien) { <small>Còn @item.SoTienConLai.ToString("N0") đ</small> }</td><td data-label="Trạng thái">@switch (item.TrangThai) { case "ChuaXuLy": <span class="app-status-badge is-warning">Chưa xử lý</span>; break; case "DaDuaVaoHoaDon": <a asp-controller="HoaDon" asp-action="Details" asp-route-id="@item.HoaDonId" class="app-status-badge is-info">Hóa đơn #@item.HoaDonId</a>; break; case "DaThu": <span class="app-status-badge is-success">Đã thu</span>; break; case "DaTruCoc": <span class="app-status-badge is-info">Đã trừ cọc · phi tiền mặt</span>; break; case "DaHuy": <span class="app-status-badge is-neutral">Đã hủy</span>; break; default: <span class="app-status-badge is-neutral">@item.TrangThai</span>; break; }</td><td data-label="Thao tác">@if (item.TrangThai == QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiChuaXuLy) { <form asp-action="Huy" method="post" data-confirm="Hủy khoản phát sinh này?">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="hopDongId" value="@item.HopDongId" /><button class="btn btn-sm btn-outline-danger">Hủy khoản</button></form> } else { <span class="contract-finance-locked-note">Đã khóa theo trạng thái</span> }</td></tr> }</tbody></table></div> }</section>
    </div>
</div>
@section Scripts { <script src="~/js/contract-finance.js" asp-append-version="true"></script> }
