@model IEnumerable<QuanLyNhaTro.Models.KhoanPhatSinhHopDong>
@{
    var hopDong = ViewBag.HopDong as QuanLyNhaTro.Models.HopDong;
    ViewData["Title"] = "Khoan phat sinh";
    ViewData["ActiveMenu"] = "hopdong";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-controller="HopDong" asp-action="Details" asp-route-id="@hopDong?.Id"
       class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h5 class="mb-0">Khoan phat sinh - @hopDong?.Phong?.TenPhong</h5>
        <div class="text-muted small">HD #@hopDong?.Id</div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Them khoan phat sinh</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HopDongId" value="@hopDong?.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ngay phat sinh</label>
                        <input name="NgayPhatSinh" type="date" class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Loai khoan</label>
                        <select name="LoaiKhoan" class="form-select">
                            <option value="HuHongTaiSan">Den bu hu hong tai san</option>
                            <option value="MatChiaKhoa">Mat chia khoa/the xe</option>
                            <option value="PhatViPham">Phat vi pham</option>
                            <option value="PhuThu">Phu thu</option>
                            <option value="Khac">Khac</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mo ta</label>
                        <input name="MoTa" class="form-control" maxlength="500"
                               placeholder="VD: Lam hong quat tran phong" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">So tien</label>
                        <input name="SoTien" type="number" min="1" step="1" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ghi chu</label>
                        <input name="GhiChu" class="form-control" maxlength="255" />
                    </div>
                    <button class="btn btn-primary w-100">Luu khoan phat sinh</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Danh sach khoan phat sinh</div>
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Ngay</th>
                            <th>Noi dung</th>
                            <th class="text-end">So tien</th>
                            <th>Trang thai</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.NgayPhatSinh.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="fw-semibold">@item.MoTa</div>
                                    <div class="text-muted small">@item.LoaiKhoan @item.GhiChu</div>
                                </td>
                                <td class="text-end">@item.SoTien.ToString("N0") d</td>
                                <td>@Html.Raw(TrangThaiBadge(item))</td>
                                <td class="text-end">
                                    @if (item.TrangThai == QuanLyNhaTro.Models.KhoanPhatSinhHopDong.TrangThaiChuaXuLy)
                                    {
                                        <form asp-action="Huy" method="post"
                                              onsubmit="return confirm('Huy khoan phat sinh nay?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="hopDongId" value="@item.HopDongId" />
                                            <button class="btn btn-sm btn-outline-danger">Huy</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Chua co khoan phat sinh.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@functions {
    static string TrangThaiBadge(QuanLyNhaTro.Models.KhoanPhatSinhHopDong item) => item.TrangThai switch
    {
        "ChuaXuLy" => $"<span class='badge bg-warning text-dark'>Chua xu ly ({item.SoTienConLai:N0} d)</span>",
        "DaDuaVaoHoaDon" => $"<span class='badge bg-info text-dark'>Da dua vao hoa don #{item.HoaDonId}</span>",
        "DaThu" => "<span class='badge bg-success'>Da thu</span>",
        "DaTruCoc" => "<span class='badge bg-primary'>Da tru coc</span>",
        "DaHuy" => "<span class='badge bg-secondary'>Da huy</span>",
        _ => $"<span class='badge bg-light text-dark border'>{item.TrangThai}</span>"
    };
}
